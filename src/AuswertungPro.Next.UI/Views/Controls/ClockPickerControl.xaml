<UserControl x:Class="AuswertungPro.Next.UI.Views.Controls.ClockPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="160"
             Height="160">
    <Grid>
        <Canvas x:Name="FaceCanvas" Background="Transparent">
            <!-- Rohrleitungsquerschnitt: Rohrwand (aeusserer Ring) -->
            <Ellipse x:Name="PipeWall"
                     Stroke="#9EAEC4"
                     StrokeThickness="10"
                     Fill="Transparent"/>
            <!-- Rohrleitungsquerschnitt: Innenraum -->
            <Ellipse x:Name="PipeInterior"
                     Stroke="#CDD6E4"
                     StrokeThickness="1"
                     Fill="#F0F3F8"/>
            <!-- Markierungspunkt (gewaehlte Stunde) -->
            <Ellipse x:Name="PointMarker"
                     Width="12"
                     Height="12"
                     Fill="#16A34A"
                     Opacity="0.7"
                     Visibility="Collapsed"/>
            <!-- Mittelpunkt -->
            <Ellipse x:Name="CenterDot"
                     Width="6"
                     Height="6"
                     Fill="#1C2536"/>
        </Canvas>
    </Grid>
</UserControl>
