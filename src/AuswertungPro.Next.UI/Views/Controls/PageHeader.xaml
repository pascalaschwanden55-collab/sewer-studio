<UserControl x:Class="AuswertungPro.Next.UI.Views.Controls.PageHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="PageHeaderRoot">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <!-- Phase 3.3: Zentrales PageHeader-Control. Vereinheitlicht Titel +
         Subtitel + optionaler Action-Slot rechts. Sieht in jeder Page
         identisch aus. Spart Boilerplate.

         Verwendung:
           <ctrl:PageHeader Title="Druckcenter"
                            Subtitle="Filterbarer Ausdruck mit Kostenuebersicht">
             <ctrl:PageHeader.Actions>
               <Button Content="Aktualisieren" Command="..." />
             </ctrl:PageHeader.Actions>
           </ctrl:PageHeader>
    -->
    <Border Padding="14"
            Margin="0,0,0,10"
            Style="{DynamicResource Card}">
        <DockPanel LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="{Binding Title, ElementName=PageHeaderRoot}"
                           FontSize="{StaticResource TypeH2}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"/>
                <TextBlock Text="{Binding Subtitle, ElementName=PageHeaderRoot}"
                           FontSize="{StaticResource TypeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasSubtitle, ElementName=PageHeaderRoot, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <ContentPresenter DockPanel.Dock="Right"
                              Content="{Binding Actions, ElementName=PageHeaderRoot}"
                              VerticalAlignment="Center"/>
        </DockPanel>
    </Border>
</UserControl>
