<UserControl x:Class="AuswertungPro.Next.UI.Views.Controls.ClockRangePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="240"
             Height="240">
    <Grid>
        <Canvas x:Name="FaceCanvas" Background="Transparent">
            <!-- Zifferblatt -->
            <Ellipse x:Name="Face"
                     Stroke="#333"
                     StrokeThickness="1.5"
                     Fill="White"/>
            <!-- Bereichs-Sektor (Von bis Bis, im Uhrzeigersinn) -->
            <Path x:Name="RangeArc"
                  Fill="#44FF8C00"
                  Stroke="#FF8C00"
                  StrokeThickness="1.5"
                  Visibility="Collapsed"/>
            <!-- Zeiger Von -->
            <Line x:Name="HandVon"
                  Stroke="#FF8C00"
                  StrokeThickness="3"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Visibility="Collapsed"/>
            <!-- Zeiger Bis -->
            <Line x:Name="HandBis"
                  Stroke="#1F4E9E"
                  StrokeThickness="3"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Visibility="Collapsed"/>
            <!-- Mittelpunkt -->
            <Ellipse x:Name="CenterDot"
                     Width="8"
                     Height="8"
                     Fill="#333"/>
        </Canvas>
        <!-- Status-Anzeige -->
        <TextBlock x:Name="StatusText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   FontSize="11"
                   Foreground="#666"
                   Margin="0,0,0,2"/>
    </Grid>
</UserControl>
