<Window x:Class="AuswertungPro.Next.UI.Views.Windows.ImageAnnotationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bild-Bibliothek — Manuelles Annotieren"
        Height="900" Width="1400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Zeile 0: Ordner-Auswahl + Navigation ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource CardBrush}" CornerRadius="6"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Padding="12,10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Bildordner:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding FolderPath}" IsReadOnly="True"
                         Padding="6,4" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Ordner waehlen..." Click="BrowseFolder_Click"
                        Padding="12,4" Margin="0,0,16,0"/>

                <Button Grid.Column="3" Content="◀" Click="Previous_Click"
                        Padding="10,4" FontSize="{StaticResource TypeH4}" Margin="0,0,4,0"
                        ToolTip="Vorheriges Bild (Pfeil links)"/>
                <TextBlock Grid.Column="4" Text="{Binding PositionText}" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="4,0,4,0" MinWidth="70"
                           TextAlignment="Center"/>
                <Button Grid.Column="5" Content="▶" Click="Next_Click"
                        Padding="10,4" FontSize="{StaticResource TypeH4}" Margin="4,0,0,0"
                        ToolTip="Naechstes Bild (Pfeil rechts)"/>
                <TextBlock Grid.Column="6" Text="{Binding CurrentFileName}"
                           Foreground="{DynamicResource MutedBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- ═══ Zeile 1: Bild-Viewer mit Annotations-Canvas ═══ -->
        <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="6"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Margin="0,0,0,8">
            <Grid>
                <Image x:Name="FrameImage" Source="{Binding CurrentImage}" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False"/>

                <!-- Anzeige-Canvas: zeigt gezeichnetes Rechteck -->
                <Canvas x:Name="DisplayCanvas" IsHitTestVisible="False" ClipToBounds="True"
                        HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Zeichen-Canvas: immer aktiv -->
                <Canvas x:Name="AnnotationCanvas" Background="Transparent" ClipToBounds="True"
                        Cursor="Cross"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        MouseLeftButtonDown="AnnotationCanvas_MouseDown"
                        MouseMove="AnnotationCanvas_MouseMove"
                        MouseLeftButtonUp="AnnotationCanvas_MouseUp"
                        MouseRightButtonDown="AnnotationCanvas_RightClick"
                        MouseRightButtonUp="AnnotationCanvas_RightUp"/>

                <TextBlock Text="Ordner waehlen um Bilder zu laden" FontSize="{StaticResource TypeBodyLarge}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentImage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ═══ Zeile 2: Eingabefelder ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource CardBrush}" CornerRadius="6"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Padding="12,10" Margin="0,0,0,8">
            <StackPanel>
                <!-- Zeile 1: Code + Meter + Severity + Uhr + % -->
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Code:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <TextBox x:Name="TxtCode" Width="110"
                             Text="{Binding VsaCode, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" FontSize="15" FontWeight="Bold"
                             CharacterCasing="Upper"
                             ToolTip="VSA-Code (z.B. BAB, BCA, BBB)"/>
                    <Button Content="Katalog..." Click="OpenCodePicker_Click"
                            Padding="6,4" Margin="4,0,0,0"
                            ToolTip="Code aus Katalog waehlen (C)"/>

                    <TextBlock Text="Meter:" VerticalAlignment="Center" Margin="14,0,6,0"/>
                    <TextBox Width="60"
                             Text="{Binding MeterText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" TextAlignment="Center"
                             ToolTip="Meterstand in der Haltung (z.B. 2.79)"/>

                    <TextBlock Text="Sev:" VerticalAlignment="Center" Margin="14,0,6,0"/>
                    <TextBox Width="40"
                             Text="{Binding SeverityText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" TextAlignment="Center"
                             ToolTip="Severity 1-5"/>

                    <TextBlock Text="Uhr:" VerticalAlignment="Center" Margin="14,0,6,0"/>
                    <TextBox Width="40"
                             Text="{Binding ClockText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" TextAlignment="Center"
                             ToolTip="Uhrlage (z.B. 3, 6, 12)"/>

                    <TextBlock Text="%" VerticalAlignment="Center" Margin="14,0,6,0"/>
                    <TextBox Width="40"
                             Text="{Binding ExtentText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" TextAlignment="Center"
                             ToolTip="Umfang in Prozent (z.B. 25)"/>

                    <TextBlock Text="Notiz:" VerticalAlignment="Center" Margin="14,0,6,0"/>
                    <TextBox Width="180"
                             Text="{Binding Notiz, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4"
                             ToolTip="Freitext-Beschreibung"/>
                </WrapPanel>

                <!-- Zeile 2: Aktionen -->
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Ring (R)" Click="ToggleRingMode_Click"
                            Padding="10,5" Margin="0,0,8,0"
                            ToolTip="Ring-Modus: Zwei Kreise setzen — markiert den Bereich zwischen innerem und aeusserem Ring (z.B. Rohrwand)"/>

                    <Button Content="Bogen (B)" Click="ToggleArcMode_Click"
                            Padding="10,5" Margin="0,0,8,0"
                            ToolTip="Bogen-Modus: 3 Punkte setzen (Start, Kruemmung, Ende) — markiert einen Rohrbogen (BCC)"/>

<Button Content="Ganzes Bild (G)" Click="SelectFullImage_Click"
                            Padding="10,5" Margin="0,0,8,0"
                            ToolTip="Ganzes Bild als Bereich markieren — fuer Gesamtbefunde wie BCD, BCE, BDA"/>

                    <Button Content="Speichern (Enter)"
                            Command="{Binding SaveAnnotationCommand}"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            Padding="16,5" Margin="0,0,8,0" FontWeight="SemiBold"
                            ToolTip="Annotation speichern"/>

                    <Button Content="Kein Fund (N)"
                            Command="{Binding MarkNoFindingCommand}"
                            Padding="12,5" Margin="0,0,8,0"
                            ToolTip="Bild als Negativ-Beispiel speichern (kein Befund sichtbar)"/>

                    <Button Content="Skip (S)"
                            Command="{Binding SkipImageCommand}"
                            Padding="12,5"
                            ToolTip="Bild ueberspringen ohne Annotation"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ═══ Zeile 3: Statusleiste ═══ -->
        <Border Grid.Row="3" Background="{DynamicResource HeaderBrush}" CornerRadius="6"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}">
                    <Run Text="Annotiert: "/><Run Text="{Binding AnnotatedCount, Mode=OneWay}"/>
                    <Run Text=" / "/><Run Text="{Binding ImageCount, Mode=OneWay}"/>
                </TextBlock>

                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           Foreground="{DynamicResource MutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2" Foreground="{DynamicResource MutedBrush}" FontSize="{StaticResource TypeCaption}">
                    <Run Text="Enter=Speichern  C=Katalog  R=Ring  B=Bogen  G=Ganzes Bild  N=Kein Fund  S=Skip  ←→=Nav  Esc=Reset"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
