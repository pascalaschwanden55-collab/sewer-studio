<Window x:Class="AuswertungPro.Next.UI.Views.Windows.PhotoMeasurementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhotoAssistant — Foto vermessen"
        Width="1100" Height="750"
        MinWidth="900" MinHeight="650"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- ToggleButton fuer Werkzeuge -->
        <Style x:Key="PhotoToolBtn" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="6,3"
                                ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action-Button (OK / Abbrechen) -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="12,4"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertikaler Slider (Fuellstand / Kamerahoehe) -->
        <Style x:Key="PhotoSlider" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="IsDirectionReversed" Value="False"/>
            <Setter Property="TickFrequency" Value="10"/>
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
        </Style>

        <!-- Preset-Button (Uhr-Position / Winkel) -->
        <Style x:Key="PresetBtn" TargetType="Button">
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="4,2"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Hauptbereich -->
            <RowDefinition Height="Auto"/>  <!-- Winkel-Panel -->
            <RowDefinition Height="Auto"/>  <!-- Statusbar -->
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0: TOOLBAR ═══ -->
        <Border Grid.Row="0" Padding="8,6" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource ColorHeader}"/>
            </Border.Background>
            <WrapPanel Orientation="Horizontal">
                <!-- 1. Kalibrierung (immer zuerst) -->
                <ToggleButton x:Name="BtnToolCalib" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Kalibrierung: Referenzlinie ueber bekannten Rohrdurchmesser ziehen (DN)">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Line X1="2" Y1="12" X2="22" Y2="12" Stroke="#67E8F9" StrokeThickness="2"/>
                            <Line X1="2" Y1="8" X2="2" Y2="16" Stroke="#67E8F9" StrokeThickness="2"/>
                            <Line X1="22" Y1="8" X2="22" Y2="16" Stroke="#67E8F9" StrokeThickness="2"/>
                            <TextBlock Text="DN" FontSize="8" FontWeight="Bold" Foreground="#67E8F9"
                                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-2,0,0"/>
                        </Grid>
                        <TextBlock Text="Kalibrieren" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>

                <!-- 2. Markieren: Rechteck fuer KI-Korrektur -->
                <ToggleButton x:Name="BtnToolMarkRect" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Bereich markieren: Rechteck um Schaden/Beobachtung fuer KI-Training">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Rectangle Width="18" Height="14" Stroke="#4ADE80" StrokeThickness="2"
                                       StrokeDashArray="3,1.5"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="+" FontSize="{StaticResource TypeCaption}" FontWeight="Bold" Foreground="#4ADE80"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Markieren" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>

                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,6"/>

                <!-- 3. Messen: Lineal -->
                <ToggleButton x:Name="BtnToolRuler" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Lineal: Distanz in mm messen (Drag-Linie zwischen 2 Punkten)">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Line X1="3" Y1="20" X2="21" Y2="4" Stroke="White" StrokeThickness="2"/>
                            <Ellipse Width="5" Height="5" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="1,0,0,1"/>
                            <Ellipse Width="5" Height="5" Fill="White" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,1,1,0"/>
                            <TextBlock Text="mm" FontSize="7" FontWeight="Bold" Foreground="#CBD5E1"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Lineal" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="BtnToolPipeSurface" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Rohroberflaeche: Distanz zwischen 2 Punkten auf der Rohrwand messen">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Path Data="M 3,16 Q 12,5 21,16" Stroke="#00FF00" StrokeThickness="2" Fill="Transparent"/>
                            <Line X1="6" Y1="15" X2="18" Y2="15" Stroke="#00FF00" StrokeThickness="1.5" StrokeDashArray="2,1"/>
                            <TextBlock Text="R" FontSize="8" FontWeight="Bold" Foreground="#00FF00"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Oberflaeche" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="BtnToolCrack" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Rissbreite: Breite mit 2 Punkten quer zum Riss messen">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Path Data="M 5,4 C 12,8 8,14 17,20" Stroke="#FF3333" StrokeThickness="1.5" Fill="Transparent"/>
                            <Line X1="6" Y1="12" X2="18" Y2="12" Stroke="#FF3333" StrokeThickness="2"/>
                            <Ellipse Width="4" Height="4" Fill="#FF3333" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            <Ellipse Width="4" Height="4" Fill="#FF3333" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        </Grid>
                        <TextBlock Text="Rissbreite" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="BtnToolJointOffset" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Muffenversatz: Versatz in mm und Prozent des DN messen">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Line X1="5" Y1="8" X2="18" Y2="8" Stroke="#FF69B4" StrokeThickness="2"/>
                            <Line X1="8" Y1="16" X2="21" Y2="16" Stroke="#FF69B4" StrokeThickness="2"/>
                            <Line X1="12" Y1="8" X2="12" Y2="16" Stroke="#FF69B4" StrokeThickness="1.5" StrokeDashArray="2,1"/>
                        </Grid>
                        <TextBlock Text="Versatz" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>

                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,6"/>

                <!-- 3. Fuellstand-Werkzeuge -->
                <ToggleButton x:Name="BtnToolWater" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Wasserstand: Fuellhoehe in % vom Querschnitt">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Ellipse Width="22" Height="22" Stroke="#93C5FD" StrokeThickness="1.5"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border Height="10" VerticalAlignment="Bottom" Margin="3,0,3,1"
                                    Background="#6093C5FD" CornerRadius="0,0,8,8"/>
                            <Line X1="2" Y1="14" X2="22" Y2="14" Stroke="#93C5FD" StrokeThickness="1.5"
                                  StrokeDashArray="2,2"/>
                        </Grid>
                        <TextBlock Text="Wasser" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="BtnToolDeposit" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Ablagerung: Sedimenthoehe in % vom Querschnitt">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Ellipse Width="22" Height="22" Stroke="{DynamicResource StatusOrangeBrush}" StrokeThickness="1.5"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border Height="8" VerticalAlignment="Bottom" Margin="3,0,3,1"
                                    Background="#80F59E0B" CornerRadius="0,0,8,8"/>
                        </Grid>
                        <TextBlock Text="Ablagerung" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="BtnToolObstacle" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Hindernis: Querschnittsverringerung von oben (Scheitel)">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Ellipse Width="22" Height="22" Stroke="#F87171" StrokeThickness="1.5"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border Height="8" VerticalAlignment="Top" Margin="3,1,3,0"
                                    Background="#80F87171" CornerRadius="8,8,0,0"/>
                            <TextBlock Text="!" FontSize="{StaticResource TypeSmall}" FontWeight="Bold" Foreground="#FCA5A5"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Hindernis" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>

                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,6"/>

                <!-- 4. Querschnitt -->
                <ToggleButton x:Name="BtnToolCrossSection" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Querschnittsverminderung: Freihand-Polygon um blockierten Bereich">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Ellipse Width="22" Height="22" Stroke="#C4B5FD" StrokeThickness="1.5"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Polygon Points="8,6 16,6 18,12 14,18 10,18 6,12"
                                     Stroke="#C4B5FD" StrokeThickness="1" StrokeDashArray="2,1"
                                     Fill="#50C4B5FD"/>
                            <TextBlock Text="%" FontSize="9" FontWeight="Bold" Foreground="#C4B5FD"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Querschnitt" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>

                <!-- 5. Deformation -->
                <ToggleButton x:Name="BtnToolDeform" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Deformation: 4 Punkte auf Rohrwand klicken (oben, unten, links, rechts)">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Ellipse Width="22" Height="20" Stroke="#FBBF24" StrokeThickness="1.5"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="22" Height="22" Stroke="White" StrokeThickness="1"
                                     StrokeDashArray="3,2" Opacity="0.5"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Line X1="12" Y1="2" X2="12" Y2="22" Stroke="#FBBF24" StrokeThickness="1"
                                  StrokeDashArray="1,2" Opacity="0.8"/>
                        </Grid>
                        <TextBlock Text="Deformation" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>

                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,6"/>

                <!-- 6. Anschluss -->
                <ToggleButton x:Name="BtnToolConnection" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Anschluss: Hoehe und Breite der Oeffnung messen">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Ellipse Width="14" Height="14" Stroke="#34D399" StrokeThickness="2"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Line X1="17" Y1="7" X2="22" Y2="2" Stroke="#34D399" StrokeThickness="1.5"/>
                        </Grid>
                        <TextBlock Text="Anschluss" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>

                <!-- 7. Abzweig - LEGACY, ersetzt durch BtnToolConnection (Mondsichel-Schablone) -->
                <ToggleButton x:Name="BtnToolLateral" Style="{StaticResource PhotoToolBtn}"
                              Visibility="Collapsed"
                              ToolTip="Abzweig: Einmuendungswinkel messen">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Line X1="4" Y1="12" X2="20" Y2="12" Stroke="#FCA5A5" StrokeThickness="2"/>
                            <Line X1="14" Y1="12" X2="22" Y2="4" Stroke="#FCA5A5" StrokeThickness="2"/>
                            <TextBlock Text="&#x2220;" FontSize="{StaticResource TypeMicro}" Foreground="#FCA5A5"
                                       HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0"/>
                        </Grid>
                        <TextBlock Text="Abzweig" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>

                <!-- 8. Bogen -->
                <ToggleButton x:Name="BtnToolBend" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Bogen: Kruemmungsradius abschaetzen">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Path Data="M 4,18 Q 12,2 20,18" Stroke="#FDBA74" StrokeThickness="2" Fill="Transparent"/>
                            <Ellipse Width="4" Height="4" Fill="#FDBA74" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                            <Ellipse Width="4" Height="4" Fill="#FDBA74" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,2"/>
                        </Grid>
                        <TextBlock Text="Bogen" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>

                <!-- 9. Ringriss: 2 Klicks (Mittelpunkt + Ringpunkt) → 12 BBoxes entlang Umfang -->
                <ToggleButton x:Name="BtnToolRingBBox" Style="{StaticResource PhotoToolBtn}"
                              ToolTip="Ringriss: Mittelpunkt + Punkt auf Riss klicken → 12 BBoxes fuer 360° Riss">
                    <StackPanel>
                        <Grid Width="24" Height="24">
                            <Ellipse Width="20" Height="20" Stroke="#F472B6" StrokeThickness="1.5" StrokeDashArray="2,1" Fill="Transparent" Margin="2"/>
                            <!-- 4 kleine Kaestchen zur Andeutung der BBoxes -->
                            <Rectangle Width="5" Height="5" Stroke="#F472B6" StrokeThickness="1" Fill="#33F472B6" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                            <Rectangle Width="5" Height="5" Stroke="#F472B6" StrokeThickness="1" Fill="#33F472B6" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <Rectangle Width="5" Height="5" Stroke="#F472B6" StrokeThickness="1" Fill="#33F472B6" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                            <Rectangle Width="5" Height="5" Stroke="#F472B6" StrokeThickness="1" Fill="#33F472B6" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Ringriss" FontSize="9" HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </ToggleButton>
            </WrapPanel>
        </Border>

        <!-- ═══ ROW 1: HAUPTBEREICH ═══ -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Fuellstand-Slider -->
                <ColumnDefinition Width="*"/>     <!-- Foto + Canvas -->
                <ColumnDefinition Width="Auto"/>  <!-- Rechtes Panel -->
            </Grid.ColumnDefinitions>

            <!-- Links: Fuellstand-Slider -->
            <Border x:Name="PanelFillSlider" Grid.Column="0" Padding="4" Margin="0,0,6,0"
                    Visibility="Collapsed">
                <StackPanel VerticalAlignment="Stretch">
                    <TextBlock Text="100%" FontSize="9" Foreground="{DynamicResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <Slider x:Name="SliderFill" Style="{StaticResource PhotoSlider}"
                            VerticalAlignment="Stretch" Height="Auto"
                            Value="0" SmallChange="1" LargeChange="5"
                            ValueChanged="SliderFill_ValueChanged"/>
                    <TextBlock Text="0%" FontSize="9" Foreground="{DynamicResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Mitte: Foto + Canvas -->
            <Border Grid.Column="1" Background="Black" CornerRadius="6" ClipToBounds="True">
                <Grid x:Name="PhotoContainer" SizeChanged="PhotoContainer_SizeChanged">
                    <Image x:Name="PhotoImage" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Canvas x:Name="OverlayCanvas" Background="Transparent"
                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                            MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                            MouseMove="Canvas_MouseMove"
                            MouseWheel="Canvas_MouseWheel"
                            MouseLeave="Canvas_MouseLeave"
                            ClipToBounds="True"/>
                    <!-- Live-Werte-Overlay (Foto-Assistent) - links oben -->
                    <Border x:Name="PaLiveValuesBorder"
                            Background="#CC000000" CornerRadius="4" Padding="8,5"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="6,6,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="PaLiveValuesText"
                                   Foreground="#F5F5DC" FontFamily="Consolas" FontSize="{StaticResource TypeCaption}"
                                   Text="" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Rechts: Kamera-Slider + OSD + Buttons -->
            <Border Grid.Column="2" Padding="8,0,0,0" Width="100">
                <StackPanel>
                    <!-- Kamera-Hoehe -->
                    <TextBlock x:Name="TxtCamLabel" Text="Kamera" FontSize="{StaticResource TypeMicro}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,2"
                               Visibility="Collapsed"/>
                    <Slider x:Name="SliderCamera" Style="{StaticResource PhotoSlider}"
                            Height="120" Value="50"
                            ValueChanged="SliderCamera_ValueChanged"
                            Visibility="Collapsed"/>

                    <!-- OSD -->
                    <Border Background="{DynamicResource HeaderBrush}" CornerRadius="4" Padding="6" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock x:Name="TxtDnInfo" Text="DN —" FontSize="{StaticResource TypeMicro}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TxtMeasureInfo" Text="" FontSize="{StaticResource TypeSmall}"
                                       FontWeight="Bold" Foreground="White"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Foto-Assistent (BAA / BAJ / BCA) ═══ -->
                    <StackPanel x:Name="PaSliderPanel" Visibility="Collapsed" Margin="0,8,0,0">
                        <TextBlock Text="Ø Hauptrohr (mm)" FontSize="9"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Slider x:Name="PaSliderPipeDn" Minimum="100" Maximum="1000"
                                Value="300" TickFrequency="50" IsSnapToTickEnabled="False"
                                ValueChanged="PaSliderPipeDn_ValueChanged"/>
                        <TextBlock x:Name="PaTxtPipeDn" Text="300 mm" FontSize="{StaticResource TypeMicro}"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>

                        <StackPanel x:Name="PaLatDnPanel" Visibility="Collapsed">
                            <TextBlock Text="Lateral Ø %" FontSize="9"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Slider x:Name="PaSliderLatDn" Minimum="20" Maximum="100"
                                    Value="50" TickFrequency="10"
                                    ValueChanged="PaSliderLatDn_ValueChanged"/>
                            <TextBlock x:Name="PaTxtLatDn" Text="50 %" FontSize="{StaticResource TypeMicro}"
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- VSA-Code-Vorschlag -->
                    <Border x:Name="PaVsaCodeBox" Background="#1F2937" CornerRadius="4"
                            Padding="6" Margin="0,8,0,0" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="VSA-CODE-VORSCHLAG" FontSize="8" FontWeight="Bold"
                                       Foreground="#9CA3AF"/>
                            <TextBlock x:Name="PaVsaCodeText" Text="—" FontSize="{StaticResource TypeBodyLarge}"
                                       FontWeight="Bold" Foreground="#FBBF24"/>
                            <TextBlock x:Name="PaVsaDescriptionText" Text="" FontSize="9"
                                       Foreground="White" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Spacer -->
                    <Border Height="1" Margin="0,12" Background="{DynamicResource BorderBrush}"/>

                    <!-- OK / Abbrechen -->
                    <Button x:Name="BtnOk" Content="OK &#x2714;" Style="{StaticResource ActionBtn}"
                            Background="#22C55E" Click="BtnOk_Click"
                            ToolTip="Alle Messungen und Markierungen uebernehmen und Fenster schliessen"/>
                    <Button x:Name="BtnCancel" Content="Abbrechen" Style="{StaticResource ActionBtn}"
                            Background="#EF4444" Click="BtnCancel_Click"
                            ToolTip="Alle Aenderungen verwerfen und Fenster ohne Speichern schliessen"/>

                    <!-- Undo -->
                    <Button x:Name="BtnUndo" Content="&#x21B6; Undo" Style="{StaticResource ActionBtn}"
                            Background="#6366F1" Click="BtnUndo_Click" Margin="0,8,0,0"
                            ToolTip="Letzte Zeichnung oder Messung rueckgaengig machen"
                            Visibility="Collapsed"/>
                    <Button x:Name="BtnDelete" Content="&#x2716; Loeschen" Style="{StaticResource ActionBtn}"
                            Background="#EF4444" Click="BtnDelete_Click" Margin="0,4,0,0"
                            ToolTip="Ausgewaehlte Markierung oder Messung dauerhaft vom Foto entfernen"
                            Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ ROW 2: WINKEL-PANEL (nur Abzweig / Bogen) ═══ -->
        <Border x:Name="PanelAngle" Grid.Row="2" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}"
                Visibility="Collapsed">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource ColorHeader}"/>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Position (Uhr) -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="POSITION (Uhr)" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,4"/>
                    <WrapPanel>
                        <Button Content="12h" Style="{StaticResource PresetBtn}" Tag="0"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 12 Uhr setzen — Scheitel (oben, 0 Grad)"/>
                        <Button Content="1h" Style="{StaticResource PresetBtn}" Tag="30"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 1 Uhr setzen — rechts oben (30 Grad)"/>
                        <Button Content="2h" Style="{StaticResource PresetBtn}" Tag="60"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 2 Uhr setzen — rechts oben (60 Grad)"/>
                        <Button Content="3h" Style="{StaticResource PresetBtn}" Tag="90"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 3 Uhr setzen — rechte Seite (90 Grad)"/>
                        <Button Content="4h" Style="{StaticResource PresetBtn}" Tag="120"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 4 Uhr setzen — rechts unten (120 Grad)"/>
                        <Button Content="5h" Style="{StaticResource PresetBtn}" Tag="150"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 5 Uhr setzen — rechts unten (150 Grad)"/>
                        <Button Content="6h" Style="{StaticResource PresetBtn}" Tag="180"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 6 Uhr setzen — Sohle (unten, 180 Grad)"/>
                        <Button Content="7h" Style="{StaticResource PresetBtn}" Tag="210"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 7 Uhr setzen — links unten (210 Grad)"/>
                        <Button Content="8h" Style="{StaticResource PresetBtn}" Tag="240"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 8 Uhr setzen — links unten (240 Grad)"/>
                        <Button Content="9h" Style="{StaticResource PresetBtn}" Tag="270"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 9 Uhr setzen — linke Seite (270 Grad)"/>
                        <Button Content="10h" Style="{StaticResource PresetBtn}" Tag="300"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 10 Uhr setzen — links oben (300 Grad)"/>
                        <Button Content="11h" Style="{StaticResource PresetBtn}" Tag="330"
                                Click="PositionPreset_Click"
                                ToolTip="Uhrlage 11 Uhr setzen — links oben (330 Grad)"/>
                    </WrapPanel>
                    <Slider x:Name="SliderPosition" Minimum="0" Maximum="360"
                            Value="0" TickFrequency="30" IsSnapToTickEnabled="False"
                            Margin="0,6,0,0"
                            ValueChanged="SliderPosition_ValueChanged"/>
                    <TextBlock x:Name="TxtPosition" Text="0°" FontSize="{StaticResource TypeCaption}"
                               Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Winkel -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="WINKEL" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,4"/>
                    <WrapPanel>
                        <Button Content="15°" Style="{StaticResource PresetBtn}" Tag="15"
                                Click="AnglePreset_Click"
                                ToolTip="Einmuendungswinkel auf 15 Grad setzen — sehr flacher Abzweig"/>
                        <Button Content="30°" Style="{StaticResource PresetBtn}" Tag="30"
                                Click="AnglePreset_Click"
                                ToolTip="Einmuendungswinkel auf 30 Grad setzen — flacher Abzweig"/>
                        <Button Content="45°" Style="{StaticResource PresetBtn}" Tag="45"
                                Click="AnglePreset_Click"
                                ToolTip="Einmuendungswinkel auf 45 Grad setzen — haeufigster Standardwinkel"/>
                        <Button Content="60°" Style="{StaticResource PresetBtn}" Tag="60"
                                Click="AnglePreset_Click"
                                ToolTip="Einmuendungswinkel auf 60 Grad setzen — steiler Abzweig"/>
                        <Button Content="90°" Style="{StaticResource PresetBtn}" Tag="90"
                                Click="AnglePreset_Click"
                                ToolTip="Einmuendungswinkel auf 90 Grad setzen — rechtwinkliger Anschluss"/>
                        <Button Content="135°" Style="{StaticResource PresetBtn}" Tag="135"
                                Click="AnglePreset_Click"
                                ToolTip="Einmuendungswinkel auf 135 Grad setzen — stumpfer Winkel"/>
                        <Button Content="150°" Style="{StaticResource PresetBtn}" Tag="150"
                                Click="AnglePreset_Click"
                                ToolTip="Einmuendungswinkel auf 150 Grad setzen — sehr stumpfer Winkel"/>
                    </WrapPanel>
                    <Slider x:Name="SliderAngle" Minimum="5" Maximum="175"
                            Value="45" TickFrequency="15" IsSnapToTickEnabled="False"
                            Margin="0,6,0,0"
                            ValueChanged="SliderAngle_ValueChanged"/>
                    <TextBlock x:Name="TxtAngle" Text="45°" FontSize="{StaticResource TypeCaption}"
                               Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ ROW 3: STATUSBAR ═══ -->
        <Border Grid.Row="3" Padding="12,6"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource ColorHeader}"/>
            </Border.Background>
            <TextBlock x:Name="TxtStatus"
                       Text="Werkzeug waehlen, um mit der Messung zu beginnen."
                       FontSize="{StaticResource TypeCaption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</Window>
