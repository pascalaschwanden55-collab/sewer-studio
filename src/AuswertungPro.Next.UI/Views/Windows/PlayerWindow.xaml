<Window x:Class="AuswertungPro.Next.UI.Views.Windows.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:ctrl="clr-namespace:AuswertungPro.Next.UI.Controls"
        Title="Video"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="PlayerCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Background" Value="{DynamicResource CardGlassBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="PlayerLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PlayerValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PlayerTimeText" TargetType="TextBlock" BasedOn="{StaticResource PlayerValueText}">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PlayerMetaCard" TargetType="Border">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <Style x:Key="PlayerButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PlayerPrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButtonAccent}">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="SpeedToggleButton" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource NeonCyanBrush}"/>
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource NeonCyanBrush}"/>
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource HeaderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Sidebar Section-Label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Statistik-Kachel -->
        <Style x:Key="StatTile" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- Defekt-Aktionsbutton -->
        <Style x:Key="DefectActionBtn" TargetType="Button">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Header -->
            <RowDefinition Height="*"/>         <!-- Video + Seitenpanel -->
            <RowDefinition Height="Auto"/>      <!-- Coding-Werkzeuge (nur im Codier-Modus) -->
            <RowDefinition Height="Auto"/>      <!-- Pipe Graph Timeline (Codier-Modus) -->
            <RowDefinition Height="Auto"/>      <!-- Timeline -->
            <RowDefinition Height="Auto"/>      <!-- Controls -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PlayerCard}"
                Margin="0,0,0,12"
                Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,2,14,2"
                        Background="{DynamicResource NeonCyanBrush}"
                        CornerRadius="999"/>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Videoplayer"
                               Foreground="{DynamicResource NeonCyanBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="VideoNameText"
                               Margin="0,4,0,0"
                               Text="Video"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="VideoPathText"
                               Margin="0,4,0,0"
                               Style="{StaticResource PlayerLabelText}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Margin="16,0,0,0"
                        Style="{StaticResource PlayerMetaCard}"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Hotkeys"
                                   Style="{StaticResource PlayerLabelText}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="Space Pause, Pfeile +/-5s, +/- Geschwindigkeit"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="12"
                                   TextAlignment="Right"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Video-Bereich: Grid mit optionalem Seitenpanel -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Coding-Seitenpanel (nur sichtbar im Codier-Modus) -->
                <ColumnDefinition x:Name="CodingSidePanelColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Video + Overlays: Geschwister-Pattern (wie CodingModeWindow) -->
            <Grid Grid.Column="0">
                <!-- Video-Layer -->
                <vlc:VideoView x:Name="VideoView" Background="#FF000000"/>

                <!-- Coding Overlay-Canvas (Zeichenwerkzeuge, nur im Codier-Modus) -->
                <Canvas x:Name="CodingOverlayCanvas"
                        Background="Transparent"
                        ClipToBounds="True"
                        Visibility="Collapsed"
                        Cursor="Cross"
                        MouseLeftButtonDown="CodingCanvas_MouseLeftButtonDown"
                        MouseMove="CodingCanvas_MouseMove"
                        MouseLeftButtonUp="CodingCanvas_MouseLeftButtonUp"/>

                <!-- Detection overlay layer (hidden by default) -->
                <Grid x:Name="DetectionOverlayGrid"
                      Visibility="Collapsed"
                      IsHitTestVisible="False">
                    <Canvas x:Name="DetectionCanvas"
                            Background="Transparent"
                            IsHitTestVisible="False"
                            ClipToBounds="True"/>

                    <Border x:Name="AiStatusBadge"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="12" CornerRadius="8" Padding="10,5"
                            Background="#DD111318"
                            BorderBrush="{DynamicResource NeonCyanBrush}"
                            BorderThickness="1" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="AiStatusDot" Width="8" Height="8"
                                     Fill="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="AiStatusText" Text="KI aktiv"
                                       Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FindingSummaryPanel"
                            HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                            Background="#CC111318" Padding="12,8" Visibility="Collapsed">
                        <TextBlock x:Name="FindingSummaryText"
                                   Foreground="White" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </Grid>

                <!-- Kalibrierungs-Hinweis -->
                <Border x:Name="CodingCalibrationHint"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Margin="0,8,0,0" Background="#DD000000" CornerRadius="8"
                        Padding="16,8" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="KALIBRIERUNG" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource NeonCyanBrush}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtCodingCalibHint" FontSize="12" Foreground="White"
                                   TextWrapping="Wrap" MaxWidth="300"/>
                    </StackPanel>
                </Border>

                <!-- Mess-Anzeige -->
                <Border x:Name="CodingMeasurementPanel"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,8" Background="#CC000000" CornerRadius="8"
                        Padding="12,6" Visibility="Collapsed">
                    <TextBlock x:Name="TxtCodingMeasurement"
                               Foreground="White" FontSize="13"
                               FontFamily="Consolas, Cascadia Mono" HorizontalAlignment="Center"/>
                </Border>

                <!-- OSD-Meter Anzeige (KI-gelesener Meterstand, immer sichtbar im Codier-Modus) -->
                <Border x:Name="OsdMeterBadge"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="12" Padding="10,5"
                        Background="#DD111318" CornerRadius="8"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtOsdMeter"
                               Foreground="{DynamicResource NeonCyanBrush}"
                               FontFamily="Consolas, Cascadia Mono"
                               FontSize="14" FontWeight="Bold"/>
                </Border>
            </Grid>

            <!-- ── CODING SEITENPANEL (Mockup-Design) ── -->
            <Border x:Name="CodingSidePanel" Grid.Column="1"
                    Visibility="Collapsed"
                    Margin="8,0,0,0"
                    Background="{DynamicResource CardGlassBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    CornerRadius="14" Padding="12"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- ── 1. QualityGate Zonen-Legende ── -->
                        <Border Style="{StaticResource PlayerCard}" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#x2699;" FontSize="13" Margin="0,0,6,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="QUALITYGATE ZONEN" Style="{StaticResource SectionLabel}"
                                               Margin="0"/>
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <Border Width="12" Height="12" CornerRadius="3"
                                                Background="#22C55E" Margin="0,0,8,0"/>
                                        <TextBlock Text="Green (>=85%): Auto-Accept" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <Border Width="12" Height="12" CornerRadius="3"
                                                Background="#F59E0B" Margin="0,0,8,0"/>
                                        <TextBlock Text="Yellow (60-85%): Review empfohlen" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <Border Width="12" Height="12" CornerRadius="3"
                                                Background="#EF4444" Margin="0,0,8,0"/>
                                        <TextBlock Text="Red (&lt;60%): Manuell erforderlich" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── 2. Erkannte Defekte (erweiterte Ereignisliste) ── -->
                        <Border Style="{StaticResource PlayerCard}" Margin="0,0,0,8">
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                    <TextBlock Style="{StaticResource SectionLabel}" Margin="0">
                                        <Run Text="ERKANNTE DEFEKTE ("/>
                                        <Run x:Name="RunCodingDefectCount" Text="0"/>
                                        <Run Text=")"/>
                                    </TextBlock>
                                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run x:Name="RunCodingOpenCount" Text="0"/>
                                        <Run Text=" offen"/>
                                    </TextBlock>
                                </DockPanel>

                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Style="{StaticResource PlayerButton}" Padding="6,2"
                                            FontSize="10" Content="&#x1F4F7; Foto"
                                            Click="CodingTakePhoto_Click"
                                            ToolTip="Foto vom aktuellen Frame fuer ausgewaehltes Ereignis aufnehmen"/>
                                </StackPanel>

                                <ListBox x:Name="LstCodingEvents"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="12"
                                         Foreground="{DynamicResource TextBrush}"
                                         MaxHeight="240"
                                         MouseDoubleClick="CodingEvents_DoubleClick"
                                         SelectionChanged="CodingEvents_SelectionChanged">
                                    <ListBox.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Bearbeiten (Doppelklick)" Click="CodingEventEdit_Click"/>
                                            <MenuItem Header="Fotos anzeigen" Click="CodingEventShowPhotos_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Zum Zeitpunkt springen" Click="CodingEventSeek_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Loeschen" Click="CodingEventDelete_Click" Foreground="OrangeRed"/>
                                        </ContextMenu>
                                    </ListBox.ContextMenu>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
                                            <Setter Property="Margin" Value="0,2"/>
                                            <Setter Property="Padding" Value="6,4"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="8"
                                                                Padding="{TemplateBinding Padding}"
                                                                Cursor="Hand">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBrush}"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <!-- Zeile 1: Zone-Dot + Code + Beschreibung + Status -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse x:Name="ZoneDot" Grid.Column="0"
                                                             Width="8" Height="8"
                                                             Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Entry.Code}"
                                                               FontFamily="Consolas"
                                                               FontWeight="Bold" FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,6,0"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Entry.Beschreibung}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" x:Name="TxtStatusIcon"
                                                               FontSize="12" Margin="4,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                                <!-- Zeile 2: Distanz + Fotos + Konfidenz -->
                                                <Grid Margin="14,2,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" FontSize="10"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Margin="0,0,12,0">
                                                        <Run Text="&#x1F4CD;"/>
                                                        <Run Text="{Binding MeterAtCapture, StringFormat='{}{0:F2}m', Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="1" FontSize="10"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Margin="0,0,12,0">
                                                        <Run Text="{Binding PhotoIndicator, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="2" x:Name="TxtConfidence"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <!-- ── 3. Defekt-Details (bei Auswahl) ── -->
                        <Border x:Name="CodingDefectDetailPanel" Style="{StaticResource PlayerCard}"
                                Margin="0,0,0,8" Visibility="Collapsed">
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="CodingDefectDetailBorderBrush" Color="#3B82F6"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness Left="4" Top="0" Right="0" Bottom="0"/>
                            </Border.BorderThickness>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="&#x25B6;" FontSize="11" Margin="0,0,6,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="DEFEKT DETAILS" Style="{StaticResource SectionLabel}" Margin="0"/>
                                </StackPanel>

                                <!-- Code + Schweregrad -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="EN 13508-2 Code" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingDetailCode"
                                                       FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="Schweregrad" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingDetailSeverity"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Beschreibung -->
                                <Border Style="{StaticResource StatTile}" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="Beschreibung" FontSize="10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="TxtCodingDetailDescription"
                                                   FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Distanz + Position + Konfidenz -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource StatTile}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Distanz" FontSize="9"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtCodingDetailDistance"
                                                       FontFamily="Consolas" FontSize="12"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource StatTile}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Position" FontSize="9"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtCodingDetailClock"
                                                       FontFamily="Consolas" FontSize="12"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="4" Style="{StaticResource StatTile}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Konfidenz" FontSize="9"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtCodingDetailConfidence"
                                                       FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Status-Anzeige -->
                                <TextBlock x:Name="TxtCodingDetailStatus" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,6"/>

                                <!-- Aktionsbuttons: Akzeptieren / Bearbeiten / Ablehnen -->
                                <Grid x:Name="CodingDefectActionGrid" Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" x:Name="BtnCodingAcceptDefect"
                                            Style="{StaticResource DefectActionBtn}"
                                            Background="#16A34A"
                                            Click="CodingAcceptDefect_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x2713;" Margin="0,0,4,0"/>
                                            <TextBlock Text="Akzeptieren"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" x:Name="BtnCodingEditDefect"
                                            Style="{StaticResource DefectActionBtn}"
                                            Background="#D97706"
                                            Click="CodingEditDefect_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x2699;" Margin="0,0,4,0"/>
                                            <TextBlock Text="Bearbeiten"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="4" x:Name="BtnCodingRejectDefect"
                                            Style="{StaticResource DefectActionBtn}"
                                            Background="#DC2626"
                                            MinWidth="40"
                                            Click="CodingRejectDefect_Click">
                                        <TextBlock Text="&#x2717;" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── 4. Kalibrierung + Messung ── -->
                        <Border Style="{StaticResource PlayerCard}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="KALIBRIERUNG" Style="{StaticResource SectionLabel}"/>
                                <TextBlock x:Name="TxtCodingCalibDn" FontSize="12"
                                           Foreground="{DynamicResource TextBrush}" Text="DN: –"/>
                                <TextBlock x:Name="TxtCodingCalibStatus" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="Nicht kalibriert" Margin="0,0,0,6"/>

                                <TextBlock Text="MESSUNG" Style="{StaticResource SectionLabel}"/>
                                <TextBlock x:Name="TxtCodingQ1" FontSize="12" Foreground="{DynamicResource TextBrush}" Text="Q1: –"/>
                                <TextBlock x:Name="TxtCodingQ2" FontSize="12" Foreground="{DynamicResource TextBrush}" Text="Q2: –"/>
                                <TextBlock x:Name="TxtCodingClock" FontSize="12" Foreground="{DynamicResource TextBrush}" Text="Uhr: –"/>
                                <TextBlock x:Name="TxtCodingArc" FontSize="12" Foreground="{DynamicResource TextBrush}" Text="Bogen: –"/>
                            </StackPanel>
                        </Border>

                        <!-- ── 5. Codieren (manuell) ── -->
                        <Border Style="{StaticResource PlayerCard}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="CODIEREN" Style="{StaticResource SectionLabel}"/>
                                <Button x:Name="BtnCodingSelectCode"
                                        Style="{StaticResource PlayerPrimaryButton}"
                                        Content="Neues Ereignis erfassen"
                                        Padding="8,6" FontSize="12"
                                        Click="CodingSelectCode_Click"
                                        ToolTip="Oeffnet Editor mit Code-Auswahl, Fotos und VSA-Feldern"/>
                                <TextBlock x:Name="TxtCodingSelectedCode"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <!-- Unsichtbar aber vorhanden fuer Kompatibilitaet -->
                                <Button x:Name="BtnCodingCreateEvent"
                                        Visibility="Collapsed"
                                        Click="CodingCreateEvent_Click"
                                        IsEnabled="False"/>
                            </StackPanel>
                        </Border>

                        <!-- ── 6. Session-Statistik ── -->
                        <Border Style="{StaticResource PlayerCard}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="SESSION STATISTIK" Style="{StaticResource SectionLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="Auto-Akzeptiert" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingStatAutoAccepted"
                                                       Text="0" FontSize="20" FontWeight="Bold"
                                                       Foreground="#22C55E"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="Pending Review" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingStatPending"
                                                       Text="0" FontSize="20" FontWeight="Bold"
                                                       Foreground="#F59E0B"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="Manuell erforderlich" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingStatReviewRequired"
                                                       Text="0" FontSize="20" FontWeight="Bold"
                                                       Foreground="#EF4444"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="Avg. Konfidenz" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingStatAvgConfidence"
                                                       Text="–" FontSize="20" FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════ CODING-WERKZEUGE (nur im Codier-Modus sichtbar) ═══════ -->
        <Border x:Name="CodingToolbar" Grid.Row="2"
                Visibility="Collapsed"
                Style="{StaticResource PlayerCard}"
                Margin="0,0,0,8" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- Meter-Anzeige -->
                    <ColumnDefinition Width="Auto"/>   <!-- Werkzeuge -->
                    <ColumnDefinition Width="Auto"/>   <!-- KI-Status + Analyse -->
                    <ColumnDefinition Width="*"/>      <!-- Findings -->
                    <ColumnDefinition Width="Auto"/>   <!-- Beenden -->
                </Grid.ColumnDefinitions>

                <!-- Meter-Navigation -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button Style="{StaticResource PlayerButton}" Content="◀" Padding="8,6"
                            Click="CodingPrevious_Click" ToolTip="Zurueck (Step)"/>
                    <TextBlock x:Name="TxtCodingMeter"
                               FontFamily="Consolas, Cascadia Mono" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" Margin="8,0"
                               Text="0.00m"/>
                    <Button Style="{StaticResource PlayerButton}" Content="▶" Padding="8,6"
                            Click="CodingNext_Click" ToolTip="Weiter (Step)"/>
                    <TextBlock x:Name="TxtCodingRange"
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Werkzeuge -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Border Width="1" Height="28" Background="{DynamicResource BorderBrush}" Margin="0,0,8,0"/>
                    <ToggleButton x:Name="BtnCodingCalibrate" Style="{StaticResource SpeedToggleButton}"
                                  ToolTip="Kalibrieren" Click="CodingCalibrate_Click">
                        <TextBlock Text="⊕ Kalib." FontSize="11"/>
                    </ToggleButton>
                    <ToggleButton x:Name="BtnCodingLine" Style="{StaticResource SpeedToggleButton}"
                                  ToolTip="Linie messen" Click="CodingToolLine_Click">
                        <TextBlock Text="━ Linie" FontSize="11"/>
                    </ToggleButton>
                    <ToggleButton x:Name="BtnCodingArc" Style="{StaticResource SpeedToggleButton}"
                                  ToolTip="Bogen (Umfang)" Click="CodingToolArc_Click">
                        <TextBlock Text="⌒ Bogen" FontSize="11"/>
                    </ToggleButton>
                    <ToggleButton x:Name="BtnCodingRect" Style="{StaticResource SpeedToggleButton}"
                                  ToolTip="Flaeche" Click="CodingToolRect_Click">
                        <TextBlock Text="▢ Fläche" FontSize="11"/>
                    </ToggleButton>
                    <ToggleButton x:Name="BtnCodingPoint" Style="{StaticResource SpeedToggleButton}"
                                  ToolTip="Punkt" Click="CodingToolPoint_Click">
                        <TextBlock Text="● Punkt" FontSize="11"/>
                    </ToggleButton>
                    <ToggleButton x:Name="BtnCodingStretch" Style="{StaticResource SpeedToggleButton}"
                                  ToolTip="Strecke" Click="CodingToolStretch_Click">
                        <TextBlock Text="↔ Strecke" FontSize="11"/>
                    </ToggleButton>
                </StackPanel>

                <!-- KI-Status + Analyse -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Border Width="1" Height="28" Background="{DynamicResource BorderBrush}" Margin="0,0,8,0"/>
                    <Ellipse x:Name="CodingAiDot" Width="10" Height="10"
                             Fill="#94A3B8" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtCodingAiStatus" FontSize="11"
                               Foreground="{DynamicResource TextBrush}"
                               Text="KI Bereit" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button x:Name="BtnCodingAnalyze"
                            Style="{StaticResource PlayerPrimaryButton}"
                            Padding="10,5" FontSize="11"
                            Click="CodingAnalyzeFrame_Click"
                            ToolTip="Aktuellen Frame per KI analysieren">
                        <TextBlock Text="⚡ Analysieren"/>
                    </Button>
                </StackPanel>

                <!-- Aktuelle Position: Code am Zeitstempel (aus DataGrid) -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Naechster Code am aktuellen Meter -->
                    <Border x:Name="CodingCurrentCodeBadge"
                            Background="{DynamicResource HeaderBrush}" CornerRadius="8"
                            Padding="8,3" Margin="0,0,8,0" Visibility="Collapsed">
                        <TextBlock x:Name="TxtCodingCurrentCode"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NeonCyanBrush}"/>
                    </Border>

                    <!-- KI-Findings -->
                    <ItemsControl x:Name="CodingFindingsList" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource HeaderBrush}" CornerRadius="8"
                                        Padding="8,3" Margin="0,0,4,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Fill="{Binding SeverityBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding Label, Mode=OneWay}"/>
                                            <Run Text="{Binding VsaCode, StringFormat='[{0}]', Mode=OneWay}"
                                                 Foreground="{DynamicResource NeonCyanBrush}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Uebernehmen + Beenden -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Style="{StaticResource PlayerPrimaryButton}"
                            Padding="10,5"
                            Click="CodingApply_Click"
                            ToolTip="Codierung in Primaere Schaeden uebernehmen">
                        <TextBlock Text="Uebernehmen" FontSize="11" FontWeight="SemiBold"/>
                    </Button>
                    <Button Style="{StaticResource PlayerButton}"
                            Foreground="#EF4444" Margin="6,0,0,0"
                            Click="CodingModeExit_Click"
                            ToolTip="Codier-Modus beenden ohne Uebernahme">
                        <TextBlock Text="✕" FontSize="11"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ PIPE GRAPH TIMELINE (nur im Codier-Modus sichtbar) ═══════ -->
        <ctrl:PipeGraphTimeline Grid.Row="3" x:Name="PipeTimeline"
                                Margin="0,0,0,8"
                                Visibility="Collapsed"/>

        <Border Grid.Row="4"
                Style="{StaticResource PlayerCard}"
                Margin="0,0,0,12"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="CurrentTimeText"
                           Grid.Column="0"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource PlayerTimeText}"
                           Text="00:00"/>

                <Grid Grid.Column="1">
                    <!-- Quick-Scan heatmap overlay — below slider -->
                    <Canvas x:Name="HeatmapCanvas"
                            IsHitTestVisible="True"
                            VerticalAlignment="Center"
                            Height="6"
                            Margin="0,12,0,0"
                            ClipToBounds="True"/>
                    <Slider x:Name="PositionSlider"
                            Minimum="0"
                            Maximum="1000"
                            Margin="0,1"
                            IsMoveToPointEnabled="True"
                            ValueChanged="PositionSlider_ValueChanged"
                            ToolTip="Videoposition - ziehen fuer Live-Vorschau, klicken zum Springen"/>
                    <!-- Damage code marker overlay — positioned dynamically to match slider track -->
                    <Canvas x:Name="DamageMarkerCanvas"
                            IsHitTestVisible="True"
                            VerticalAlignment="Center"
                            Height="28"
                            ClipToBounds="False"/>
                </Grid>

                <TextBlock x:Name="DurationText"
                           Grid.Column="2"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource PlayerTimeText}"
                           Text="00:00"/>
            </Grid>
        </Border>

        <Border Grid.Row="5"
                Style="{StaticResource PlayerCard}"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" Margin="0,0,18,0" VerticalAlignment="Center">
                    <Button Style="{StaticResource PlayerPrimaryButton}" Margin="0,0,6,0" Click="Play_Click"
                            ToolTip="Video abspielen (Leertaste)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Play" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PlayerButton}" Margin="0,0,6,0" Click="Pause_Click"
                            ToolTip="Video pausieren (Leertaste)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Pause" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PlayerButton}" Click="Stop_Click"
                            ToolTip="Wiedergabe stoppen und zum Anfang zuruecksetzen">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Stop" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Height="24" Margin="8,0"
                            Background="{DynamicResource BorderBrush}"/>

                    <ToggleButton x:Name="QuickScanButton"
                                  Style="{StaticResource SpeedToggleButton}"
                                  Margin="0,0,6,0"
                                  Click="QuickScan_Click"
                                  ToolTip="Schnell-Scan: KI-Heatmap auf der Timeline erzeugen">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Schnell-Scan" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <TextBlock x:Name="QuickScanStatusText"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="Collapsed"/>

                    <Border Width="1" Height="24" Margin="8,0"
                            Background="{DynamicResource BorderBrush}"/>

                    <ToggleButton x:Name="LiveDetectionButton"
                                  Style="{StaticResource SpeedToggleButton}"
                                  Margin="0,0,6,0"
                                  Click="LiveDetection_Click"
                                  ToolTip="Live-KI: Echtzeit-Schadenserkennung waehrend Wiedergabe (D)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Live-KI" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <ToggleButton x:Name="ManualMarkButton"
                                  Style="{StaticResource SpeedToggleButton}"
                                  Margin="0,0,6,0"
                                  Click="ManualMark_Click"
                                  ToolTip="Manuell markieren: Klick auf Video zum Schaden markieren (M)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C8;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Markieren" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <Button x:Name="CodingModeButton"
                            Style="{StaticResource PlayerPrimaryButton}"
                            Margin="6,0,0,0"
                            Click="CodingMode_Click"
                            ToolTip="Codier-Modus: Haltung komplett durchcodieren mit Overlay-Werkzeugen (C)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Codier-Modus" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock x:Name="LiveDetectionStatusText"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="Collapsed"/>
                </WrapPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Wiedergabegeschwindigkeit"
                               Style="{StaticResource PlayerLabelText}"
                               Margin="0,0,0,6"/>
                    <WrapPanel>
                        <ToggleButton x:Name="Speed05Button" Style="{StaticResource SpeedToggleButton}" Content="0.5x" Click="Speed05_Click"
                                      ToolTip="Halbe Geschwindigkeit - fuer detaillierte Inspektion"/>
                        <ToggleButton x:Name="Speed1Button" Style="{StaticResource SpeedToggleButton}" Content="1x" Click="Speed1_Click"
                                      ToolTip="Normale Wiedergabegeschwindigkeit"/>
                        <ToggleButton x:Name="Speed15Button" Style="{StaticResource SpeedToggleButton}" Content="1.5x" Click="Speed15_Click"
                                      ToolTip="1.5-fache Geschwindigkeit"/>
                        <ToggleButton x:Name="Speed2Button" Style="{StaticResource SpeedToggleButton}" Content="2x" Click="Speed2_Click"
                                      ToolTip="Doppelte Geschwindigkeit"/>
                        <ToggleButton x:Name="Speed4Button" Style="{StaticResource SpeedToggleButton}" Content="4x" Click="Speed4_Click"
                                      ToolTip="4-fache Geschwindigkeit - schneller Ueberblick"/>
                        <ToggleButton x:Name="Speed8Button" Style="{StaticResource SpeedToggleButton}" Content="8x" Margin="0" Click="Speed8_Click"
                                      ToolTip="8-fache Geschwindigkeit - maximaler Schnellvorlauf"/>
                    </WrapPanel>
                </StackPanel>

                <Border Grid.Column="2"
                        Style="{StaticResource PlayerMetaCard}"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Aktuelle Rate"
                                   Style="{StaticResource PlayerLabelText}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock x:Name="RateText"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   Text="1.00x"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
