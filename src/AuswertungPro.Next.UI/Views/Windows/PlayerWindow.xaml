<Window x:Class="AuswertungPro.Next.UI.Views.Windows.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:ctrl="clr-namespace:AuswertungPro.Next.UI.Controls"
        Title="Video"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="PlayerCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Background" Value="{DynamicResource CardGlassBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="PlayerLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PlayerValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PlayerTimeText" TargetType="TextBlock" BasedOn="{StaticResource PlayerValueText}">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PlayerMetaCard" TargetType="Border">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <Style x:Key="PlayerButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PlayerPrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButtonAccent}">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="MarkToolPopupButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                TextBlock.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HeaderBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="TextElement.Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="TextElement.Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SpeedToggleButton" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <!-- Background wird NICHT gesetzt — erlaubt Code-Behind Blink-Animation -->
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Sidebar Section-Label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Statistik-Kachel -->
        <Style x:Key="StatTile" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- Defekt-Aktionsbutton -->
        <Style x:Key="DefectActionBtn" TargetType="Button">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Header -->
            <RowDefinition Height="*"/>         <!-- Video + Seitenpanel -->
            <RowDefinition Height="Auto"/>      <!-- Coding-Werkzeuge (nur im Codier-Modus) -->
            <RowDefinition Height="Auto"/>      <!-- Pipe Graph Timeline (Codier-Modus) -->
            <RowDefinition Height="Auto"/>      <!-- Timeline -->
            <RowDefinition Height="Auto"/>      <!-- Controls -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PlayerCard}"
                Margin="0,0,0,12"
                Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,2,14,2"
                        Background="{DynamicResource AccentBrush}"
                        CornerRadius="999"/>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Videoplayer"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="{StaticResource TypeSmall}"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="VideoNameText"
                               Margin="0,4,0,0"
                               Text="Video"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="{StaticResource TypeIcon}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="VideoPathText"
                               Margin="0,4,0,0"
                               Style="{StaticResource PlayerLabelText}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Margin="16,0,0,0"
                        Style="{StaticResource PlayerMetaCard}"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Hotkeys"
                                   Style="{StaticResource PlayerLabelText}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="Space Pause, Pfeile +/-5s, +/- Geschwindigkeit"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="{StaticResource TypeSmall}"
                                   TextAlignment="Right"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Video-Bereich: Grid mit optionalem Seitenpanel -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Coding-Seitenpanel (nur sichtbar im Codier-Modus) -->
                <ColumnDefinition x:Name="CodingSidePanelColumn" Width="0"/>
                <!-- Trainings-Seitenpanel (nur sichtbar im Trainings-Modus) -->
                <ColumnDefinition x:Name="TrainingSidePanelColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Video + Overlays: Geschwister-Pattern (wie CodingModeWindow) -->
            <Grid Grid.Column="0">
                <!-- Video-Layer -->
                <vlc:VideoView x:Name="VideoView"
                               Background="#FF000000"
                               IsHitTestVisible="False"
                               Panel.ZIndex="0"/>

                <!-- Coding Overlay als Popup:
                     eigenes Top-Level-Window, damit Zeichnung trotz VLC-HwndHost sichtbar bleibt -->
                <Popup x:Name="CodingOverlayPopup"
                       PlacementTarget="{Binding ElementName=VideoView}"
                       Placement="Relative"
                       HorizontalOffset="0"
                       VerticalOffset="0"
                       AllowsTransparency="True"
                       StaysOpen="True"
                       IsOpen="False">
                    <Canvas x:Name="CodingOverlayCanvas"
                            Width="1"
                            Height="1"
                            Background="#01000000"
                            ClipToBounds="True"
                            IsHitTestVisible="True"
                            Cursor="Arrow"
                            MouseLeftButtonDown="CodingCanvas_MouseLeftButtonDown"
                            MouseMove="CodingCanvas_MouseMove"
                            MouseLeftButtonUp="CodingCanvas_MouseLeftButtonUp"
                            MouseWheel="CodingCanvas_MouseWheel"/>
                </Popup>

                <!-- Training Overlay als Popup: BBox-Zeichnen fuer KB-Trainingssamples -->
                <Popup x:Name="TrainingOverlayPopup"
                       PlacementTarget="{Binding ElementName=VideoView}"
                       Placement="Relative"
                       HorizontalOffset="0"
                       VerticalOffset="0"
                       AllowsTransparency="True"
                       StaysOpen="True"
                       IsOpen="False">
                    <Canvas x:Name="TrainingOverlayCanvas"
                            Width="1"
                            Height="1"
                            Background="#01000000"
                            ClipToBounds="True"
                            IsHitTestVisible="True"
                            Cursor="Cross"
                            MouseLeftButtonDown="TrainingCanvas_MouseLeftButtonDown"
                            MouseMove="TrainingCanvas_MouseMove"
                            MouseLeftButtonUp="TrainingCanvas_MouseLeftButtonUp"/>
                </Popup>

                <!-- Detection overlay layer (hidden by default) -->
                <Grid x:Name="DetectionOverlayGrid"
                      Visibility="Collapsed"
                      Panel.ZIndex="20"
                      IsHitTestVisible="False">
                    <Canvas x:Name="DetectionCanvas"
                            Background="Transparent"
                            IsHitTestVisible="False"
                            ClipToBounds="True"/>

                    <!-- EingabemarkerPopup wurde in die Toolbar verschoben (VLC Airspace) -->

                    <Border x:Name="AiStatusBadge"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="12" CornerRadius="8" Padding="10,5"
                            Background="#DD111318"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="AiStatusDot" Width="8" Height="8"
                                     Fill="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="AiStatusText" Text="KI aktiv"
                                       Foreground="White" FontSize="{StaticResource TypeCaption}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FindingSummaryPanel"
                            HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                            Background="#CC111318" Padding="12,8" Visibility="Collapsed">
                        <TextBlock x:Name="FindingSummaryText"
                                   Foreground="White" FontSize="{StaticResource TypeSmall}" TextWrapping="Wrap"/>
                    </Border>
                </Grid>



                <!-- LiveDetection-Bestaetigungs-Panel (bei Befund: Video angehalten, User entscheidet) -->
                <Border x:Name="DetectionConfirmationPanel" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,24" Background="#EE111318" CornerRadius="12"
                        Padding="20,12" BorderBrush="{DynamicResource StatusOrangeBrush}" BorderThickness="1.5"
                        Panel.ZIndex="30">
                    <StackPanel MaxWidth="480">
                        <TextBlock x:Name="TxtDetectionFinding" FontSize="{StaticResource TypeBodyLarge}" FontWeight="Bold"
                                   Foreground="{DynamicResource StatusOrangeBrush}" TextAlignment="Center" TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtDetectionDetail" FontSize="{StaticResource TypeSmall}"
                                   Foreground="{StaticResource MutedBrush}" TextAlignment="Center" TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="&#x2713; Akzeptieren" Click="DetectionAccept_Click"
                                    Style="{StaticResource PlayerPrimaryButton}" Padding="12,6" Margin="0,0,6,0"
                                    ToolTip="Live-Erkennung akzeptieren und Befund ins Protokoll eintragen"/>
                            <Button Content="&#x270E; Korrigieren" Click="DetectionCorrect_Click"
                                    Style="{StaticResource PlayerButton}" Padding="12,6" Margin="0,0,6,0"
                                    Foreground="{DynamicResource StatusOrangeBrush}"
                                    ToolTip="Erkannten Befund manuell korrigieren bevor er uebernommen wird"/>
                            <Button Content="&#x25B6; Weiter" Click="DetectionSkip_Click"
                                    Style="{StaticResource PlayerButton}" Padding="12,6"
                                    ToolTip="Erkennung ueberspringen und Video-Wiedergabe fortsetzen"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Mess-Anzeige -->
                <Border x:Name="CodingMeasurementPanel"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,8" Background="#CC000000" CornerRadius="8"
                        Padding="12,6" Visibility="Collapsed">
                    <TextBlock x:Name="TxtCodingMeasurement"
                               Foreground="White" FontSize="{StaticResource TypeBody}"
                               FontFamily="Consolas, Cascadia Mono" HorizontalAlignment="Center"/>
                </Border>


                <!-- OSD-Meter Anzeige (KI-gelesener Meterstand, immer sichtbar im Codier-Modus) -->
                <Border x:Name="OsdMeterBadge"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="12" Padding="10,5"
                        Background="#DD111318" CornerRadius="8"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtOsdMeter"
                               Foreground="{DynamicResource AccentBrush}"
                               FontFamily="Consolas, Cascadia Mono"
                               FontSize="{StaticResource TypeBodyLarge}" FontWeight="Bold"/>
                </Border>
            </Grid>


            <!-- TRAININGS-SEITENPANEL (nur im Trainings-Modus sichtbar) -->
            <Border x:Name="TrainingSidePanel" Grid.Column="2"
                    Visibility="Collapsed"
                    Margin="8,0,0,0"
                    Background="{DynamicResource CardGlassBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    CornerRadius="10" Padding="10"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Width="260">
                        <TextBlock Text="TRAININGS-MODUS"
                                   FontSize="{StaticResource TypeSmall}" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontSize="{StaticResource TypeCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,10">
                            Video pausieren (Leertaste) &#x2192; Rechteck um Schaden ziehen &#x2192; "Speichern" oeffnet VSA-Code-Auswahl. Sample landet als Trainingsbeispiel in der Knowledge-Base.
                        </TextBlock>

                        <Border Background="{DynamicResource HeaderBrush}" CornerRadius="8"
                                Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="STATUS" Style="{StaticResource SectionLabel}"/>
                                <TextBlock x:Name="TxtTrainingStatus"
                                           Text="Bereit. Rechteck ziehen."
                                           FontSize="{StaticResource TypeSmall}" Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtTrainingCount"
                                           Text="0 Samples in dieser Sitzung"
                                           FontSize="{StaticResource TypeMicro}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="METER (optional)" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="TxtTrainingMeter"
                                 FontSize="{StaticResource TypeSmall}" Padding="6,4"
                                 Margin="0,0,0,8"
                                 ToolTip="Meterstand des Schadens (leer = aus Video-Zeit abgeleitet)"/>

                        <TextBlock Text="SCHWEREGRAD" Style="{StaticResource SectionLabel}"/>
                        <ComboBox x:Name="CmbTrainingSeverity"
                                  FontSize="{StaticResource TypeSmall}"
                                  Margin="0,0,0,8"
                                  SelectedIndex="2">
                            <ComboBoxItem Content="1 - Optisch"/>
                            <ComboBoxItem Content="2 - Leicht"/>
                            <ComboBoxItem Content="3 - Mittel"/>
                            <ComboBoxItem Content="4 - Schwer"/>
                            <ComboBoxItem Content="5 - Kritisch"/>
                        </ComboBox>

                        <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                            <Button x:Name="BtnTrainingSave"
                                    Content="&#x1F4BE; Speichern (Code waehlen)"
                                    Style="{StaticResource PlayerPrimaryButton}"
                                    Click="TrainingSave_Click"
                                    Margin="0,0,0,4"
                                    IsEnabled="False"
                                    ToolTip="Aktuelles Rechteck mit VSA-Code verknuepfen und als Trainingsbeispiel speichern"/>
                            <Button x:Name="BtnTrainingClear"
                                    Content="&#x2716; Rechteck loeschen"
                                    Style="{StaticResource PlayerButton}"
                                    Click="TrainingClear_Click"
                                    Margin="0,0,0,4"
                                    IsEnabled="False"/>
                            <Button x:Name="BtnTrainingNegativ"
                                    Content="&#x229B; Negativ-Beispiel speichern"
                                    Style="{StaticResource PlayerButton}"
                                    Click="TrainingNegativ_Click"
                                    ToolTip="Aktuellen Frame als Negativ-Beispiel (kein Befund) speichern"/>
                        </StackPanel>

                        <Border Background="{DynamicResource HeaderBrush}" CornerRadius="8"
                                Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="HINWEISE" Style="{StaticResource SectionLabel}"/>
                                <TextBlock TextWrapping="Wrap" FontSize="{StaticResource TypeMicro}"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    &#x2022; Leertaste: Video pausieren/weiter&#x0A;&#x2022; Rechteck: Ziehen mit gedrueckter Maustaste&#x0A;&#x2022; Code-Auswahl oeffnet sich nach "Speichern"&#x0A;&#x2022; Frame wird automatisch als PNG exportiert&#x0A;&#x2022; KB indexiert das Sample wenn Ollama laeuft
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource HeaderBrush}" CornerRadius="8"
                                Padding="10,8" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="OPERATEUR-ANNOTATION"
                                           Style="{StaticResource SectionLabel}"/>
                                <TextBlock TextWrapping="Wrap" FontSize="{StaticResource TypeMicro}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,6">
                                    Codes aus dem Inspektions-PDF einlesen und der Reihe nach codieren.
                                </TextBlock>
                                <Button x:Name="BtnTrainingStartOperator"
                                        Content="Haltungsordner waehlen…"
                                        Style="{StaticResource PlayerButton}"
                                        Click="TrainingStartOperator_Click"
                                        ToolTip="Ordner mit Video + PDF auswaehlen. Codes aus dem PDF werden als Aufgaben angezeigt."/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnTrainingExit"
                                Content="Trainings-Modus beenden"
                                Style="{StaticResource PlayerButton}"
                                Click="TrainingExit_Click"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═════════ OPERATEUR-ANNOTATION (Slice 1, Phase 7) ═════════
                 Sub-Panel innerhalb der Trainings-Modus-Spalte. Zeigt die
                 PDF-Codes als Aufgabenliste. Box-Overlay nutzt das vorhandene
                 CodingOverlayPopup/Canvas-Pattern (B6: WPF-Airspace mit LibVLC).
            -->
            <Border x:Name="OperatorSidePanel" Grid.Column="2"
                    Visibility="Collapsed"
                    Margin="8,0,0,0"
                    Background="{DynamicResource CardGlassBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    CornerRadius="10" Padding="10"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Width="260">
                        <TextBlock Text="OPERATEUR-ANNOTATION"
                                   FontSize="{StaticResource TypeSmall}" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontSize="{StaticResource TypeCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,10">
                            Code aus der Liste waehlen &#x2192; Box ueber Schaden ziehen &#x2192; SAM-Maske bestaetigen. Sample landet in Store + KB + YOLO-Datensatz.
                        </TextBlock>

                        <Border Background="{DynamicResource HeaderBrush}" CornerRadius="8"
                                Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="STATUS" Style="{StaticResource SectionLabel}"/>
                                <TextBlock x:Name="TxtOperatorStatus"
                                           Text="Keine Sitzung — Haltungsordner importieren."
                                           FontSize="{StaticResource TypeSmall}" Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtOperatorProgress"
                                           Text=""
                                           FontSize="{StaticResource TypeMicro}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="CODES AUS PDF" Style="{StaticResource SectionLabel}"/>
                        <ListBox x:Name="OperatorCodeList"
                                 FontSize="{StaticResource TypeSmall}"
                                 Margin="0,0,0,8"
                                 MaxHeight="320"
                                 SelectionChanged="OperatorCodeList_SelectionChanged"
                                 ToolTip="Klick: Code waehlen + zum Meterstand springen. Hotkeys: Strg+Eingabe = Bestaetigen, Strg+Umsch+Z = Ueberspringen, Strg+R = Nicht zutreffend.">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Status-Dot: faerbt sich je nach State.
                                             Pending=grau, Active/PreviewReady=akzent,
                                             Committed=gruen, Skipped=orange,
                                             Rejected=rot, Error=rot -->
                                        <Ellipse Grid.Column="0" Width="8" Height="8"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,6,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Active">
                                                            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="PreviewReady">
                                                            <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Committed">
                                                            <Setter Property="Fill" Value="#22C55E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Skipped">
                                                            <Setter Property="Fill" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Rejected">
                                                            <Setter Property="Fill" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Error">
                                                            <Setter Property="Fill" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Code}"
                                                   FontFamily="Consolas, Cascadia Mono"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Meterstand, StringFormat='{}{0:F2} m'}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontFamily="Consolas, Cascadia Mono"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                            <Button x:Name="BtnOperatorBox"
                                    Content="&#x25A2; Box ziehen + SAM"
                                    Style="{StaticResource PlayerPrimaryButton}"
                                    Click="OperatorBox_Click"
                                    IsEnabled="False"
                                    Margin="0,0,0,4"
                                    ToolTip="Aktiviert das Rechteck-Tool. Box ueber den Schaden ziehen, SAM segmentiert. Maske wird angezeigt — erst Strg+Enter / 'Bestaetigen' schreibt das Sample."/>
                            <Button x:Name="BtnOperatorConfirm"
                                    Content="&#x2714; Bestaetigen (Strg+Eingabe)"
                                    Style="{StaticResource PlayerPrimaryButton}"
                                    Click="OperatorConfirm_Click"
                                    IsEnabled="False"
                                    Margin="0,0,0,4"
                                    ToolTip="SAM-Maske bestaetigen — Sample wird in Store + KB + YOLO geschrieben."/>
                            <Button x:Name="BtnOperatorSkip"
                                    Content="&#x21B7; Code ueberspringen"
                                    Style="{StaticResource PlayerButton}"
                                    Click="OperatorSkip_Click"
                                    IsEnabled="False"
                                    Margin="0,0,0,4"
                                    ToolTip="Aktuellen Code als 'Skipped' markieren (z.B. Frame unscharf). Hotkey: Strg+Umsch+Z"/>
                            <Button x:Name="BtnOperatorReject"
                                    Content="&#x2716; Nicht zutreffend"
                                    Style="{StaticResource PlayerButton}"
                                    Click="OperatorReject_Click"
                                    IsEnabled="False"
                                    Margin="0,0,0,4"
                                    ToolTip="Code als Protokollfehler markieren. Hotkey: Strg+R"/>
                        </StackPanel>

                        <Button x:Name="BtnOperatorExit"
                                Content="Sitzung beenden"
                                Style="{StaticResource PlayerButton}"
                                Click="OperatorExit_Click"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>



            <!-- YOLO-Statusanzeige -->
        <Border Grid.Row="3" x:Name="YoloStatusBar" Visibility="Collapsed"
                    Background="{DynamicResource SurfaceBrush}" CornerRadius="4"
                    Padding="10,4" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="YoloDot" Width="8" Height="8"
                             Fill="{StaticResource MutedBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtYoloStatus" Text="YOLO: Bereit"
                               FontSize="{StaticResource TypeCaption}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtYoloModel" Text=""
                               FontSize="{StaticResource TypeMicro}" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

        <Border Grid.Row="4"
                Style="{StaticResource PlayerCard}"
                Margin="0,0,0,12"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="CurrentTimeText"
                           Grid.Column="0"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource PlayerTimeText}"
                           Text="00:00"/>

                <Grid Grid.Column="1">
                    <!-- Quick-Scan heatmap overlay, below slider -->
                    <Canvas x:Name="HeatmapCanvas"
                            IsHitTestVisible="True"
                            VerticalAlignment="Center"
                            Height="6"
                            Margin="0,12,0,0"
                            ClipToBounds="True"/>
                    <Slider x:Name="PositionSlider"
                            Minimum="0"
                            Maximum="1000"
                            Margin="0,1"
                            IsMoveToPointEnabled="True"
                            ValueChanged="PositionSlider_ValueChanged"
                            ToolTip="Videoposition - ziehen fuer Live-Vorschau, klicken zum Springen"/>
                    <!-- Damage code marker overlay, positioned dynamically to match slider track -->
                    <Canvas x:Name="DamageMarkerCanvas"
                            IsHitTestVisible="True"
                            VerticalAlignment="Center"
                            Height="28"
                            ClipToBounds="False"/>
                </Grid>

                <TextBlock x:Name="DurationText"
                           Grid.Column="2"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource PlayerTimeText}"
                           Text="00:00"/>
            </Grid>
        </Border>

        <Border Grid.Row="5"
                Style="{StaticResource PlayerCard}"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" Margin="0,0,18,0" VerticalAlignment="Center">
                    <Button Style="{StaticResource PlayerPrimaryButton}" Margin="0,0,6,0" Click="Play_Click"
                            ToolTip="Video abspielen (Leertaste)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Play" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PlayerButton}" Margin="0,0,6,0" Click="Pause_Click"
                            ToolTip="Video pausieren (Leertaste)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Pause" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PlayerButton}" Click="Stop_Click"
                            ToolTip="Wiedergabe stoppen und zum Anfang zuruecksetzen">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Stop" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Height="24" Margin="8,0"
                            Background="{DynamicResource BorderBrush}"/>

                    <!-- Schnell-Scan, Live-KI, Markieren, Trainings-Modus aus dem normalen
                         Player-Modus entfernt. KI-Funktionalitaet lebt jetzt nur noch im
                         Codier-Modus. Buttons + Popups bleiben als unsichtbare Stubs damit
                         existing Code-Behind-Referenzen (Hotkeys M/D, etc.) nicht crashen. -->
                    <ToggleButton x:Name="QuickScanButton" Visibility="Collapsed"
                                  Click="QuickScan_Click"/>
                    <TextBlock x:Name="QuickScanStatusText" Visibility="Collapsed"/>
                    <ToggleButton x:Name="LiveDetectionButton" Visibility="Collapsed"
                                  Click="LiveDetection_Click"/>
                    <Button x:Name="ManualMarkButton" Visibility="Collapsed"
                            Click="ManualMark_Click">
                        <TextBlock x:Name="TxtMarkToolName" Text="Markieren"/>
                    </Button>
                    <Popup x:Name="MarkToolPopup" StaysOpen="False" IsOpen="False"
                           PlacementTarget="{Binding ElementName=ManualMarkButton}"/>

                    <Button x:Name="CodingModeButton"
                            Style="{StaticResource PlayerPrimaryButton}"
                            Margin="6,0,0,0"
                            Click="CodingMode_Click"
                            ToolTip="Codier-Modus: Haltung komplett durchcodieren mit Overlay-Werkzeugen (C)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Codier-Modus" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <ToggleButton x:Name="TrainingModeButton" Visibility="Collapsed"
                                  Click="TrainingMode_Click"/>

                    <TextBlock x:Name="LiveDetectionStatusText" Visibility="Collapsed"/>
                </WrapPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Wiedergabegeschwindigkeit"
                               Style="{StaticResource PlayerLabelText}"
                               Margin="0,0,0,6"/>
                    <WrapPanel>
                        <ToggleButton x:Name="Speed05Button" Style="{StaticResource SpeedToggleButton}" Content="0.5x" Click="Speed05_Click"
                                      ToolTip="Halbe Geschwindigkeit - fuer detaillierte Inspektion"/>
                        <ToggleButton x:Name="Speed1Button" Style="{StaticResource SpeedToggleButton}" Content="1x" Click="Speed1_Click"
                                      ToolTip="Normale Wiedergabegeschwindigkeit"/>
                        <ToggleButton x:Name="Speed15Button" Style="{StaticResource SpeedToggleButton}" Content="1.5x" Click="Speed15_Click"
                                      ToolTip="1.5-fache Geschwindigkeit"/>
                        <ToggleButton x:Name="Speed2Button" Style="{StaticResource SpeedToggleButton}" Content="2x" Click="Speed2_Click"
                                      ToolTip="Doppelte Geschwindigkeit"/>
                        <ToggleButton x:Name="Speed4Button" Style="{StaticResource SpeedToggleButton}" Content="4x" Click="Speed4_Click"
                                      ToolTip="4-fache Geschwindigkeit - schneller Ueberblick"/>
                        <ToggleButton x:Name="Speed8Button" Style="{StaticResource SpeedToggleButton}" Content="8x" Margin="0" Click="Speed8_Click"
                                      ToolTip="8-fache Geschwindigkeit - maximaler Schnellvorlauf"/>
                    </WrapPanel>
                </StackPanel>

                <Border Grid.Column="2"
                        Style="{StaticResource PlayerMetaCard}"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Aktuelle Rate"
                                   Style="{StaticResource PlayerLabelText}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock x:Name="RateText"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="{StaticResource TypeH3}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   Text="1.00x"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
