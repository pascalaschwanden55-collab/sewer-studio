<Window x:Class="AuswertungPro.Next.UI.Views.Windows.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:ctrl="clr-namespace:AuswertungPro.Next.UI.Controls"
        Title="Video"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="PlayerCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Background" Value="{DynamicResource CardGlassBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="PlayerLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PlayerValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PlayerTimeText" TargetType="TextBlock" BasedOn="{StaticResource PlayerValueText}">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PlayerMetaCard" TargetType="Border">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <Style x:Key="PlayerButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PlayerPrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButtonAccent}">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="MarkToolPopupButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                TextBlock.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HeaderBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="TextElement.Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="TextElement.Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SpeedToggleButton" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource NeonCyanBrush}"/>
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource NeonCyanBrush}"/>
                                <!-- Background wird NICHT gesetzt — erlaubt Code-Behind Blink-Animation -->
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Sidebar Section-Label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Statistik-Kachel -->
        <Style x:Key="StatTile" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- Defekt-Aktionsbutton -->
        <Style x:Key="DefectActionBtn" TargetType="Button">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Header -->
            <RowDefinition Height="*"/>         <!-- Video + Seitenpanel -->
            <RowDefinition Height="Auto"/>      <!-- Coding-Werkzeuge (nur im Codier-Modus) -->
            <RowDefinition Height="Auto"/>      <!-- Pipe Graph Timeline (Codier-Modus) -->
            <RowDefinition Height="Auto"/>      <!-- Timeline -->
            <RowDefinition Height="Auto"/>      <!-- Controls -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PlayerCard}"
                Margin="0,0,0,12"
                Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,2,14,2"
                        Background="{DynamicResource NeonCyanBrush}"
                        CornerRadius="999"/>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Videoplayer"
                               Foreground="{DynamicResource NeonCyanBrush}"
                               FontSize="{StaticResource TypeSmall}"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="VideoNameText"
                               Margin="0,4,0,0"
                               Text="Video"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="VideoPathText"
                               Margin="0,4,0,0"
                               Style="{StaticResource PlayerLabelText}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Margin="16,0,0,0"
                        Style="{StaticResource PlayerMetaCard}"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Hotkeys"
                                   Style="{StaticResource PlayerLabelText}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="Space Pause, Pfeile +/-5s, +/- Geschwindigkeit"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="{StaticResource TypeSmall}"
                                   TextAlignment="Right"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Video-Bereich: Grid mit optionalem Seitenpanel -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Coding-Seitenpanel (nur sichtbar im Codier-Modus) -->
                <ColumnDefinition x:Name="CodingSidePanelColumn" Width="0"/>
                <!-- Trainings-Seitenpanel (nur sichtbar im Trainings-Modus) -->
                <ColumnDefinition x:Name="TrainingSidePanelColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Video + Overlays: Geschwister-Pattern (wie CodingModeWindow) -->
            <Grid Grid.Column="0">
                <!-- Video-Layer -->
                <vlc:VideoView x:Name="VideoView"
                               Background="#FF000000"
                               IsHitTestVisible="False"
                               Panel.ZIndex="0"/>

                <!-- Coding Overlay als Popup:
                     eigenes Top-Level-Window, damit Zeichnung trotz VLC-HwndHost sichtbar bleibt -->
                <Popup x:Name="CodingOverlayPopup"
                       PlacementTarget="{Binding ElementName=VideoView}"
                       Placement="Relative"
                       HorizontalOffset="0"
                       VerticalOffset="0"
                       AllowsTransparency="True"
                       StaysOpen="True"
                       IsOpen="False">
                    <Canvas x:Name="CodingOverlayCanvas"
                            Width="1"
                            Height="1"
                            Background="#01000000"
                            ClipToBounds="True"
                            IsHitTestVisible="True"
                            Cursor="Arrow"
                            MouseLeftButtonDown="CodingCanvas_MouseLeftButtonDown"
                            MouseMove="CodingCanvas_MouseMove"
                            MouseLeftButtonUp="CodingCanvas_MouseLeftButtonUp"
                            MouseWheel="CodingCanvas_MouseWheel"/>
                </Popup>

                <!-- Training Overlay als Popup: BBox-Zeichnen fuer KB-Trainingssamples -->
                <Popup x:Name="TrainingOverlayPopup"
                       PlacementTarget="{Binding ElementName=VideoView}"
                       Placement="Relative"
                       HorizontalOffset="0"
                       VerticalOffset="0"
                       AllowsTransparency="True"
                       StaysOpen="True"
                       IsOpen="False">
                    <Canvas x:Name="TrainingOverlayCanvas"
                            Width="1"
                            Height="1"
                            Background="#01000000"
                            ClipToBounds="True"
                            IsHitTestVisible="True"
                            Cursor="Cross"
                            MouseLeftButtonDown="TrainingCanvas_MouseLeftButtonDown"
                            MouseMove="TrainingCanvas_MouseMove"
                            MouseLeftButtonUp="TrainingCanvas_MouseLeftButtonUp"/>
                </Popup>

                <!-- Detection overlay layer (hidden by default) -->
                <Grid x:Name="DetectionOverlayGrid"
                      Visibility="Collapsed"
                      Panel.ZIndex="20"
                      IsHitTestVisible="False">
                    <Canvas x:Name="DetectionCanvas"
                            Background="Transparent"
                            IsHitTestVisible="False"
                            ClipToBounds="True"/>

                    <!-- EingabemarkerPopup wurde in die Toolbar verschoben (VLC Airspace) -->

                    <Border x:Name="AiStatusBadge"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="12" CornerRadius="8" Padding="10,5"
                            Background="#DD111318"
                            BorderBrush="{DynamicResource NeonCyanBrush}"
                            BorderThickness="1" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="AiStatusDot" Width="8" Height="8"
                                     Fill="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="AiStatusText" Text="KI aktiv"
                                       Foreground="White" FontSize="{StaticResource TypeCaption}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FindingSummaryPanel"
                            HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                            Background="#CC111318" Padding="12,8" Visibility="Collapsed">
                        <TextBlock x:Name="FindingSummaryText"
                                   Foreground="White" FontSize="{StaticResource TypeSmall}" TextWrapping="Wrap"/>
                    </Border>
                </Grid>

                <!-- Kalibrierungs-Hinweis -->
                <Border x:Name="CodingCalibrationHint"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Margin="0,8,0,0" Background="#DD000000" CornerRadius="8"
                        Padding="16,8" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="KALIBRIERUNG" FontSize="{StaticResource TypeSmall}" FontWeight="Bold"
                                   Foreground="{DynamicResource NeonCyanBrush}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtCodingCalibHint" FontSize="{StaticResource TypeSmall}" Foreground="White"
                                   TextWrapping="Wrap" MaxWidth="300"/>
                    </StackPanel>
                </Border>

                <!-- KI-Bestaetigungs-Panel (bei Gelb/Rot: Video angehalten, User entscheidet) -->
                <Border x:Name="CodingConfirmationPanel" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#EE111318" CornerRadius="12" Padding="20,16"
                        BorderBrush="{DynamicResource NeonCyanBrush}" BorderThickness="1">
                    <StackPanel MaxWidth="420">
                        <!-- Ampel-Farbe + KI-Vorschlag -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse x:Name="ConfirmAmpel" Width="16" Height="16" Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtConfirmCode" FontSize="{StaticResource TypeH4}" FontWeight="Bold"
                                       Foreground="{DynamicResource NeonCyanBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtConfirmConfidence" FontSize="{StaticResource TypeSmall}" Margin="8,0,0,0"
                                       Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtConfirmDescription" Foreground="White" FontSize="{StaticResource TypeBody}"
                                   TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtConfirmDetail" Foreground="{StaticResource MutedBrush}" FontSize="{StaticResource TypeCaption}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <!-- Aktionen -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="&#x2713; Uebernehmen" Click="ConfirmAccept_Click"
                                    Style="{StaticResource PlayerPrimaryButton}" Padding="12,6" Margin="0,0,6,0"
                                    ToolTip="KI-Vorschlag akzeptieren und als Befund in das Protokoll uebernehmen"/>
                            <Button Content="&#x270E; Code aendern" Click="ConfirmEdit_Click"
                                    Style="{StaticResource PlayerButton}" Padding="12,6" Margin="0,0,6,0"
                                    Foreground="{DynamicResource NeonCyanBrush}"
                                    ToolTip="KI-Vorschlag bearbeiten und Schadenscode manuell korrigieren"/>
                            <Button Content="&#x2717; Verwerfen" Click="ConfirmReject_Click"
                                    Style="{StaticResource PlayerButton}" Padding="12,6"
                                    Foreground="#EF4444"
                                    ToolTip="KI-Vorschlag ablehnen und nicht ins Protokoll uebernehmen"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- LiveDetection-Bestaetigungs-Panel (bei Befund: Video angehalten, User entscheidet) -->
                <Border x:Name="DetectionConfirmationPanel" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,24" Background="#EE111318" CornerRadius="12"
                        Padding="20,12" BorderBrush="#F59E0B" BorderThickness="1.5"
                        Panel.ZIndex="30">
                    <StackPanel MaxWidth="480">
                        <TextBlock x:Name="TxtDetectionFinding" FontSize="{StaticResource TypeBodyLarge}" FontWeight="Bold"
                                   Foreground="#F59E0B" TextAlignment="Center" TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtDetectionDetail" FontSize="{StaticResource TypeSmall}"
                                   Foreground="{StaticResource MutedBrush}" TextAlignment="Center" TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="&#x2713; Akzeptieren" Click="DetectionAccept_Click"
                                    Style="{StaticResource PlayerPrimaryButton}" Padding="12,6" Margin="0,0,6,0"
                                    ToolTip="Live-Erkennung akzeptieren und Befund ins Protokoll eintragen"/>
                            <Button Content="&#x270E; Korrigieren" Click="DetectionCorrect_Click"
                                    Style="{StaticResource PlayerButton}" Padding="12,6" Margin="0,0,6,0"
                                    Foreground="#F59E0B"
                                    ToolTip="Erkannten Befund manuell korrigieren bevor er uebernommen wird"/>
                            <Button Content="&#x25B6; Weiter" Click="DetectionSkip_Click"
                                    Style="{StaticResource PlayerButton}" Padding="12,6"
                                    ToolTip="Erkennung ueberspringen und Video-Wiedergabe fortsetzen"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Mess-Anzeige -->
                <Border x:Name="CodingMeasurementPanel"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,8" Background="#CC000000" CornerRadius="8"
                        Padding="12,6" Visibility="Collapsed">
                    <TextBlock x:Name="TxtCodingMeasurement"
                               Foreground="White" FontSize="{StaticResource TypeBody}"
                               FontFamily="Consolas, Cascadia Mono" HorizontalAlignment="Center"/>
                </Border>

                <!-- KI-Scan-Overlay: wandernde Linie + Rahmen waehrend Analyse -->
                <Border x:Name="CodingScanOverlay" Visibility="Collapsed"
                        IsHitTestVisible="False"
                        BorderBrush="#F59E0B" BorderThickness="2"
                        CornerRadius="0" Opacity="0.6">
                    <Grid>
                        <!-- Wandernde Scan-Linie -->
                        <Rectangle x:Name="CodingScanLine" Width="2" Height="Auto"
                                   Fill="#F59E0B" HorizontalAlignment="Left"
                                   VerticalAlignment="Stretch" Opacity="0.8"/>
                        <!-- Analyse-Badge oben rechts -->
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="8" Padding="8,4" CornerRadius="6"
                                Background="#DD111318">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#F59E0B" Margin="0,0,5,0"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtScanStatus" Text="KI scannt..."
                                           Foreground="#F59E0B" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Flash-Effekt bei Fund (kurzes gruenes/gelbes Aufblitzen) -->
                <Border x:Name="CodingFlashOverlay" Visibility="Collapsed"
                        IsHitTestVisible="False"
                        Background="#22C55E" Opacity="0"/>

                <!-- OSD-Meter Anzeige (KI-gelesener Meterstand, immer sichtbar im Codier-Modus) -->
                <Border x:Name="OsdMeterBadge"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="12" Padding="10,5"
                        Background="#DD111318" CornerRadius="8"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtOsdMeter"
                               Foreground="{DynamicResource NeonCyanBrush}"
                               FontFamily="Consolas, Cascadia Mono"
                               FontSize="{StaticResource TypeBodyLarge}" FontWeight="Bold"/>
                </Border>
            </Grid>

            <!-- â"€â"€ CODING SEITENPANEL (Mockup-Design) â"€â"€ -->
            <Border x:Name="CodingSidePanel" Grid.Column="1"
                    Visibility="Collapsed"
                    Margin="8,0,0,0"
                    Background="{DynamicResource CardGlassBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    CornerRadius="10" Padding="6,4,6,4"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- == 1. QualityGate kompakt (eine Zeile) == -->
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="8" Height="8" CornerRadius="2" Background="#22C55E" Margin="0,0,3,0" VerticalAlignment="Center"/>
                            <TextBlock Text="&#x2265;85%" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Border Width="8" Height="8" CornerRadius="2" Background="#F59E0B" Margin="0,0,3,0" VerticalAlignment="Center"/>
                            <TextBlock Text="60-85%" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Border Width="8" Height="8" CornerRadius="2" Background="#EF4444" Margin="0,0,3,0" VerticalAlignment="Center"/>
                            <TextBlock Text="&lt;60%" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtQualityGateStatus" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </WrapPanel>

                        <!-- == 2. Drei-Spalten-Ansicht: KI-Befunde | Details | Import == -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition x:Name="ColDefectDetail" Width="0"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Linke Spalte: KI-erkannte Befunde -->
                            <Border Grid.Column="0" Style="{StaticResource PlayerCard}">
                                <DockPanel>
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                                        <TextBlock Style="{StaticResource SectionLabel}" Margin="0" FontSize="10">
                                            <Run Text="KI-BEFUNDE ("/>
                                            <Run x:Name="RunCodingDefectCount" Text="0"/>
                                            <Run Text=")"/>
                                        </TextBlock>
                                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   FontSize="9"
                                                   Foreground="{DynamicResource TextSecondaryBrush}">
                                            <Run x:Name="RunCodingOpenCount" Text="0"/>
                                            <Run Text=" offen"/>
                                        </TextBlock>
                                    </DockPanel>

                                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                                        <Button Style="{StaticResource PlayerButton}" Padding="4,2"
                                                FontSize="9" Content="&#x1F4F7; Foto"
                                                Click="CodingTakePhoto_Click"
                                                ToolTip="Foto vom aktuellen Frame fuer ausgewaehltes Ereignis aufnehmen"/>
                                    </StackPanel>

                                    <ListBox x:Name="LstCodingEvents"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontSize="{StaticResource TypeCaption}"
                                             Foreground="{DynamicResource TextBrush}"
                                             MaxHeight="400"
                                             PreviewMouseRightButtonDown="CodingEvents_PreviewMouseRightButtonDown"
                                             MouseDoubleClick="CodingEvents_DoubleClick"
                                             SelectionChanged="CodingEvents_SelectionChanged">
                                        <ListBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Bearbeiten (Doppelklick)" Click="CodingEventEdit_Click"/>
                                                <MenuItem Header="Fotos anzeigen" Click="CodingEventShowPhotos_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Streckenschaden schliessen (Ende hier)"
                                                          Click="CodingEventCloseStretch_Click"
                                                          FontWeight="SemiBold"/>
                                                <Separator/>
                                                <MenuItem Header="Zum Zeitpunkt springen" Click="CodingEventSeek_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Loeschen" Click="CodingEventDelete_Click" Foreground="OrangeRed"/>
                                            </ContextMenu>
                                        </ListBox.ContextMenu>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
                                                <Setter Property="Margin" Value="0,1"/>
                                                <Setter Property="Padding" Value="4,3"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    Cursor="Hand">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBrush}"/>
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse x:Name="ZoneDot" Grid.Column="0"
                                                                 Width="7" Height="7"
                                                                 Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Entry.Code}"
                                                                   FontFamily="Consolas"
                                                                   FontWeight="Bold" FontSize="{StaticResource TypeCaption}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,4,0"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Entry.Beschreibung}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" x:Name="TxtStatusIcon"
                                                                   FontSize="{StaticResource TypeCaption}" Margin="2,0,0,0"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <Grid Margin="11,1,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" FontSize="9"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Margin="0,0,8,0">
                                                            <Run Text="&#x1F4CD;"/>
                                                            <Run Text="{Binding MeterAtCapture, StringFormat='{}{0:F2}m', Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="1" FontSize="9"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Margin="0,0,8,0">
                                                            <Run Text="{Binding PhotoIndicator, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="2" x:Name="TxtConfidence"
                                                                   FontSize="9" FontWeight="SemiBold"
                                                                   HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>

                            <!-- Mittlere Spalte: Defekt-Details (bei Auswahl sichtbar) -->
                            <Border x:Name="CodingDefectDetailInline" Grid.Column="2"
                                    Style="{StaticResource PlayerCard}" Visibility="Collapsed">
                                <StackPanel>
                                    <!-- Kompakte Details: Code + Konfidenz -->
                                    <TextBlock x:Name="TxtInlineDetailCode"
                                               FontFamily="Consolas" FontSize="{StaticResource TypeH4}" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtInlineDetailDesc"
                                               FontSize="10" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>

                                    <!-- Distanz + Position + Konfidenz -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Distanz" FontSize="8"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtInlineDetailDistance"
                                                       FontFamily="Consolas" FontSize="{StaticResource TypeCaption}"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Konfidenz" FontSize="8"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtInlineDetailConfidence"
                                                       FontFamily="Consolas" FontSize="{StaticResource TypeCaption}" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Status -->
                                    <TextBlock x:Name="TxtInlineDetailStatus" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>

                                    <!-- Aktionsbuttons vertikal -->
                                    <StackPanel Margin="0,2,0,0">
                                        <Button x:Name="BtnInlineAccept"
                                                Style="{StaticResource DefectActionBtn}"
                                                Background="#16A34A" Margin="0,0,0,4"
                                                Click="CodingAcceptDefect_Click"
                                                ToolTip="Ausgewaehlten KI-Befund akzeptieren und ins Protokoll uebernehmen">
                                            <TextBlock Text="&#x2713; Akzeptieren" FontSize="10"/>
                                        </Button>
                                        <Button x:Name="BtnInlineEdit"
                                                Style="{StaticResource DefectActionBtn}"
                                                Background="#D97706" Margin="0,0,0,4"
                                                Click="CodingEditDefect_Click"
                                                ToolTip="Befund-Details wie Code, Schweregrad oder Beschreibung bearbeiten">
                                            <TextBlock Text="&#x2699; Bearbeiten" FontSize="10"/>
                                        </Button>
                                        <Button x:Name="BtnInlineReject"
                                                Style="{StaticResource DefectActionBtn}"
                                                Background="#DC2626"
                                                Click="CodingRejectDefect_Click"
                                                ToolTip="Befund ablehnen und aus der KI-Befundliste entfernen">
                                            <TextBlock Text="&#x2717; Ablehnen" FontSize="10"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Rechte Spalte: Import-Codierung (Referenz) -->
                            <Border Grid.Column="4" Style="{StaticResource PlayerCard}">
                                <DockPanel>
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                                        <TextBlock Style="{StaticResource SectionLabel}" Margin="0" FontSize="10">
                                            <Run Text="IMPORT ("/>
                                            <Run x:Name="RunImportDefectCount" Text="0"/>
                                            <Run Text=")"/>
                                        </TextBlock>
                                    </DockPanel>

                                    <ListBox x:Name="LstImportEvents"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontSize="{StaticResource TypeCaption}"
                                             Foreground="{DynamicResource TextBrush}"
                                             MaxHeight="400"
                                             IsHitTestVisible="True"
                                             MouseDoubleClick="ImportEvents_DoubleClick">
                                        <ListBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="&#x2713; Bestätigen (als Training übernehmen)" Click="ImportConfirm_Click"/>
                                                <MenuItem Header="Zum Zeitpunkt springen" Click="ImportSeek_Click"/>
                                            </ContextMenu>
                                        </ListBox.ContextMenu>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
                                                <Setter Property="Margin" Value="0,1"/>
                                                <Setter Property="Padding" Value="4,3"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    Cursor="Hand">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBrush}"/>
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#6366F1"/>
                                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="7" Height="7"
                                                                CornerRadius="4"
                                                                Background="#6366F1"
                                                                Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Entry.Code}"
                                                                   FontFamily="Consolas"
                                                                   FontWeight="Bold" FontSize="{StaticResource TypeCaption}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,4,0"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Entry.Beschreibung}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <TextBlock Margin="11,1,0,0" FontSize="9"
                                                               Foreground="{DynamicResource TextSecondaryBrush}">
                                                        <Run Text="&#x1F4CD;"/>
                                                        <Run Text="{Binding MeterAtCapture, StringFormat='{}{0:F2}m', Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>
                        </Grid>

                        <!-- â"€â"€ 3. Defekt-Details (bei Auswahl) â"€â"€ -->
                        <Border x:Name="CodingDefectDetailPanel" Style="{StaticResource PlayerCard}"
                                Margin="0,0,0,8" Visibility="Collapsed">
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="CodingDefectDetailBorderBrush" Color="#3B82F6"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness Left="4" Top="0" Right="0" Bottom="0"/>
                            </Border.BorderThickness>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="&#x25B6;" FontSize="{StaticResource TypeCaption}" Margin="0,0,6,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="DEFEKT DETAILS" Style="{StaticResource SectionLabel}" Margin="0"/>
                                </StackPanel>

                                <!-- Code + Schweregrad -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="EN 13508-2 Code" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingDetailCode"
                                                       FontFamily="Consolas" FontSize="{StaticResource TypeH3}" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="Schweregrad" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingDetailSeverity"
                                                       FontSize="{StaticResource TypeH3}" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Beschreibung -->
                                <Border Style="{StaticResource StatTile}" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="Beschreibung" FontSize="10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="TxtCodingDetailDescription"
                                                   FontSize="{StaticResource TypeSmall}" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Distanz + Position + Konfidenz -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource StatTile}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Distanz" FontSize="9"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtCodingDetailDistance"
                                                       FontFamily="Consolas" FontSize="{StaticResource TypeSmall}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource StatTile}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Position" FontSize="9"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtCodingDetailClock"
                                                       FontFamily="Consolas" FontSize="{StaticResource TypeSmall}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="4" Style="{StaticResource StatTile}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Konfidenz" FontSize="9"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="TxtCodingDetailConfidence"
                                                       FontFamily="Consolas" FontSize="{StaticResource TypeSmall}" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Status-Anzeige -->
                                <TextBlock x:Name="TxtCodingDetailStatus" FontSize="{StaticResource TypeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,6"/>

                                <!-- Aktionsbuttons: Akzeptieren / Bearbeiten / Ablehnen -->
                                <Grid x:Name="CodingDefectActionGrid" Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" x:Name="BtnCodingAcceptDefect"
                                            Style="{StaticResource DefectActionBtn}"
                                            Background="#16A34A"
                                            Click="CodingAcceptDefect_Click"
                                            ToolTip="Defekt bestaetigen und mit aktuellem Code ins Protokoll uebernehmen">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x2713;" Margin="0,0,4,0"/>
                                            <TextBlock Text="Akzeptieren"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" x:Name="BtnCodingEditDefect"
                                            Style="{StaticResource DefectActionBtn}"
                                            Background="#D97706"
                                            Click="CodingEditDefect_Click"
                                            ToolTip="Schadenscode, Schweregrad und Position im Detail-Editor anpassen">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x2699;" Margin="0,0,4,0"/>
                                            <TextBlock Text="Bearbeiten"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="4" x:Name="BtnCodingRejectDefect"
                                            Style="{StaticResource DefectActionBtn}"
                                            Background="#DC2626"
                                            MinWidth="40"
                                            Click="CodingRejectDefect_Click"
                                            ToolTip="Defekt verwerfen und aus der Befundliste entfernen">
                                        <TextBlock Text="&#x2717;" FontSize="{StaticResource TypeBodyLarge}"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- == 4. Kalibrierung + Messung (kompakt) == -->
                        <Border Style="{StaticResource PlayerCard}" Margin="0,0,0,4" Padding="6,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="KALIB." FontSize="8" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="TxtCodingCalibDn" FontSize="10" Foreground="{DynamicResource TextBrush}" Text="DN: &#x2014;"/>
                                    <TextBlock x:Name="TxtCodingCalibStatus" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" Text="&#x2014;"/>
                                </StackPanel>
                                <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtCodingQ1" FontSize="10" Foreground="{DynamicResource TextBrush}" Text="Q1:&#x2014;" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="TxtCodingQ2" FontSize="10" Foreground="{DynamicResource TextBrush}" Text="Q2:&#x2014;" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="TxtCodingClock" FontSize="10" Foreground="{DynamicResource TextBrush}" Text="Uhr:&#x2014;" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="TxtCodingArc" FontSize="10" Foreground="{DynamicResource TextBrush}" Text="Bogen:&#x2014;"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <!-- â"€â"€ 5. Codieren (manuell) â"€â"€ -->
                        <Border Style="{StaticResource PlayerCard}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="CODIEREN" Style="{StaticResource SectionLabel}"/>
                                <Button x:Name="BtnCodingSelectCode"
                                        Style="{StaticResource PlayerPrimaryButton}"
                                        Content="Neues Ereignis erfassen"
                                        Padding="8,6" FontSize="{StaticResource TypeSmall}"
                                        Click="CodingSelectCode_Click"
                                        ToolTip="Oeffnet Editor mit Code-Auswahl, Fotos und VSA-Feldern"/>
                                <TextBlock x:Name="TxtCodingSelectedCode"
                                           FontSize="{StaticResource TypeCaption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <!-- Unsichtbar aber vorhanden fuer Kompatibilitaet -->
                                <Button x:Name="BtnCodingCreateEvent"
                                        Visibility="Collapsed"
                                        Click="CodingCreateEvent_Click"
                                        IsEnabled="False"
                                        ToolTip="Neues Ereignis mit ausgewaehltem Code an aktueller Position erstellen"/>
                            </StackPanel>
                        </Border>

                        <!-- â"€â"€ 6. Session-Statistik â"€â"€ -->
                        <Border Style="{StaticResource PlayerCard}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="SESSION STATISTIK" Style="{StaticResource SectionLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="Auto-Akzeptiert" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingStatAutoAccepted"
                                                       Text="0" FontSize="20" FontWeight="Bold"
                                                       Foreground="#22C55E"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="Pending Review" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingStatPending"
                                                       Text="0" FontSize="20" FontWeight="Bold"
                                                       Foreground="#F59E0B"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="Manuell erforderlich" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingStatReviewRequired"
                                                       Text="0" FontSize="20" FontWeight="Bold"
                                                       Foreground="#EF4444"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource StatTile}">
                                        <StackPanel>
                                            <TextBlock Text="Avg. Konfidenz" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TxtCodingStatAvgConfidence"
                                                       Text="&#x2014;" FontSize="20" FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- TRAININGS-SEITENPANEL (nur im Trainings-Modus sichtbar) -->
            <Border x:Name="TrainingSidePanel" Grid.Column="2"
                    Visibility="Collapsed"
                    Margin="8,0,0,0"
                    Background="{DynamicResource CardGlassBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    CornerRadius="10" Padding="10"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Width="260">
                        <TextBlock Text="TRAININGS-MODUS"
                                   FontSize="{StaticResource TypeSmall}" FontWeight="Bold"
                                   Foreground="{DynamicResource NeonCyanBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontSize="{StaticResource TypeCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,10">
                            Video pausieren (Leertaste) &#x2192; Rechteck um Schaden ziehen &#x2192; "Speichern" oeffnet VSA-Code-Auswahl. Sample landet als Trainingsbeispiel in der Knowledge-Base.
                        </TextBlock>

                        <Border Background="{DynamicResource HeaderBrush}" CornerRadius="8"
                                Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="STATUS" Style="{StaticResource SectionLabel}"/>
                                <TextBlock x:Name="TxtTrainingStatus"
                                           Text="Bereit. Rechteck ziehen."
                                           FontSize="{StaticResource TypeSmall}" Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtTrainingCount"
                                           Text="0 Samples in dieser Sitzung"
                                           FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="METER (optional)" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="TxtTrainingMeter"
                                 FontSize="{StaticResource TypeSmall}" Padding="6,4"
                                 Margin="0,0,0,8"
                                 ToolTip="Meterstand des Schadens (leer = aus Video-Zeit abgeleitet)"/>

                        <TextBlock Text="SCHWEREGRAD" Style="{StaticResource SectionLabel}"/>
                        <ComboBox x:Name="CmbTrainingSeverity"
                                  FontSize="{StaticResource TypeSmall}"
                                  Margin="0,0,0,8"
                                  SelectedIndex="2">
                            <ComboBoxItem Content="1 - Optisch"/>
                            <ComboBoxItem Content="2 - Leicht"/>
                            <ComboBoxItem Content="3 - Mittel"/>
                            <ComboBoxItem Content="4 - Schwer"/>
                            <ComboBoxItem Content="5 - Kritisch"/>
                        </ComboBox>

                        <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                            <Button x:Name="BtnTrainingSave"
                                    Content="&#x1F4BE; Speichern (Code waehlen)"
                                    Style="{StaticResource PlayerPrimaryButton}"
                                    Click="TrainingSave_Click"
                                    Margin="0,0,0,4"
                                    IsEnabled="False"
                                    ToolTip="Aktuelles Rechteck mit VSA-Code verknuepfen und als Trainingsbeispiel speichern"/>
                            <Button x:Name="BtnTrainingClear"
                                    Content="&#x2716; Rechteck loeschen"
                                    Style="{StaticResource PlayerButton}"
                                    Click="TrainingClear_Click"
                                    Margin="0,0,0,4"
                                    IsEnabled="False"/>
                            <Button x:Name="BtnTrainingNegativ"
                                    Content="&#x229B; Negativ-Beispiel speichern"
                                    Style="{StaticResource PlayerButton}"
                                    Click="TrainingNegativ_Click"
                                    ToolTip="Aktuellen Frame als Negativ-Beispiel (kein Befund) speichern"/>
                        </StackPanel>

                        <Border Background="{DynamicResource HeaderBrush}" CornerRadius="8"
                                Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="HINWEISE" Style="{StaticResource SectionLabel}"/>
                                <TextBlock TextWrapping="Wrap" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    &#x2022; Leertaste: Video pausieren/weiter&#x0A;&#x2022; Rechteck: Ziehen mit gedrueckter Maustaste&#x0A;&#x2022; Code-Auswahl oeffnet sich nach "Speichern"&#x0A;&#x2022; Frame wird automatisch als PNG exportiert&#x0A;&#x2022; KB indexiert das Sample wenn Ollama laeuft
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnTrainingExit"
                                Content="Trainings-Modus beenden"
                                Style="{StaticResource PlayerButton}"
                                Click="TrainingExit_Click"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- â•â•â•â•â•â•â• CODING-WERKZEUGE (nur im Codier-Modus sichtbar) â•â•â•â•â•â•â• -->
        <Border x:Name="CodingToolbar" Grid.Row="2"
                Visibility="Collapsed"
                Style="{StaticResource PlayerCard}"
                Margin="0,0,0,8" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- Meter-Anzeige -->
                    <ColumnDefinition Width="Auto"/>   <!-- Werkzeuge -->
                    <ColumnDefinition Width="Auto"/>   <!-- KI-Status + Analyse -->
                    <ColumnDefinition Width="*"/>      <!-- Findings -->
                    <ColumnDefinition Width="Auto"/>   <!-- Beenden -->
                </Grid.ColumnDefinitions>

                <!-- Meter-Navigation -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button Style="{StaticResource PlayerButton}" Content="&#x25C0;" Padding="8,6"
                            Click="CodingPrevious_Click" ToolTip="Einen Schritt zurueck zum vorherigen Meterstand in der Haltung"/>
                    <TextBlock x:Name="TxtCodingMeter"
                               FontFamily="Consolas, Cascadia Mono" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" Margin="8,0"
                               Text="0.00m"/>
                    <Button Style="{StaticResource PlayerButton}" Content="&#x25B6;" Padding="8,6"
                            Click="CodingNext_Click" ToolTip="Einen Schritt vorwaerts zum naechsten Meterstand in der Haltung"/>
                    <TextBlock x:Name="TxtCodingRange"
                               FontSize="{StaticResource TypeCaption}" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Direkte Werkzeug-Buttons (Dropdown entfernt - "Werkzeuge"-Untermenue weg) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Border Width="1" Height="28" Background="{DynamicResource BorderBrush}" Margin="0,0,8,0"/>

                    <!-- Aktives Werkzeug Label -->
                    <TextBlock x:Name="TxtActiveToolLabel" Text="" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

                    <!-- Markieren: direkt als Button (vorher im Werkzeuge-Untermenue) -->
                    <Button x:Name="BtnCodingRect" Style="{StaticResource PlayerButton}" Padding="8,5"
                            Click="CodingToolRect_Click" Margin="0,0,6,0"
                            ToolTip="Rechteckigen Bereich im Frame markieren fuer gezielte KI-Analyse">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25A2;" FontSize="{StaticResource TypeSmall}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Markieren" FontSize="{StaticResource TypeCaption}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Kalibrieren: direkt als Button -->
                    <Button x:Name="BtnCodingCalibrate" Style="{StaticResource PlayerButton}" Padding="8,5"
                            Click="CodingCalibrate_Click"
                            ToolTip="Rohrdurchmesser im Video kalibrieren fuer praezise Vermessungen">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2295;" FontSize="{StaticResource TypeSmall}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Kalibrieren" FontSize="{StaticResource TypeCaption}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Legacy: Dropdown-Button + Popups als unsichtbare Stubs - rueckwaertskompatibel
                         (existierende Code-Behind-Referenzen ToolsDropdown_Click + CodingMarkToolPopup
                         bleiben damit gueltig, ohne dass der Nutzer sie sieht). -->
                    <Button x:Name="BtnToolsDropdown" Visibility="Collapsed"
                            Click="ToolsDropdown_Click"/>
                    <Popup x:Name="ToolsDropdownPopup" StaysOpen="False" IsOpen="False"
                           PlacementTarget="{Binding ElementName=BtnToolsDropdown}"/>
                    <Popup x:Name="CodingMarkToolPopup" StaysOpen="False" IsOpen="False"
                           PlacementTarget="{Binding ElementName=BtnToolsDropdown}"/>
                </StackPanel>

                <!-- KI-Status + Analyse (zwei Zeilen) -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0">
                    <!-- Zeile 1: Status + Hauptbuttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <Border Width="1" Height="28" Background="{DynamicResource BorderBrush}" Margin="0,0,8,0"/>
                        <Grid Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse x:Name="CodingAiPulseRing" Width="10" Height="10"
                                     Stroke="#F59E0B" StrokeThickness="2" Fill="Transparent"
                                     Opacity="0" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="CodingAiDot" Width="10" Height="10" Fill="{StaticResource MutedBrush}"/>
                        </Grid>
                        <TextBlock x:Name="TxtCodingAiStatus" FontSize="{StaticResource TypeCaption}"
                                   Foreground="{DynamicResource TextBrush}"
                                   Text="Kuenstliche Intelligenz bereit" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="TxtCodingAiStage" FontSize="9"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ToggleButton x:Name="BtnCodingLiveAi" Style="{StaticResource SpeedToggleButton}"
                                      IsChecked="False" Margin="0,0,6,0"
                                      ToolTip="Automatische KI-Analyse im Codiermodus an/aus (alle 5s)" Click="CodingLiveAi_Click">
                            <TextBlock Text="Automatische KI-Analyse" FontSize="{StaticResource TypeCaption}"/>
                        </ToggleButton>
                        <Button x:Name="BtnCodingAnalyze"
                                Style="{StaticResource PlayerPrimaryButton}"
                                Padding="10,5" FontSize="{StaticResource TypeCaption}"
                                Click="CodingAnalyzeFrame_Click"
                                ToolTip="Aktuellen Frame einmalig per KI analysieren">
                            <TextBlock Text="Aktuellen Frame analysieren"/>
                        </Button>
                    </StackPanel>
                    <!-- Zeile 2: Pausenmodus + Eingabemarker + Overlays -->
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="BtnCodingPauseMode" Style="{StaticResource SpeedToggleButton}"
                                      IsChecked="False" Margin="0,0,6,0"
                                      ToolTip="Pausenmodus: Video pausiert bei jedem KI-Befund — Zeit zum Korrigieren oder Bestaetigen"
                                      Click="CodingPauseMode_Click">
                            <TextBlock Text="KI-Analyse mit Pause" FontSize="{StaticResource TypeCaption}"/>
                        </ToggleButton>
                        <Button x:Name="BtnCodingClearOverlays"
                                Padding="8,5" FontSize="{StaticResource TypeCaption}" Margin="0,0,6,0"
                                Background="{StaticResource CardBrush}" Foreground="{StaticResource MutedBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Cursor="Hand"
                                Click="CodingClearOverlays_Click"
                                ToolTip="Alle Einblendungen/Markierungen vom Video entfernen">
                            <TextBlock Text="&#x2716; Overlays aus" FontSize="10"/>
                        </Button>
                        <ToggleButton x:Name="BtnEingabemarker" Style="{StaticResource SpeedToggleButton}"
                                      IsChecked="False" Margin="0,0,0,0"
                                      ToolTip="Eingabemarker: Video pausiert, Stelle markieren, Stichwort eingeben → KI bestimmt Code"
                                      Click="Eingabemarker_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4CD;" FontSize="{StaticResource TypeBodyLarge}" Margin="0,0,4,0"/>
                                <TextBlock Text="Eingabemarker" FontSize="{StaticResource TypeCaption}"/>
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>

                    <!-- Eingabemarker: Freitext + Schnellauswahl -->
                    <Border x:Name="EingabemarkerPopup" Visibility="Collapsed"
                            Margin="6,0,0,0" VerticalAlignment="Center"
                            Background="{StaticResource HeaderBrush}" CornerRadius="6"
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="2"
                            Padding="6,4">
                        <StackPanel Orientation="Horizontal">
                            <!-- Freitext-Eingabe (primaer) -->
                            <TextBox x:Name="TxtEingabemarker"
                                     FontSize="{StaticResource TypeSmall}" Width="220"
                                     Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     Padding="4,3" VerticalContentAlignment="Center"
                                     KeyDown="CmbEingabemarker_KeyDown">
                                <TextBox.ToolTip>
                                    <TextBlock>
                                        Freitext: z.B. "Beule unten", "Riss bei 3 Uhr", "Anschluss offen 9h"
                                        <LineBreak/>Oder Stichwort aus der Liste waehlen.
                                        <LineBreak/>Enter = Bestaetigen | Esc = Abbrechen
                                    </TextBlock>
                                </TextBox.ToolTip>
                            </TextBox>
                            <!-- Schnellauswahl (Dropdown) -->
                            <ComboBox x:Name="CmbEingabemarker"
                                      FontSize="{StaticResource TypeCaption}" Width="130" Margin="4,0,0,0"
                                      Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      SelectionChanged="CmbEingabemarker_SelectionChanged">
                                <ComboBox.ToolTip>Schnellauswahl: Haeufigste Codes</ComboBox.ToolTip>
                                <ComboBoxItem Content="Rohranfang" FontWeight="SemiBold"/>
                                <ComboBoxItem Content="Rohrende" FontWeight="SemiBold"/>
                                <ComboBoxItem Content="Anschluss" FontWeight="SemiBold"/>
                                <ComboBoxItem Content="Bogen" FontWeight="SemiBold"/>
                                <Separator/>
                                <ComboBoxItem Content="Riss"/>
                                <ComboBoxItem Content="Bruch"/>
                                <ComboBoxItem Content="Verformung"/>
                                <ComboBoxItem Content="Versatz"/>
                                <ComboBoxItem Content="Wurzeln"/>
                                <ComboBoxItem Content="Ablagerung"/>
                                <ComboBoxItem Content="Inkrustation"/>
                                <ComboBoxItem Content="Wasserstand"/>
                                <ComboBoxItem Content="Abbruch"/>
                            </ComboBox>
                            <TextBlock Text="Enter &#x2714;" Foreground="{StaticResource MutedBrush}" FontSize="9"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Aktuelle Position: Code am Zeitstempel (aus DataGrid) -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Naechster Code am aktuellen Meter -->
                    <Border x:Name="CodingCurrentCodeBadge"
                            Background="{DynamicResource HeaderBrush}" CornerRadius="8"
                            Padding="8,3" Margin="0,0,8,0" Visibility="Collapsed">
                        <TextBlock x:Name="TxtCodingCurrentCode"
                                   FontSize="{StaticResource TypeCaption}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NeonCyanBrush}"/>
                    </Border>

                    <!-- KI-Findings: Vollstaendige Anzeige mit Code + Klartext + Details -->
                    <ItemsControl x:Name="CodingFindingsList" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource HeaderBrush}" CornerRadius="8"
                                        Padding="10,4" Margin="0,0,6,0" VerticalAlignment="Center"
                                        ToolTip="{Binding FullTooltip, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="{Binding SeverityBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <!-- VSA-Code fett -->
                                        <TextBlock FontSize="{StaticResource TypeCaption}" FontWeight="Bold"
                                                   Foreground="{DynamicResource NeonCyanBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding VsaCode, Mode=OneWay}"/>
                                        <!-- Klartext-Beschreibung -->
                                        <TextBlock FontSize="{StaticResource TypeCaption}" FontWeight="Normal"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                   Text="{Binding Description, Mode=OneWay}"/>
                                        <!-- Meter + Uhr (wenn vorhanden) -->
                                        <TextBlock FontSize="10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                                   Text="{Binding PositionText, Mode=OneWay}"/>
                                        <!-- Confidence -->
                                        <TextBlock FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{Binding ConfidenceBrush}"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                   Text="{Binding ConfidenceText, Mode=OneWay}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Uebernehmen + Beenden -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Style="{StaticResource PlayerPrimaryButton}"
                            Padding="10,5"
                            Click="CodingApply_Click"
                            ToolTip="Codierung in Primaere Schaeden uebernehmen">
                        <TextBlock Text="Uebernehmen" FontSize="{StaticResource TypeCaption}" FontWeight="SemiBold"/>
                    </Button>
                    <Button Style="{StaticResource PlayerButton}"
                            Foreground="#EF4444" Margin="6,0,0,0"
                            Click="CodingModeExit_Click"
                            ToolTip="Codier-Modus beenden ohne Uebernahme">
                        <TextBlock Text="Beenden" FontSize="{StaticResource TypeCaption}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- â•â•â•â•â•â•â• PIPE GRAPH TIMELINE (nur im Codier-Modus sichtbar) â•â•â•â•â•â•â• -->
        <StackPanel Grid.Row="3" x:Name="CodingTimelinePanel" Visibility="Collapsed">
            <ctrl:PipeGraphTimeline x:Name="PipeTimeline" Visibility="Collapsed" Height="0"/>

            <!-- YOLO-Statusanzeige -->
            <Border x:Name="YoloStatusBar" Visibility="Collapsed"
                    Background="{DynamicResource SurfaceBrush}" CornerRadius="4"
                    Padding="10,4" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="YoloDot" Width="8" Height="8"
                             Fill="{StaticResource MutedBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtYoloStatus" Text="YOLO: Bereit"
                               FontSize="{StaticResource TypeCaption}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtYoloModel" Text=""
                               FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="4"
                Style="{StaticResource PlayerCard}"
                Margin="0,0,0,12"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="CurrentTimeText"
                           Grid.Column="0"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource PlayerTimeText}"
                           Text="00:00"/>

                <Grid Grid.Column="1">
                    <!-- Quick-Scan heatmap overlay, below slider -->
                    <Canvas x:Name="HeatmapCanvas"
                            IsHitTestVisible="True"
                            VerticalAlignment="Center"
                            Height="6"
                            Margin="0,12,0,0"
                            ClipToBounds="True"/>
                    <Slider x:Name="PositionSlider"
                            Minimum="0"
                            Maximum="1000"
                            Margin="0,1"
                            IsMoveToPointEnabled="True"
                            ValueChanged="PositionSlider_ValueChanged"
                            ToolTip="Videoposition - ziehen fuer Live-Vorschau, klicken zum Springen"/>
                    <!-- Damage code marker overlay, positioned dynamically to match slider track -->
                    <Canvas x:Name="DamageMarkerCanvas"
                            IsHitTestVisible="True"
                            VerticalAlignment="Center"
                            Height="28"
                            ClipToBounds="False"/>
                </Grid>

                <TextBlock x:Name="DurationText"
                           Grid.Column="2"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource PlayerTimeText}"
                           Text="00:00"/>
            </Grid>
        </Border>

        <Border Grid.Row="5"
                Style="{StaticResource PlayerCard}"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" Margin="0,0,18,0" VerticalAlignment="Center">
                    <Button Style="{StaticResource PlayerPrimaryButton}" Margin="0,0,6,0" Click="Play_Click"
                            ToolTip="Video abspielen (Leertaste)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Play" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PlayerButton}" Margin="0,0,6,0" Click="Pause_Click"
                            ToolTip="Video pausieren (Leertaste)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Pause" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PlayerButton}" Click="Stop_Click"
                            ToolTip="Wiedergabe stoppen und zum Anfang zuruecksetzen">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Stop" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Height="24" Margin="8,0"
                            Background="{DynamicResource BorderBrush}"/>

                    <!-- Schnell-Scan, Live-KI, Markieren, Trainings-Modus aus dem normalen
                         Player-Modus entfernt. KI-Funktionalitaet lebt jetzt nur noch im
                         Codier-Modus. Buttons + Popups bleiben als unsichtbare Stubs damit
                         existing Code-Behind-Referenzen (Hotkeys M/D, etc.) nicht crashen. -->
                    <ToggleButton x:Name="QuickScanButton" Visibility="Collapsed"
                                  Click="QuickScan_Click"/>
                    <TextBlock x:Name="QuickScanStatusText" Visibility="Collapsed"/>
                    <ToggleButton x:Name="LiveDetectionButton" Visibility="Collapsed"
                                  Click="LiveDetection_Click"/>
                    <Button x:Name="ManualMarkButton" Visibility="Collapsed"
                            Click="ManualMark_Click">
                        <TextBlock x:Name="TxtMarkToolName" Text="Markieren"/>
                    </Button>
                    <Popup x:Name="MarkToolPopup" StaysOpen="False" IsOpen="False"
                           PlacementTarget="{Binding ElementName=ManualMarkButton}"/>

                    <Button x:Name="CodingModeButton"
                            Style="{StaticResource PlayerPrimaryButton}"
                            Margin="6,0,0,0"
                            Click="CodingMode_Click"
                            ToolTip="Codier-Modus: Haltung komplett durchcodieren mit Overlay-Werkzeugen (C)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Codier-Modus" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <ToggleButton x:Name="TrainingModeButton" Visibility="Collapsed"
                                  Click="TrainingMode_Click"/>

                    <TextBlock x:Name="LiveDetectionStatusText" Visibility="Collapsed"/>
                </WrapPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Wiedergabegeschwindigkeit"
                               Style="{StaticResource PlayerLabelText}"
                               Margin="0,0,0,6"/>
                    <WrapPanel>
                        <ToggleButton x:Name="Speed05Button" Style="{StaticResource SpeedToggleButton}" Content="0.5x" Click="Speed05_Click"
                                      ToolTip="Halbe Geschwindigkeit - fuer detaillierte Inspektion"/>
                        <ToggleButton x:Name="Speed1Button" Style="{StaticResource SpeedToggleButton}" Content="1x" Click="Speed1_Click"
                                      ToolTip="Normale Wiedergabegeschwindigkeit"/>
                        <ToggleButton x:Name="Speed15Button" Style="{StaticResource SpeedToggleButton}" Content="1.5x" Click="Speed15_Click"
                                      ToolTip="1.5-fache Geschwindigkeit"/>
                        <ToggleButton x:Name="Speed2Button" Style="{StaticResource SpeedToggleButton}" Content="2x" Click="Speed2_Click"
                                      ToolTip="Doppelte Geschwindigkeit"/>
                        <ToggleButton x:Name="Speed4Button" Style="{StaticResource SpeedToggleButton}" Content="4x" Click="Speed4_Click"
                                      ToolTip="4-fache Geschwindigkeit - schneller Ueberblick"/>
                        <ToggleButton x:Name="Speed8Button" Style="{StaticResource SpeedToggleButton}" Content="8x" Margin="0" Click="Speed8_Click"
                                      ToolTip="8-fache Geschwindigkeit - maximaler Schnellvorlauf"/>
                    </WrapPanel>
                </StackPanel>

                <Border Grid.Column="2"
                        Style="{StaticResource PlayerMetaCard}"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Aktuelle Rate"
                                   Style="{StaticResource PlayerLabelText}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock x:Name="RateText"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="{StaticResource TypeH3}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   Text="1.00x"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
