<Window x:Class="AuswertungPro.Next.UI.Views.Windows.LiveFrameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Live-Frame Vorschau"
        Height="640" Width="860"
        MinWidth="400" MinHeight="300"
        Background="{StaticResource BgLightBrush}"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="12,8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="LIVE-FRAME / ANALYSE"
                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding LiveFrameInfo}"
                           FontSize="11" Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Live Frame -->
        <Border Grid.Row="1" Margin="8"
                CornerRadius="8"
                Background="{StaticResource BgLightBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <Image x:Name="LiveImage"
                       Stretch="Uniform"
                       StretchDirection="Both"/>
                <Canvas x:Name="OverlayCanvas"
                        Background="Transparent"
                        IsHitTestVisible="False"/>
                <TextBlock Text="Warte auf Frame..."
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           x:Name="PlaceholderText"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource HeaderBrush}" Padding="12,6"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           x:Name="StatusText"
                           FontSize="11" Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock DockPanel.Dock="Right"
                           x:Name="QuantText"
                           FontSize="10" Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="400"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
