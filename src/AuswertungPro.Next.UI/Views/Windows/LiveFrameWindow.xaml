<Window x:Class="AuswertungPro.Next.UI.Views.Windows.LiveFrameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Live-Frame Vorschau"
        Height="640" Width="860"
        MinWidth="400" MinHeight="300"
        Background="#111318"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#151820" Padding="12,8"
                BorderBrush="#2A3248" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="LIVE-FRAME / ANALYSE"
                           FontSize="11" FontWeight="SemiBold" Foreground="#6B7A94"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding LiveFrameInfo}"
                           FontSize="11" Foreground="#8090A8"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Live Frame -->
        <Border Grid.Row="1" Margin="8"
                CornerRadius="8"
                Background="#0E1118"
                BorderBrush="#2A3248"
                BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <Image x:Name="LiveImage"
                       Stretch="Uniform"
                       StretchDirection="Both"/>
                <Canvas x:Name="OverlayCanvas"
                        Background="Transparent"
                        IsHitTestVisible="False"/>
                <TextBlock Text="Warte auf Frame..."
                           Foreground="#6B7A94"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           x:Name="PlaceholderText"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#151820" Padding="12,6"
                BorderBrush="#2A3248" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           x:Name="StatusText"
                           FontSize="11" Foreground="#A5B4FC"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock DockPanel.Dock="Right"
                           x:Name="QuantText"
                           FontSize="10" Foreground="#9CA3AF"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="400"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
