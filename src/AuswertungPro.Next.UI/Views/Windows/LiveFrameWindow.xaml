<Window x:Class="AuswertungPro.Next.UI.Views.Windows.LiveFrameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Live-Frame Vorschau"
        Height="680" Width="900"
        MinWidth="420" MinHeight="320"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="16,14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="LIVE-FRAME / ANALYSE" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Aktuelle KI-Vorschau mit Overlay-Infos" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Border DockPanel.Dock="Right" Background="{StaticResource HeaderBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12,8">
                    <TextBlock Text="{Binding LiveFrameInfo}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
            <Grid>
                <Border CornerRadius="14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF0D1523" Offset="0"/>
                            <GradientStop Color="#FF111C2E" Offset="0.55"/>
                            <GradientStop Color="#FF0A1321" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border Margin="0" CornerRadius="14" Background="#120D6EFD" BorderBrush="#300D6EFD" BorderThickness="1"/>
                <Image x:Name="LiveImage" Stretch="Uniform" StretchDirection="Both" Margin="8"/>
                <Canvas x:Name="OverlayCanvas" Background="Transparent" IsHitTestVisible="False" Margin="8"/>
                <TextBlock x:Name="PlaceholderText"
                           Text="Warte auf Frame..."
                           Foreground="#9FB3CF"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource HeaderBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14,10" Margin="0,12,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" x:Name="StatusText" FontSize="12" Foreground="{StaticResource AccentBrush}" TextTrimming="CharacterEllipsis"/>
                <TextBlock DockPanel.Dock="Right" x:Name="QuantText" FontSize="11" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="440"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
