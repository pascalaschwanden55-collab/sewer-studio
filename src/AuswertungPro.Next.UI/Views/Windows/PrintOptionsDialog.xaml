<Window x:Class="AuswertungPro.Next.UI.Views.Windows.PrintOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitle}"
        Width="480" Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgMidBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titel -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding DialogTitle}"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding DialogSubtitle}"
                       FontSize="{StaticResource TypeCaption}" Foreground="{StaticResource MutedBrush}"/>
        </StackPanel>

        <!-- Sektionen mit Checkboxen -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
            <ItemsControl ItemsSource="{Binding Sections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,8">
                            <!-- Sektions-Header -->
                            <TextBlock Text="{Binding Header}"
                                       FontSize="{StaticResource TypeSmall}" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,4,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Header}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- Optionen -->
                            <ItemsControl ItemsSource="{Binding Options}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsEnabled}"
                                                  Margin="8,3,0,0"
                                                  ToolTip="{Binding InfoText}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Info-Bereich -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding InfoLines}" Margin="8,12,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Text}" FontSize="{StaticResource TypeCaption}"
                               Foreground="{Binding Foreground}"
                               Margin="0,2"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="90" Height="30" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Style="{StaticResource SecondaryButton}"
                    ToolTip="Abbrechen ohne PDF zu erstellen"/>
            <Button Content="{Binding OkButtonText}" Width="140" Height="30"
                    Click="Ok_Click"
                    Style="{StaticResource PrimaryButton}"
                    ToolTip="{Binding OkButtonTooltip}"/>
        </StackPanel>
    </Grid>
</Window>
