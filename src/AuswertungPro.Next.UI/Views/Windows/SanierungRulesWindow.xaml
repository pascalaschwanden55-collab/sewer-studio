<Window x:Class="AuswertungPro.Next.UI.Views.Windows.SanierungRulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KI-Sanierungsregeln verwalten"
        Width="1100" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="KI-Sanierungsregeln (Hard-Constraints)"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,12">
            Diese Regeln werden VOR jeder KI-Anfrage ausgewertet und schliessen technisch unzulaessige Verfahren aus.
            Beispiel: "WENN Bogen >= 15 Grad DANN GFK-Liner ausschliessen WEIL nicht bogengaengig".
            Die KI darf ausgeschlossene Verfahren niemals empfehlen.
        </TextBlock>

        <DataGrid Grid.Row="2" x:Name="RulesGrid"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" SelectionMode="Single"
                  AlternatingRowBackground="#F8F9FA"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  MouseDoubleClick="RulesGrid_MouseDoubleClick"
                  SelectionChanged="RulesGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Aktiv" Binding="{Binding Enabled}" Width="50"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220"/>
                <DataGridTextColumn Header="WENN (Bedingung)" Binding="{Binding ConditionsSummary}" Width="280"/>
                <DataGridTextColumn Header="DANN ausschliessen" Binding="{Binding ExcludesSummary}" Width="200"/>
                <DataGridTextColumn Header="WEIL (Begruendung)" Binding="{Binding Reason}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="AddButton" Content="+ Neue Regel" Click="Add_Click"
                    Margin="0,0,8,0" Padding="14,6" FontWeight="SemiBold"/>
            <Button x:Name="EditButton" Content="Bearbeiten" Click="Edit_Click"
                    Margin="0,0,8,0" Padding="14,6" IsEnabled="False"/>
            <Button x:Name="ToggleButton" Content="Aktivieren / Deaktivieren" Click="Toggle_Click"
                    Margin="0,0,8,0" Padding="14,6" IsEnabled="False"/>
            <Button x:Name="DeleteButton" Content="Loeschen" Click="Delete_Click"
                    Margin="0,0,16,0" Padding="14,6" IsEnabled="False"/>
            <Button x:Name="SaveButton" Content="Speichern + Engine neu laden" Click="Save_Click"
                    Margin="0,0,8,0" Padding="14,6" FontWeight="Bold"
                    Background="{StaticResource NeonCyanBrush}" Foreground="White"/>
            <Button Content="Schliessen" Click="Close_Click" Padding="14,6"/>
        </StackPanel>
    </Grid>
</Window>
