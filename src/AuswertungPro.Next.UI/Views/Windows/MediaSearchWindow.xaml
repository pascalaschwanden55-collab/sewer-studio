<Window x:Class="AuswertungPro.Next.UI.Views.Windows.MediaSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Medien suchen und verlinken" Height="720" Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="800" MinHeight="500">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Status row backgrounds (light-theme compatible) -->
        <SolidColorBrush x:Key="StatusFoundRowBrush" Color="#E6F9F0"/>
        <SolidColorBrush x:Key="StatusAmbiguousRowBrush" Color="#FFF7E6"/>
        <SolidColorBrush x:Key="StatusMissingRowBrush" Color="#FEF0F0"/>

        <!-- Status text colors (high contrast on light bg) -->
        <SolidColorBrush x:Key="StatusFoundTextBrush" Color="#059669"/>
        <SolidColorBrush x:Key="StatusAmbiguousTextBrush" Color="#D97706"/>
        <SolidColorBrush x:Key="StatusMissingTextBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="StatusLinkedTextBrush" Color="#0B5F78"/>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="Gefunden">
                    <Setter Property="Foreground" Value="{StaticResource StatusFoundTextBrush}"/>
                </Trigger>
                <Trigger Property="Text" Value="Mehrdeutig">
                    <Setter Property="Foreground" Value="{StaticResource StatusAmbiguousTextBrush}"/>
                </Trigger>
                <Trigger Property="Text" Value="Nicht gefunden">
                    <Setter Property="Foreground" Value="{StaticResource StatusMissingTextBrush}"/>
                </Trigger>
                <Trigger Property="Text" Value="Verlinkt">
                    <Setter Property="Foreground" Value="{StaticResource StatusLinkedTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Options -->
        <Border Style="{DynamicResource Card}" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Medien-Suche" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Suchordner:" Style="{StaticResource LabelText}" Width="90"/>
                    <TextBox x:Name="FolderBox" Width="600" Margin="0,0,8,0"
                             Padding="6,4" FontSize="13" VerticalContentAlignment="Center"/>
                    <Button x:Name="BrowseButton" Content="Durchsuchen..." Click="Browse_Click"
                            Style="{DynamicResource SecondaryButton}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <CheckBox x:Name="OverwriteCheck" Margin="90,0,20,0"
                              Content="Bereits verlinkte ueberschreiben" FontSize="12"/>
                    <CheckBox x:Name="PdfCheck" Margin="0,0,20,0"
                              Content="PDFs suchen" IsChecked="True" FontSize="12"/>
                    <CheckBox x:Name="FotoCheck" Margin="0,0,20,0"
                              Content="Fotos suchen" IsChecked="True" FontSize="12"/>
                    <CheckBox x:Name="RecursiveCheck" Margin="0,0,20,0"
                              Content="Rekursiv (Unterordner)" IsChecked="True" FontSize="12"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="StartButton" Content="Suche starten" Click="Start_Click"
                            Style="{DynamicResource PrimaryButton}" Margin="90,0,10,0"/>
                    <Button x:Name="CancelSearchButton" Content="Abbrechen" Click="CancelSearch_Click"
                            Style="{DynamicResource SecondaryButton}" IsEnabled="False"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 1: Progress -->
        <Border Style="{DynamicResource Card}" Grid.Row="1" Margin="0,0,0,10"
                x:Name="ProgressPanel" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="ProgressText" Grid.Row="0" Text="Suche laeuft..."
                           Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
                <ProgressBar x:Name="ProgressBar" Grid.Row="1" Height="10" Minimum="0" Maximum="100"
                             HorizontalAlignment="Stretch"/>
            </Grid>
        </Border>

        <!-- Row 2: Results DataGrid -->
        <Border Style="{DynamicResource Card}" Grid.Row="2" Margin="0,0,0,10" Padding="0">
            <DataGrid x:Name="ResultGrid" AutoGenerateColumns="False" IsReadOnly="False"
                      CanUserSortColumns="True" CanUserResizeColumns="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" FontSize="13"
                      EnableRowVirtualization="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="" Binding="{Binding Apply, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="36"/>
                    <DataGridTextColumn Header="Haltungsname" Binding="{Binding Haltungsname}" Width="160" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Video" Binding="{Binding VideoStatusText}" Width="90" IsReadOnly="True"
                                        ElementStyle="{StaticResource StatusTextStyle}"/>
                    <DataGridTextColumn Header="Video-Pfad" Binding="{Binding VideoPath}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="PDF" Binding="{Binding PdfStatusText}" Width="90" IsReadOnly="True"
                                        ElementStyle="{StaticResource StatusTextStyle}"/>
                    <DataGridTextColumn Header="PDF-Pfad" Binding="{Binding PdfPath}" Width="200" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Fotos" Binding="{Binding FotoStatusText}" Width="90" IsReadOnly="True"
                                        ElementStyle="{StaticResource StatusTextStyle}"/>
                    <DataGridTextColumn Header="Foto-Anzahl" Binding="{Binding FotoCount}" Width="80" IsReadOnly="True"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding VideoStatusText}" Value="Gefunden">
                                <Setter Property="Background" Value="{StaticResource StatusFoundRowBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding VideoStatusText}" Value="Mehrdeutig">
                                <Setter Property="Background" Value="{StaticResource StatusAmbiguousRowBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding VideoStatusText}" Value="Nicht gefunden">
                                <Setter Property="Background" Value="{StaticResource StatusMissingRowBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>

        <!-- Row 3: Footer -->
        <Border Style="{DynamicResource Card}" Grid.Row="3" Padding="14,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <Button x:Name="ApplyButton" Content="Anwenden" Click="Apply_Click"
                            Style="{DynamicResource PrimaryButton}" IsEnabled="False" Margin="0,0,8,0"/>
                    <Button x:Name="CloseButton" Content="Schliessen" Click="Close_Click"
                            Style="{DynamicResource SecondaryButton}"/>
                </StackPanel>
                <TextBlock x:Name="SummaryText" Style="{StaticResource LabelText}"
                           Text="Starten Sie die Suche um Ergebnisse anzuzeigen."
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
