<Window x:Class="AuswertungPro.Next.UI.Views.Windows.TrainingCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AuswertungPro.Next.UI.Views.Windows"
        Title="Training Center" Height="900" Width="1400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NotNullToBoolConverter x:Key="NotNullToBool"/>
        <local:FileToImageConverter x:Key="FileToImage"/>
    </Window.Resources>
    <Grid Margin="12" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Padding="10" CornerRadius="6"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ordner:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding RootFolder}" IsReadOnly="True"
                         ToolTip="{Binding RootFolder}" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Ordner wählen..."
                        Command="{Binding BrowseRootFolderCommand}"
                        ToolTip="Mehrere Ordner auswählen (werden kumuliert)" Margin="0,0,4,0"/>
                <Button Grid.Column="3" Content="X"
                        Command="{Binding ClearRootFoldersCommand}"
                        ToolTip="Ordnerauswahl zurücksetzen"
                        Padding="6,2" Margin="0,0,8,0"/>
                <Button Grid.Column="4" Content="Scannen" Command="{Binding ScanCommand}" Margin="0,0,4,0"/>
                <Button Grid.Column="5" Content="Speichern" Command="{Binding SaveCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="6" Content="&#x25B6; Batch-Import + KB" Command="{Binding BatchImportAndIndexCommand}"
                        ToolTip="Alle Ordner scannen, Samples generieren, auto-approve, Knowledge Base indizieren"
                        FontWeight="SemiBold" Margin="0,0,8,0"/>
                <Button Grid.Column="7" Content="KB prüfen" Command="{Binding CheckKnowledgeBaseCommand}"
                        ToolTip="Liest Samples, Embeddings, Versionen und Top-Codes aus der Knowledge Base"
                        Margin="0,0,8,0"/>
                <Button Grid.Column="8" Content="Abbrechen" Command="{Binding CancelBatchCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

        <!-- Row 1: Trainingsstand -->
        <Border Grid.Row="1" Background="#1E293B" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Ampel-Kreis + Label -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                    <Border Width="14" Height="14" CornerRadius="7"
                            VerticalAlignment="Center" Margin="0,0,8,0"
                            Background="{Binding KbReadinessBrush}"/>
                    <TextBlock Text="{Binding KbReadinessLabel}" Foreground="#E2E8F0" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Zaehler -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Foreground="#94A3B8" Text="Samples: "/>
                    <TextBlock Foreground="#E2E8F0" Text="{Binding KbSampleCount}" FontWeight="Bold"/>
                    <TextBlock Foreground="#FBBF24" FontSize="11"
                               Text="{Binding KbErrorCount, StringFormat=' ({0}⚠'}"/>
                    <TextBlock Foreground="#64748B" FontSize="11"
                               Text="{Binding KbNewCount, StringFormat=' {0} neu)'}"/>
                    <TextBlock Foreground="#94A3B8" Text="  |  Codes: "/>
                    <TextBlock Foreground="#E2E8F0" Text="{Binding KbCodesCovered}" FontWeight="Bold"/>
                </StackPanel>

                <!-- Top-Codes Tooltip -->
                <TextBlock Grid.Column="2" Text="Code-Verteilung" Foreground="#64748B" Cursor="Help">
                    <TextBlock.ToolTip>
                        <TextBlock Text="{Binding KbTopCodesText}" FontFamily="Consolas"/>
                    </TextBlock.ToolTip>
                </TextBlock>

                <!-- Letztes Update -->
                <TextBlock Grid.Column="4" Foreground="#64748B">
                    <Run Text="Letzte KB-Aktualisierung: "/>
                    <Run Text="{Binding KbLastUpdate, Mode=OneWay}" Foreground="#94A3B8"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Tab Content -->
        <TabControl Grid.Row="2">

            <!-- Tab 1: Fälle -->
            <TabItem Header="Fälle">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid Grid.Column="0"
                              ItemsSource="{Binding Cases}"
                              SelectedItem="{Binding SelectedCase, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CaseId" Binding="{Binding CaseId}" Width="1.2*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.6*"/>
                            <DataGridTextColumn Header="Video" Binding="{Binding VideoPath}" Width="2*"/>
                            <DataGridTextColumn Header="Protokoll" Binding="{Binding ProtocolPath}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="1" Margin="12,0,0,0" Padding="10" CornerRadius="6"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Ausgewählter Fall" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Grid.Row="1" Text="{Binding SelectedCase.CaseId}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Text="{Binding SelectedCase.FolderPath}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="3" Text="{Binding SelectedCase.VideoPath}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="4" Text="{Binding SelectedCase.ProtocolPath}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <StackPanel Grid.Row="5" Orientation="Vertical" Margin="0,12,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                    <Button Content="Approve" Command="{Binding ApproveCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Reject" Command="{Binding RejectCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Set New" Command="{Binding SetNewCommand}"/>
                                </StackPanel>
                                <Button Content="Samples generieren..."
                                        Command="{Binding GenerateSamplesCommand}"
                                        HorizontalAlignment="Stretch"
                                        Padding="8,6"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: Samples -->
            <TabItem Header="Samples">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0"
                                  ItemsSource="{Binding Samples}"
                                  SelectedItem="{Binding SelectedSample, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="0.6*"/>
                                <DataGridTextColumn Header="m Start" Binding="{Binding MeterStart, StringFormat=F2}" Width="0.5*"/>
                                <DataGridTextColumn Header="m End" Binding="{Binding MeterEnd, StringFormat=F2}" Width="0.5*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.6*"/>
                                <DataGridCheckBoxColumn Header="OSD ?" Binding="{Binding HasOsdMismatch}" Width="0.4*"/>
                                <DataGridTextColumn Header="Exportiert" Binding="{Binding ExportedUtc, StringFormat=g}" Width="0.8*"/>
                                <DataGridTextColumn Header="Fall" Binding="{Binding CaseId}" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Sample-Vorschau -->
                        <Border Grid.Column="1" Margin="12,0,0,0" Padding="10" CornerRadius="6"
                                Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Sample-Details" FontWeight="SemiBold" FontSize="14"/>
                                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                    <TextBlock>
                                        <Run Text="Code: "/>
                                        <Run Text="{Binding SelectedSample.Code}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,4,0,0">
                                        <Run Text="Beschreibung: "/>
                                        <Run Text="{Binding SelectedSample.Beschreibung}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,4,0,0">
                                        <Run Text="Meter: "/>
                                        <Run Text="{Binding SelectedSample.MeterStart, StringFormat=F2}"/>
                                        <Run Text=" – "/>
                                        <Run Text="{Binding SelectedSample.MeterEnd, StringFormat=F2}"/>
                                        <Run Text=" m"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">
                                        <Run Text="Frame: "/>
                                        <Run Text="{Binding SelectedSample.FramePath}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Image Grid.Row="2" MaxHeight="200" Margin="0,8,0,0"
                                       Stretch="Uniform" StretchDirection="DownOnly"
                                       Source="{Binding SelectedSample.FramePath, Converter={StaticResource FileToImage}}"/>
                                <StackPanel Grid.Row="5" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="Approve" Command="{Binding ApproveSampleCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Reject" Command="{Binding RejectSampleCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Neu laden" Command="{Binding LoadSamplesCommand}" Margin="0,0,8,0"/>
                        <Button Content="YOLO Export..."
                                Command="{Binding ExportYoloCommand}"
                                ToolTip="Exportiert Approved-Samples als YOLO-Trainingsdaten (images + labels + data.yaml). Nutzt Sidecar wenn verfügbar, sonst lokaler Export."
                                FontWeight="SemiBold" Margin="0,0,8,0"/>
                        <Button Content="Protokoll-Training"
                                Command="{Binding ExportApprovedCommand}"
                                ToolTip="Speichert Approved-Samples als Few-Shot-Beispiele für die Qwen-Protokollgenerierung (protocol_training.json)"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 3: Selbsttraining – Echtzeit-Visualisierungen -->
            <TabItem Header="Selbsttraining" x:Name="SelfTrainingTab">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Start/Stop Buttons -->
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>  <!-- Pipeline-Leiste -->
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>  <!-- Service-Indikatoren -->
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*"/>     <!-- Hauptbereich: 3 Spalten -->
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>  <!-- Log (klappbar) -->
                    </Grid.RowDefinitions>

                    <!-- ═══ Row 0: Start/Stop/Pause Buttons ═══ -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <Button Content="▶ Selbsttraining starten"
                                Command="{Binding RunSelfTrainingCommand}"
                                Background="#059669" Foreground="White" FontWeight="SemiBold"
                                Padding="16,6" Margin="0,0,8,0" Cursor="Hand"/>
                        <CheckBox Content="Alle erneut durchlaufen"
                                 IsChecked="{Binding ForceRerunAll}"
                                 Foreground="White" FontSize="11"
                                 VerticalAlignment="Center" Margin="0,0,12,0"
                                 ToolTip="Bereits verarbeitete Haltungen nochmals analysieren (KI lernt mit mehr Wissen)"/>
                        <Button Content="⏸ Pause / Fortsetzen"
                                Command="{Binding PauseSelfTrainingCommand}"
                                IsEnabled="{Binding IsSelfTrainingRunning}"
                                Background="#D97706" Foreground="White" FontWeight="SemiBold"
                                Padding="16,6" Margin="0,0,8,0" Cursor="Hand"/>
                        <Button Content="⏹ Abbrechen"
                                Command="{Binding StopSelfTrainingCommand}"
                                IsEnabled="{Binding IsSelfTrainingRunning}"
                                Background="#DC2626" Foreground="White" FontWeight="SemiBold"
                                Padding="16,6" Cursor="Hand"/>
                    </StackPanel>

                    <!-- ═══ Row 2: Pipeline-Stage-Leiste ═══ -->
                    <Border Grid.Row="2" Background="#1E293B" CornerRadius="6" Padding="12,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- Stage 0: Timeline -->
                            <StackPanel Orientation="Horizontal" x:Name="Stage0">
                                <Ellipse Width="12" Height="12" x:Name="Dot0" Fill="#475569"/>
                                <TextBlock Text="OSD-Scan" Foreground="#94A3B8" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                            <TextBlock Text=" → " Foreground="#475569" VerticalAlignment="Center" FontSize="11"/>
                            <!-- Stage 1: Frame -->
                            <StackPanel Orientation="Horizontal" x:Name="Stage1">
                                <Ellipse Width="12" Height="12" x:Name="Dot1" Fill="#475569"/>
                                <TextBlock Text="Frame" Foreground="#94A3B8" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                            <TextBlock Text=" → " Foreground="#475569" VerticalAlignment="Center" FontSize="11"/>
                            <!-- Stage 2: KI -->
                            <StackPanel Orientation="Horizontal" x:Name="Stage2">
                                <Ellipse Width="12" Height="12" x:Name="Dot2" Fill="#475569"/>
                                <TextBlock Text="KI-Analyse" Foreground="#94A3B8" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                            <TextBlock Text=" → " Foreground="#475569" VerticalAlignment="Center" FontSize="11"/>
                            <!-- Stage 3: Vergleich -->
                            <StackPanel Orientation="Horizontal" x:Name="Stage3">
                                <Ellipse Width="12" Height="12" x:Name="Dot3" Fill="#475569"/>
                                <TextBlock Text="Vergleich" Foreground="#94A3B8" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                            <TextBlock Text=" → " Foreground="#475569" VerticalAlignment="Center" FontSize="11"/>
                            <!-- Stage 4: Technik -->
                            <StackPanel Orientation="Horizontal" x:Name="Stage4">
                                <Ellipse Width="12" Height="12" x:Name="Dot4" Fill="#475569"/>
                                <TextBlock Text="Technik" Foreground="#94A3B8" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                            <TextBlock Text=" → " Foreground="#475569" VerticalAlignment="Center" FontSize="11"/>
                            <!-- Stage 5: Fertig -->
                            <StackPanel Orientation="Horizontal" x:Name="Stage5">
                                <Ellipse Width="12" Height="12" x:Name="Dot5" Fill="#475569"/>
                                <TextBlock Text="Fertig" Foreground="#94A3B8" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Row 4: Service-Indikatoren + aktueller Eintrag ═══ -->
                    <Border Grid.Row="4" Background="#1E293B" CornerRadius="6" Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 5 Service-Dots -->
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Border Width="10" Height="10" CornerRadius="5" Background="#475569" x:Name="SvcOsd"
                                        ToolTip="OSD-Meter-Erkennung" Margin="0,0,6,0"/>
                                <Border Width="10" Height="10" CornerRadius="5" Background="#475569" x:Name="SvcFrame"
                                        ToolTip="Frame-Extraktion" Margin="0,0,6,0"/>
                                <Border Width="10" Height="10" CornerRadius="5" Background="#475569" x:Name="SvcQwen"
                                        ToolTip="Qwen VL KI-Analyse" Margin="0,0,6,0"/>
                                <Border Width="10" Height="10" CornerRadius="5" Background="#475569" x:Name="SvcCompare"
                                        ToolTip="Deterministischer Vergleich" Margin="0,0,6,0"/>
                                <Border Width="10" Height="10" CornerRadius="5" Background="#475569" x:Name="SvcTech"
                                        ToolTip="Technik-Bewertung" Margin="0,0,6,0"/>
                                <TextBlock Text="Services" Foreground="#64748B" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>

                            <!-- Aktives Modell -->
                            <Border Grid.Column="1" CornerRadius="4" Padding="8,2" Margin="12,0,0,0"
                                    IsEnabled="{Binding IsModelActive, Mode=OneWay}"
                                    x:Name="ActiveModelBorder" Background="#0F172A">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" x:Name="ModelPulse" Fill="#475569" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ActiveModelName, Mode=OneWay}" x:Name="ModelNameText"
                                               Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Aktueller Eintrag -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Foreground="#94A3B8" FontSize="12">
                                    <Run Text="Code: "/><Run Text="{Binding CurrentEntryCode, Mode=OneWay}" Foreground="#F1F5F9" FontWeight="Bold"/>
                                    <Run Text="  |  Meter: "/><Run Text="{Binding CurrentEntryMeter, Mode=OneWay, StringFormat=F1}" Foreground="#F1F5F9"/>
                                    <Run Text=" m"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Technik-Note -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <TextBlock Text="Technik: " Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentTechniqueGrade, Mode=OneWay}" Foreground="#FBBF24"
                                           FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ═══ Row 6: Hauptbereich – 3 Spalten ═══ -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>  <!-- Frame-Vorschau -->
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>    <!-- Vergleich + Match-Rate -->
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="280"/>  <!-- Ergebnis-Verlauf + Code-Verteilung -->
                        </Grid.ColumnDefinitions>

                        <!-- Spalte 1: Live-Frame -->
                        <Border Grid.Column="0" Background="#0F172A" CornerRadius="6" Padding="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Live-Frame" Foreground="#64748B" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <Border Grid.Row="1" Background="#1E293B" CornerRadius="4">
                                    <Image Stretch="Uniform" StretchDirection="DownOnly"
                                           Source="{Binding LiveFramePath, Mode=OneWay, Converter={StaticResource FileToImage}}" Margin="2"/>
                                </Border>
                                <TextBlock Grid.Row="2" Foreground="#64748B" FontSize="10" Margin="0,4,0,0"
                                           Text="{Binding CurrentComparisonText, Mode=OneWay}"/>
                            </Grid>
                        </Border>

                        <!-- Spalte 2: Vergleich + Match-Rate-Balken -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- Match-Rate Balken -->
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="*"/>     <!-- Log / Vergleich Details -->
                            </Grid.RowDefinitions>

                            <!-- Match-Rate-Balken (gestapelt) -->
                            <Border Grid.Row="0" Background="#0F172A" CornerRadius="6" Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="24"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Match-Rate" Foreground="#64748B" FontSize="10" FontWeight="SemiBold"/>
                                    <!-- Gestapelter Balken -->
                                    <Grid Grid.Row="2" x:Name="MatchRateBar">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0" x:Name="ExactCol"/>
                                            <ColumnDefinition Width="0" x:Name="PartialCol"/>
                                            <ColumnDefinition Width="0" x:Name="MismatchCol"/>
                                            <ColumnDefinition Width="0" x:Name="NoFindingsCol"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#4ADE80" CornerRadius="3,0,0,3"
                                                ToolTip="ExactMatch"/>
                                        <Border Grid.Column="1" Background="#FBBF24"
                                                ToolTip="PartialMatch"/>
                                        <Border Grid.Column="2" Background="#F87171"
                                                ToolTip="Mismatch"/>
                                        <Border Grid.Column="3" Background="#64748B" CornerRadius="0,3,3,0"
                                                ToolTip="NoFindings"/>
                                        <Border Grid.Column="4" Background="#1E293B" CornerRadius="0,3,3,0"/>
                                    </Grid>
                                    <!-- Legende -->
                                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                                        <Border Width="8" Height="8" Background="#4ADE80" CornerRadius="2" Margin="0,0,3,0"/>
                                        <TextBlock Text="{Binding ExactPercent, Mode=OneWay, StringFormat=P0}" Foreground="#94A3B8" FontSize="10" Margin="0,0,10,0"/>
                                        <Border Width="8" Height="8" Background="#FBBF24" CornerRadius="2" Margin="0,0,3,0"/>
                                        <TextBlock Text="{Binding PartialPercent, Mode=OneWay, StringFormat=P0}" Foreground="#94A3B8" FontSize="10" Margin="0,0,10,0"/>
                                        <Border Width="8" Height="8" Background="#F87171" CornerRadius="2" Margin="0,0,3,0"/>
                                        <TextBlock Text="{Binding MismatchPercent, Mode=OneWay, StringFormat=P0}" Foreground="#94A3B8" FontSize="10" Margin="0,0,10,0"/>
                                        <Border Width="8" Height="8" Background="#64748B" CornerRadius="2" Margin="0,0,3,0"/>
                                        <TextBlock Text="{Binding NoFindingsPercent, Mode=OneWay, StringFormat=P0}" Foreground="#94A3B8" FontSize="10"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Log / Batch-Import Bereich -->
                            <Border Grid.Row="2" Background="#0F172A" CornerRadius="6" Padding="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Live-Log" Foreground="#64748B" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox Grid.Row="1"
                                             Text="{Binding LogText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas" FontSize="11"
                                             TextWrapping="NoWrap" AcceptsReturn="True"
                                             Background="#0F172A" Foreground="#CBD5E1"
                                             BorderThickness="0" x:Name="LogTextBox"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Spalte 3: Ergebnis-Verlauf + Code-Verteilung -->
                        <Grid Grid.Column="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>    <!-- Ergebnis-Verlauf -->
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/> <!-- Code-Verteilung -->
                            </Grid.RowDefinitions>

                            <!-- Ergebnis-Verlauf (scrollbare Liste) -->
                            <Border Grid.Row="0" Background="#0F172A" CornerRadius="6" Padding="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Ergebnis-Verlauf" Foreground="#64748B" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ListBox Grid.Row="1" x:Name="ResultsListBox"
                                             ItemsSource="{Binding SelfTrainingResults}"
                                             Background="Transparent" BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="4,2" Margin="0,1" CornerRadius="3"
                                                        Background="#1E293B">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="24"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Index}" Foreground="#475569" FontSize="10" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding VsaCode}" Foreground="#F1F5F9"
                                                                   FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Meter, StringFormat=F1}" Foreground="#94A3B8"
                                                                   FontSize="10" VerticalAlignment="Center"/>
                                                        <!-- Farbiger Level-Indikator -->
                                                        <Border Grid.Column="3" HorizontalAlignment="Right" Padding="4,1" CornerRadius="3"
                                                                x:Name="LevelBorder">
                                                            <TextBlock Text="{Binding Level}" FontSize="9" Foreground="#0F172A" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="ExactMatch">
                                                        <Setter TargetName="LevelBorder" Property="Background" Value="#4ADE80"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="PartialMatch">
                                                        <Setter TargetName="LevelBorder" Property="Background" Value="#FBBF24"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Mismatch">
                                                        <Setter TargetName="LevelBorder" Property="Background" Value="#F87171"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="NoFindings">
                                                        <Setter TargetName="LevelBorder" Property="Background" Value="#64748B"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>

                            <!-- Code-Verteilung (Balken pro Code) -->
                            <Border Grid.Row="2" Background="#0F172A" CornerRadius="6" Padding="6"
                                    MaxHeight="200">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Code-Verteilung" Foreground="#64748B" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CodeDistribution}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="55"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="30"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Code}" Foreground="#E2E8F0" FontSize="10"
                                                               FontFamily="Consolas" VerticalAlignment="Center"/>
                                                    <!-- Gestapelter Mini-Balken -->
                                                    <Grid Grid.Column="1" Height="10" Margin="4,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="{Binding Exact, FallbackValue=0}"/>
                                                            <ColumnDefinition Width="{Binding Partial, FallbackValue=0}"/>
                                                            <ColumnDefinition Width="{Binding Mismatch, FallbackValue=0}"/>
                                                            <ColumnDefinition Width="{Binding NoFindings, FallbackValue=0}"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="#4ADE80" CornerRadius="2,0,0,2"/>
                                                        <Border Grid.Column="1" Background="#FBBF24"/>
                                                        <Border Grid.Column="2" Background="#F87171"/>
                                                        <Border Grid.Column="3" Background="#64748B" CornerRadius="0,2,2,0"/>
                                                    </Grid>
                                                    <TextBlock Grid.Column="2" Text="{Binding Total}" Foreground="#94A3B8"
                                                               FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ═══ Row 8: Klappbares Echtzeit-Log ═══ -->
                    <Expander Grid.Row="8" Header="Echtzeit-Log" IsExpanded="False"
                              Foreground="#94A3B8" FontSize="11">
                        <ListBox ItemsSource="{Binding SelfTrainingLogEntries}"
                                 x:Name="SelfTrainingLogList"
                                 MaxHeight="150" Background="#0F172A" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="10" Foreground="#94A3B8"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                    </Expander>
                </Grid>
            </TabItem>

            <!-- Tab 4: Review Queue (Self-Improving Loop) -->
            <TabItem Header="Review Queue">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Zur Prüfung:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ReviewQueueCount}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding ReviewStatusText}" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding ReviewQueue}"
                              SelectedItem="{Binding SelectedReviewItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserSortColumns="True"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Priorität" Binding="{Binding PriorityLabel}" Width="80"/>
                            <DataGridTextColumn Header="Befund" Binding="{Binding Label}" Width="*"/>
                            <DataGridTextColumn Header="Vorgeschlagen" Binding="{Binding SuggestedCode}" Width="100"/>
                            <DataGridTextColumn Header="Konfidenz" Binding="{Binding Confidence, StringFormat=P0}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Akzeptieren" x:Name="ReviewApproveBtn"
                                Click="ReviewApprove_Click"
                                Padding="12,4" Margin="0,0,8,0"
                                IsEnabled="{Binding SelectedReviewItem, Converter={StaticResource NotNullToBool}, FallbackValue=False}"/>
                        <Button Content="Ablehnen + Korrektur" x:Name="ReviewRejectBtn"
                                Click="ReviewReject_Click"
                                Padding="12,4"
                                IsEnabled="{Binding SelectedReviewItem, Converter={StaticResource NotNullToBool}, FallbackValue=False}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- KB Qualitaet Tab -->
            <TabItem Header="KB Qualit&#228;t">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">

                        <!-- Coverage-Analyse -->
                        <Border Background="#0F172A" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Coverage-Analyse" Foreground="#E2E8F0" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Foreground="#94A3B8" FontSize="11" Margin="0,4,0,0">
                                    <Run Text="Codes mit weniger als 3 KB-Samples: "/>
                                    <Run Text="{Binding KbCoverageGapsCount, Mode=OneWay}" Foreground="#FBBF24" FontWeight="Bold"/>
                                </TextBlock>
                                <TextBlock Text="{Binding KbCoverageGapsText, Mode=OneWay}"
                                           FontFamily="Consolas" FontSize="11" Foreground="#CBD5E1"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Genauigkeit pro Code -->
                        <Border Background="#0F172A" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Genauigkeit pro Code (Top 8)" Foreground="#E2E8F0" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Foreground="#64748B" FontSize="10" Margin="0,2,0,4"
                                           Text="F1 = Gesamtgenauigkeit, P = Precision, R = Recall"/>
                                <TextBlock Text="{Binding KbAccuracyText, Mode=OneWay}"
                                           FontFamily="Consolas" FontSize="11" Foreground="#CBD5E1"
                                           TextWrapping="NoWrap" Margin="0,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Problematische KB-Samples -->
                        <Border Background="#0F172A" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Problematische KB-Samples: " Foreground="#E2E8F0" FontSize="13"/>
                                <TextBlock Text="{Binding KbStaleSampleCount, Mode=OneWay}"
                                           Foreground="#F87171" FontWeight="Bold" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- Match-Rate Trend -->
                        <Border Background="#0F172A" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Match-Rate Trend (letzte Laeufe)" Foreground="#E2E8F0" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding KbTrendDirection, Mode=OneWay}"
                                               Foreground="#4ADE80" FontSize="16" FontWeight="Bold" Margin="8,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding KbTrendText, Mode=OneWay}"
                                           FontFamily="Consolas" FontSize="11" Foreground="#CBD5E1"
                                           TextWrapping="NoWrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════ Tab 6: Lehrer-Annotationen ═══════ -->
            <TabItem Header="Lehrer" x:Name="TeacherTab">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <!-- Filter-Leiste -->
                    <Border Grid.Row="0" Padding="8" CornerRadius="4" Margin="0,0,0,8"
                            Background="{DynamicResource HeaderBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <DockPanel>
                            <TextBlock Text="VSA-Filter:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="TeacherFilterCombo" Width="120"
                                      SelectionChanged="TeacherFilter_Changed" Margin="0,0,16,0">
                                <ComboBoxItem Content="Alle" IsSelected="True"/>
                            </ComboBox>
                            <TextBlock x:Name="TeacherCountText" VerticalAlignment="Center"
                                       FontWeight="SemiBold" Foreground="#64748B"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <Button x:Name="BtnTeacherRefresh" Content="🔄 Aktualisieren"
                                        Click="TeacherRefresh_Click" Margin="0,0,8,0"
                                        Padding="8,4" FontSize="12"/>
                                <Button x:Name="BtnTeacherAddFewShot" Content="📚 → FewShot"
                                        Click="TeacherAddToFewShot_Click" Margin="0,0,8,0"
                                        Padding="8,4" FontSize="12" IsEnabled="False"/>
                                <Button x:Name="BtnTeacherDelete" Content="🗑 Loeschen"
                                        Click="TeacherDelete_Click"
                                        Padding="8,4" FontSize="12" IsEnabled="False"
                                        Foreground="#EF4444"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Thumbnail-Galerie -->
                    <Border Grid.Row="1" CornerRadius="4"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="TeacherGallery">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="ThumbBorder" Margin="4" Padding="4" CornerRadius="4"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                Background="{DynamicResource HeaderBrush}"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="TeacherThumb_Click"
                                                Width="140">
                                            <StackPanel>
                                                <Image Source="{Binding CroppedRegionPath, Converter={StaticResource FileToImage}}"
                                                       Width="120" Height="90" Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="{Binding VsaCode}" FontWeight="Bold"
                                                           FontSize="13" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                <TextBlock FontSize="11" Foreground="#64748B"
                                                           HorizontalAlignment="Center">
                                                    <Run Text="{Binding MeterPosition, StringFormat={}{0:F1}m}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                                  Background="Transparent" Margin="0,2"/>

                    <!-- Detail-Ansicht -->
                    <Border Grid.Row="3" CornerRadius="4" Padding="8"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <Grid x:Name="TeacherDetailPanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Volles Frame -->
                            <Image x:Name="TeacherDetailImage" Grid.Column="0"
                                   Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                                   Margin="0,0,8,0"/>

                            <!-- Metadaten -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="TeacherDetailCode" FontSize="18" FontWeight="Bold"/>
                                <TextBlock x:Name="TeacherDetailBeschreibung" FontSize="12"
                                           Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,4,0,8"/>
                                <TextBlock x:Name="TeacherDetailMeter" FontSize="13"/>
                                <TextBlock x:Name="TeacherDetailClock" FontSize="13"/>
                                <TextBlock x:Name="TeacherDetailTool" FontSize="13"/>
                                <TextBlock x:Name="TeacherDetailDate" FontSize="12"
                                           Foreground="#64748B" Margin="0,4,0,0"/>
                                <TextBlock x:Name="TeacherDetailId" FontSize="11"
                                           Foreground="#475569" FontFamily="Consolas" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Progress Bar (sichtbar wenn Busy) -->
        <Grid Grid.Row="3" Margin="0,8,0,0"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <ProgressBar Height="20" Minimum="0"
                         Maximum="{Binding ProgressMax}"
                         Value="{Binding ProgressValue}"/>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="11">
                <Run Text="{Binding ProgressValue, Mode=OneWay}"/>
                <Run Text="/"/>
                <Run Text="{Binding ProgressMax, Mode=OneWay}"/>
            </TextBlock>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="4" Padding="8" CornerRadius="6" Margin="0,4,0,0"
                Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}" DockPanel.Dock="Left" TextWrapping="Wrap"/>
                <TextBlock Text="Busy..." DockPanel.Dock="Right"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
