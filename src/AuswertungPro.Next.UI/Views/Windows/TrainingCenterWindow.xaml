<Window x:Class="AuswertungPro.Next.UI.Views.Windows.TrainingCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AuswertungPro.Next.UI.Views.Windows"
        xmlns:ctrl="clr-namespace:AuswertungPro.Next.UI.Controls"
        Title="Training Center" Height="800" Width="1200"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NotNullToBoolConverter x:Key="NotNullToBool"/>
        <local:InverseBoolConverter x:Key="InverseBool"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Padding="10" CornerRadius="6"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="1" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ordner:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding RootFolder}" IsReadOnly="True"
                         ToolTip="{Binding RootFolder}" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Ordner wählen..."
                        Command="{Binding BrowseRootFolderCommand}"
                        ToolTip="Wählen Sie einen oder mehrere Ordner mit Inspektionsdaten aus. Jeder Ordner sollte ein Video (.mp4) und ein Protokoll (.pdf/.json) enthalten. Sie können mehrfach klicken um weitere Ordner hinzuzufügen."
                        Margin="0,0,4,0"/>
                <Button Grid.Column="3" Content="X"
                        Command="{Binding ClearRootFoldersCommand}"
                        ToolTip="Setzt die Ordnerauswahl zurück und entfernt alle bisher gewählten Ordner aus der Liste."
                        Padding="6,2" Margin="0,0,8,0"/>
                <Button Grid.Column="4" Content="Scannen" Command="{Binding ScanCommand}" Margin="0,0,8,0"
                        ToolTip="Durchsucht alle gewählten Ordner nach Video- und Protokolldateien. Zeigt auf dem Fälle-Tab an, welche Haltungen gefunden wurden und ob Video/Protokoll vorhanden ist. Es werden noch keine Samples erzeugt."/>
                <Button Grid.Column="5" Content="Speichern" Command="{Binding SaveCommand}" Margin="0,0,8,0"
                        ToolTip="Speichert alle aktuellen Trainings-Samples (inkl. Approve/Reject-Status) dauerhaft auf die Festplatte. Wichtig nach manuellem Approve/Reject von Samples."/>
                <Button Grid.Column="6" Content="Abbrechen" Command="{Binding CancelBatchCommand}"
                        ToolTip="Bricht den aktuell laufenden Vorgang sofort ab. Bereits erzeugte Samples bleiben erhalten."
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

        <!-- Row 1: Trainingsstand (vereinfacht) -->
        <Border Grid.Row="1" Background="#1E293B" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="#94A3B8" Text="Samples: "/>
                <TextBlock Foreground="#E2E8F0" Text="{Binding SampleCountDisplay}" FontWeight="Bold"/>
                <TextBlock Foreground="#94A3B8" Text="  |  PDF-basiertes Training" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tab Content -->
        <TabControl Grid.Row="2">

            <!-- Tab 1: Fälle -->
            <TabItem Header="Fälle">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid Grid.Column="0"
                              ItemsSource="{Binding Cases}"
                              SelectedItem="{Binding SelectedCase, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CaseId" Binding="{Binding CaseId}" Width="1.5*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.6*"/>
                            <DataGridTextColumn Header="Protokoll (PDF)" Binding="{Binding ProtocolPath}" Width="3*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="1" Margin="12,0,0,0" Padding="10" CornerRadius="6"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Ausgewählter Fall" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Grid.Row="1" Text="{Binding SelectedCase.CaseId}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Text="{Binding SelectedCase.FolderPath}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="3" Text="{Binding SelectedCase.ProtocolPath}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <StackPanel Grid.Row="5" Orientation="Vertical" Margin="0,12,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                    <Button Content="Approve" Command="{Binding ApproveCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Reject" Command="{Binding RejectCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Set New" Command="{Binding SetNewCommand}"/>
                                </StackPanel>
                                <Button Content="Samples generieren..."
                                        Command="{Binding GenerateSamplesCommand}"
                                        HorizontalAlignment="Stretch"
                                        Padding="8,6"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: Samples -->
            <TabItem Header="Samples">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0"
                                  ItemsSource="{Binding Samples}"
                                  SelectedItem="{Binding SelectedSample, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="0.6*"/>
                                <DataGridTextColumn Header="m Start" Binding="{Binding MeterStart, StringFormat=F2}" Width="0.5*"/>
                                <DataGridTextColumn Header="m End" Binding="{Binding MeterEnd, StringFormat=F2}" Width="0.5*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.6*"/>
                                <DataGridCheckBoxColumn Header="OSD ?" Binding="{Binding HasOsdMismatch}" Width="0.4*"/>
                                <DataGridTextColumn Header="Exportiert" Binding="{Binding ExportedUtc, StringFormat=g}" Width="0.8*"/>
                                <DataGridTextColumn Header="Fall" Binding="{Binding CaseId}" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Sample-Vorschau -->
                        <Border Grid.Column="1" Margin="12,0,0,0" Padding="10" CornerRadius="6"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Sample-Details" FontWeight="SemiBold" FontSize="14"/>
                                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                    <TextBlock>
                                        <Run Text="Code: "/>
                                        <Run Text="{Binding SelectedSample.Code}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,4,0,0">
                                        <Run Text="Beschreibung: "/>
                                        <Run Text="{Binding SelectedSample.Beschreibung}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,4,0,0">
                                        <Run Text="Meter: "/>
                                        <Run Text="{Binding SelectedSample.MeterStart, StringFormat=F2}"/>
                                        <Run Text=" – "/>
                                        <Run Text="{Binding SelectedSample.MeterEnd, StringFormat=F2}"/>
                                        <Run Text=" m"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">
                                        <Run Text="Frame: "/>
                                        <Run Text="{Binding SelectedSample.FramePath}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Image Grid.Row="2" MaxHeight="200" Margin="0,8,0,0"
                                       Stretch="Uniform" StretchDirection="DownOnly"
                                       Source="{Binding SelectedSample.FramePath}"/>
                                <StackPanel Grid.Row="5" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="Approve" Command="{Binding ApproveSampleCommand}" Margin="0,0,8,0"
                                            ToolTip="Markiert dieses Sample als korrekt. Nur 'Approved' Samples werden in die Wissensdatenbank aufgenommen und als Lernbeispiele für die KI verwendet. Geprüfte Samples verbessern die Qualität der automatischen Schadenserkennung."/>
                                    <Button Content="Reject" Command="{Binding RejectSampleCommand}"
                                            ToolTip="Markiert dieses Sample als fehlerhaft oder unbrauchbar. Abgelehnte Samples werden nicht für das Training verwendet und beeinflussen die KI-Auswertung nicht. Verwenden Sie dies bei falsch erkannten Codes oder schlechten Video-Frames."/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Pipe Graph Timeline fuer Samples -->
                    <ctrl:PipeGraphTimeline Grid.Row="1" x:Name="SampleTimeline" Margin="0,8,0,0"
                                            TotalLength="{Binding SamplesMaxMeter}"
                                            CurrentMeter="{Binding SelectedSampleMeter}"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Neu laden" Command="{Binding LoadSamplesCommand}" Margin="0,0,8,0"
                                ToolTip="Lädt alle gespeicherten Trainings-Samples erneut von der Festplatte in die Tabelle. Nützlich wenn Samples extern geändert wurden oder die Anzeige nicht aktuell ist."/>
                        <Button Content="Protokoll-Training"
                                Command="{Binding ExportApprovedCommand}"
                                ToolTip="Exportiert alle als 'Approved' markierten Samples als Few-Shot-Lernbeispiele für die Qwen-Protokollgenerierung. Diese Beispiele werden gespeichert und bei zukünftigen KI-Protokollvorschlägen als Referenz mitgegeben, um die Codeauswahl zu verbessern."/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab: Selbsttraining (autonomes KI-Training) -->
            <TabItem x:Name="SelfTrainingTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse x:Name="SelfTrainPulseRing" Width="10" Height="10"
                                     Stroke="#F59E0B" StrokeThickness="2" Fill="Transparent"
                                     Opacity="0" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="SelfTrainDot" Width="10" Height="10" Fill="#94A3B8"/>
                        </Grid>
                        <TextBlock Text="Selbsttraining"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Steuerleiste -->
                    <Border Grid.Row="0" Background="#1E293B" CornerRadius="6" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Fälle:" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ListBox x:Name="SelfTrainCaseList" Width="360" Height="60"
                                     ItemsSource="{Binding SelfTrainingCases}"
                                     DisplayMemberPath="CaseId"
                                     SelectionMode="Extended"
                                     SelectionChanged="SelfTrainCaseList_SelectionChanged"
                                     Background="#0F172A" Foreground="#E2E8F0"
                                     BorderBrush="#334155" BorderThickness="1"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Margin="0,0,8,0"/>
                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,16,0">
                                <Button Content="Alle" Click="SelfTrainSelectAll_Click"
                                        Padding="8,2" FontSize="11" Margin="0,0,0,2"/>
                                <Button Content="Keine" Click="SelfTrainSelectNone_Click"
                                        Padding="8,2" FontSize="11"/>
                            </StackPanel>
                            <Button Content="&#x1F4DA; Bibliothek" Command="{Binding BuildFewShotLibraryCommand}"
                                    IsEnabled="{Binding IsBuildingFewShot, Converter={StaticResource InverseBool}}"
                                    ToolTip="Few-Shot Beispiel-Bibliothek aus PDFs aufbauen (verbessert KI-Erkennung)"
                                    Padding="12,4" Margin="0,0,4,0"/>
                            <Button Content="&#x25B6; Start" Command="{Binding StartSelfTrainingCommand}"
                                    IsEnabled="{Binding IsSelfTrainingRunning, Converter={StaticResource InverseBool}}"
                                    FontWeight="SemiBold" Padding="12,4" Margin="0,0,4,0"/>
                            <Button Content="&#x23F8; Pause" Command="{Binding PauseSelfTrainingCommand}"
                                    Visibility="{Binding IsSelfTrainingRunning, Converter={StaticResource BoolToVis}}"
                                    Padding="12,4" Margin="0,0,4,0"/>
                            <Button Content="&#x23F9; Stop" Command="{Binding StopSelfTrainingCommand}"
                                    Visibility="{Binding IsSelfTrainingRunning, Converter={StaticResource BoolToVis}}"
                                    Padding="12,4"/>
                            <TextBlock Text="{Binding FewShotStatus}" Foreground="#22C55E"
                                       FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"
                                       TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                            <TextBlock Text="{Binding SelfTrainingStageName}" Foreground="#F59E0B"
                                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Hauptbereich: Frame + Vergleich -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Frame-Vorschau mit Scan-Overlay -->
                        <Border Grid.Column="0" Background="#0F172A" CornerRadius="6">
                            <Grid>
                                <Image x:Name="SelfTrainFrame" Stretch="Uniform" StretchDirection="DownOnly"
                                       Source="{Binding SelfTrainingFramePath, TargetNullValue={x:Null}}"
                                       Margin="4"/>
                                <!-- Scan-Overlay -->
                                <Border x:Name="SelfTrainScanOverlay" Visibility="Collapsed"
                                        BorderBrush="#F59E0B" BorderThickness="2" CornerRadius="4"
                                        IsHitTestVisible="False" Opacity="0.6">
                                    <Grid>
                                        <Border x:Name="SelfTrainScanLine" Height="2" Background="#F59E0B"
                                                VerticalAlignment="Top" Opacity="0.8"/>
                                        <Border Background="#111827" CornerRadius="3" Padding="6,3"
                                                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0">
                                            <TextBlock x:Name="SelfTrainScanLabel" Text="KI scannt..."
                                                       Foreground="#F59E0B" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <!-- Flash-Overlay -->
                                <Border x:Name="SelfTrainFlashOverlay" Opacity="0" IsHitTestVisible="False"
                                        CornerRadius="6"/>
                            </Grid>
                        </Border>

                        <!-- Vergleich + Technik Details -->
                        <Border Grid.Column="2" Background="#1E293B" CornerRadius="6" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="VERGLEICH" FontWeight="Bold" FontSize="14" Foreground="#E2E8F0"/>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Foreground="#94A3B8">
                                        <Run Text="Protokoll: " FontWeight="SemiBold"/>
                                        <Run Text="{Binding SelfTrainingCurrentCode, Mode=OneWay}"/>
                                        <Run Text=" @ "/>
                                        <Run Text="{Binding SelfTrainingCurrentMeter, StringFormat=F1, Mode=OneWay}"/>
                                        <Run Text="m"/>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Row="3" Text="{Binding SelfTrainingComparisonText}"
                                           Foreground="#E2E8F0" TextWrapping="Wrap" Margin="0,8,0,0"
                                           FontFamily="Consolas" FontSize="12"/>

                                <TextBlock Grid.Row="5" Text="AUFNAHMETECHNIK" FontWeight="Bold" FontSize="14"
                                           Foreground="#E2E8F0"/>
                                <TextBlock Grid.Row="6" Text="{Binding SelfTrainingTechniqueText}"
                                           Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,8,0,0"
                                           FontFamily="Consolas" FontSize="12"/>

                                <!-- Zaehler -->
                                <Border Grid.Row="8" Background="#0F172A" CornerRadius="4" Padding="8,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Foreground="#4ADE80" Margin="0,0,12,0">
                                            <Run Text="Treffer: "/><Run Text="{Binding SelfTrainingExactCount, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#FACC15" Margin="0,0,12,0">
                                            <Run Text="Teil: "/><Run Text="{Binding SelfTrainingPartialCount, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#F87171" Margin="0,0,12,0">
                                            <Run Text="Abw: "/><Run Text="{Binding SelfTrainingMismatchCount, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#64748B">
                                            <Run Text="Leer: "/><Run Text="{Binding SelfTrainingNoFindingsCount, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Progress -->
                    <Grid Grid.Row="4" Visibility="{Binding IsSelfTrainingRunning, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- Fall-Fortschritt -->
                        <TextBlock Grid.Row="0" FontSize="11" Foreground="#F59E0B" Margin="0,0,0,2">
                            <Run Text="Fall "/>
                            <Run Text="{Binding SelfTrainingCaseIndex, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding SelfTrainingCaseTotal, Mode=OneWay}"/>
                        </TextBlock>
                        <Grid Grid.Row="1">
                            <ProgressBar Height="18" Minimum="0"
                                         Maximum="{Binding SelfTrainingTotal}"
                                         Value="{Binding SelfTrainingProgress}"
                                         Foreground="#F59E0B"/>
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="White">
                                <Run Text="{Binding SelfTrainingProgress, Mode=OneWay}"/>
                                <Run Text="/"/>
                                <Run Text="{Binding SelfTrainingTotal, Mode=OneWay}"/>
                                <Run Text=" Einträge"/>
                            </TextBlock>
                        </Grid>
                    </Grid>

                    <!-- Status -->
                    <TextBlock Grid.Row="5" Text="{Binding SelfTrainingStatus}"
                               Foreground="#94A3B8" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Progress Bar (sichtbar wenn Busy) -->
        <Grid Grid.Row="3" Margin="0,8,0,0"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <ProgressBar Height="20" Minimum="0"
                         Maximum="{Binding ProgressMax}"
                         Value="{Binding ProgressValue}"/>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="11">
                <Run Text="{Binding ProgressValue, Mode=OneWay}"/>
                <Run Text="/"/>
                <Run Text="{Binding ProgressMax, Mode=OneWay}"/>
            </TextBlock>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="4" Padding="8" CornerRadius="6" Margin="0,4,0,0"
                Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}" DockPanel.Dock="Left" TextWrapping="Wrap"/>
                <TextBlock Text="Busy..." DockPanel.Dock="Right"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
