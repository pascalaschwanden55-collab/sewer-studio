<Window x:Class="AuswertungPro.Next.UI.Views.Windows.TrainingCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AuswertungPro.Next.UI.Views.Windows"
        Title="Training Center" Height="800" Width="1200"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NotNullToBoolConverter x:Key="NotNullToBool"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Padding="10" CornerRadius="6"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="1" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ordner:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding RootFolder}" IsReadOnly="True"
                         ToolTip="{Binding RootFolder}" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Ordner wählen..."
                        Command="{Binding BrowseRootFolderCommand}"
                        ToolTip="Mehrere Ordner auswählen (werden kumuliert)" Margin="0,0,4,0"/>
                <Button Grid.Column="3" Content="X"
                        Command="{Binding ClearRootFoldersCommand}"
                        ToolTip="Ordnerauswahl zurücksetzen"
                        Padding="6,2" Margin="0,0,8,0"/>
                <Button Grid.Column="4" Content="Scannen" Command="{Binding ScanCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="5" Content="Speichern" Command="{Binding SaveCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="6" Content="&#x25B6; Batch-Import + KB" Command="{Binding BatchImportAndIndexCommand}"
                        ToolTip="Alle Ordner scannen, Samples generieren, auto-approve, Knowledge Base indizieren"
                        FontWeight="SemiBold" Margin="0,0,8,0"/>
                <Button Grid.Column="7" Content="KB prüfen" Command="{Binding CheckKnowledgeBaseCommand}"
                        ToolTip="Liest Samples, Embeddings, Versionen und Top-Codes aus der Knowledge Base"
                        Margin="0,0,8,0"/>
                <Button Grid.Column="8" Content="Abbrechen" Command="{Binding CancelBatchCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

        <!-- Row 1: Trainingsstand -->
        <Border Grid.Row="1" Background="#1E293B" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Ampel-Kreis + Label -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                    <Border Width="14" Height="14" CornerRadius="7"
                            VerticalAlignment="Center" Margin="0,0,8,0"
                            Background="{Binding KbReadinessBrush}"/>
                    <TextBlock Text="{Binding KbReadinessLabel}" Foreground="#E2E8F0" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Zaehler -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Foreground="#94A3B8" Text="Samples: "/>
                    <TextBlock Foreground="#E2E8F0" Text="{Binding KbSampleCount}" FontWeight="Bold"/>
                    <TextBlock Foreground="#94A3B8" Text="  |  Codes: "/>
                    <TextBlock Foreground="#E2E8F0" Text="{Binding KbCodesCovered}" FontWeight="Bold"/>
                </StackPanel>

                <!-- Top-Codes Tooltip -->
                <TextBlock Grid.Column="2" Text="Code-Verteilung" Foreground="#64748B" Cursor="Help">
                    <TextBlock.ToolTip>
                        <TextBlock Text="{Binding KbTopCodesText}" FontFamily="Consolas"/>
                    </TextBlock.ToolTip>
                </TextBlock>

                <!-- Letztes Update -->
                <TextBlock Grid.Column="4" Foreground="#64748B">
                    <Run Text="Letzte KB-Aktualisierung: "/>
                    <Run Text="{Binding KbLastUpdate, Mode=OneWay}" Foreground="#94A3B8"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Tab Content -->
        <TabControl Grid.Row="2">

            <!-- Tab 1: Fälle -->
            <TabItem Header="Fälle">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid Grid.Column="0"
                              ItemsSource="{Binding Cases}"
                              SelectedItem="{Binding SelectedCase, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CaseId" Binding="{Binding CaseId}" Width="1.2*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.6*"/>
                            <DataGridTextColumn Header="Video" Binding="{Binding VideoPath}" Width="2*"/>
                            <DataGridTextColumn Header="Protokoll" Binding="{Binding ProtocolPath}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="1" Margin="12,0,0,0" Padding="10" CornerRadius="6"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Ausgewählter Fall" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Grid.Row="1" Text="{Binding SelectedCase.CaseId}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Text="{Binding SelectedCase.FolderPath}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="3" Text="{Binding SelectedCase.VideoPath}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="4" Text="{Binding SelectedCase.ProtocolPath}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <StackPanel Grid.Row="5" Orientation="Vertical" Margin="0,12,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                    <Button Content="Approve" Command="{Binding ApproveCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Reject" Command="{Binding RejectCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Set New" Command="{Binding SetNewCommand}"/>
                                </StackPanel>
                                <Button Content="Samples generieren..."
                                        Command="{Binding GenerateSamplesCommand}"
                                        HorizontalAlignment="Stretch"
                                        Padding="8,6"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: Samples -->
            <TabItem Header="Samples">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0"
                                  ItemsSource="{Binding Samples}"
                                  SelectedItem="{Binding SelectedSample, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="0.6*"/>
                                <DataGridTextColumn Header="m Start" Binding="{Binding MeterStart, StringFormat=F2}" Width="0.5*"/>
                                <DataGridTextColumn Header="m End" Binding="{Binding MeterEnd, StringFormat=F2}" Width="0.5*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.6*"/>
                                <DataGridCheckBoxColumn Header="OSD ?" Binding="{Binding HasOsdMismatch}" Width="0.4*"/>
                                <DataGridTextColumn Header="Exportiert" Binding="{Binding ExportedUtc, StringFormat=g}" Width="0.8*"/>
                                <DataGridTextColumn Header="Fall" Binding="{Binding CaseId}" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Sample-Vorschau -->
                        <Border Grid.Column="1" Margin="12,0,0,0" Padding="10" CornerRadius="6"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Sample-Details" FontWeight="SemiBold" FontSize="14"/>
                                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                    <TextBlock>
                                        <Run Text="Code: "/>
                                        <Run Text="{Binding SelectedSample.Code}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,4,0,0">
                                        <Run Text="Beschreibung: "/>
                                        <Run Text="{Binding SelectedSample.Beschreibung}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,4,0,0">
                                        <Run Text="Meter: "/>
                                        <Run Text="{Binding SelectedSample.MeterStart, StringFormat=F2}"/>
                                        <Run Text=" – "/>
                                        <Run Text="{Binding SelectedSample.MeterEnd, StringFormat=F2}"/>
                                        <Run Text=" m"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">
                                        <Run Text="Frame: "/>
                                        <Run Text="{Binding SelectedSample.FramePath}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Image Grid.Row="2" MaxHeight="200" Margin="0,8,0,0"
                                       Stretch="Uniform" StretchDirection="DownOnly"
                                       Source="{Binding SelectedSample.FramePath}"/>
                                <StackPanel Grid.Row="5" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="Approve" Command="{Binding ApproveSampleCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Reject" Command="{Binding RejectSampleCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Neu laden" Command="{Binding LoadSamplesCommand}" Margin="0,0,8,0"/>
                        <Button Content="YOLO Export..."
                                Command="{Binding ExportYoloCommand}"
                                ToolTip="Exportiert Approved-Samples als YOLO-Trainingsdaten (images + labels + data.yaml). Nutzt Sidecar wenn verfügbar, sonst lokaler Export."
                                FontWeight="SemiBold" Margin="0,0,8,0"/>
                        <Button Content="Protokoll-Training"
                                Command="{Binding ExportApprovedCommand}"
                                ToolTip="Speichert Approved-Samples als Few-Shot-Beispiele für die Qwen-Protokollgenerierung (protocol_training.json)"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 3: Log + Live-Vorschau -->
            <TabItem Header="Log / Live">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Log-TextBox -->
                    <TextBox Grid.Column="0"
                             Text="{Binding LogText, Mode=OneWay}"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             x:Name="LogTextBox"/>

                    <!-- Live-Vorschau -->
                    <Border Grid.Column="1" Margin="12,0,0,0" Padding="10" CornerRadius="6"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Live-Vorschau" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>

                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                <TextBlock>
                                    <Run Text="Fall: " FontWeight="SemiBold"/>
                                    <Run Text="{Binding LiveCaseInfo, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Margin="0,4,0,0">
                                    <Run Text="Code: " FontWeight="SemiBold"/>
                                    <Run Text="{Binding LiveCodeInfo, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Margin="0,4,0,0">
                                    <Run Text="Meter: " FontWeight="SemiBold"/>
                                    <Run Text="{Binding LiveMeterInfo, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Progress-Info -->
                            <TextBlock Grid.Row="2" Margin="0,6,0,0"
                                       FontSize="11" Foreground="Gray">
                                <Run Text="{Binding ProgressValue, Mode=OneWay}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding ProgressMax, Mode=OneWay}"/>
                                <Run Text=" Fälle verarbeitet"/>
                            </TextBlock>

                            <Border Grid.Row="3" Margin="0,8,0,0"
                                    Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                    CornerRadius="4">
                                <Image Stretch="Uniform" StretchDirection="DownOnly"
                                       Source="{Binding LiveFramePath, Mode=OneWay, TargetNullValue={x:Null}}"
                                       Margin="4"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Review Queue Tab (Self-Improving Loop) -->
            <TabItem Header="Review Queue">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Zur Prüfung:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ReviewQueueCount}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding ReviewStatusText}" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Queue List -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding ReviewQueue}"
                              SelectedItem="{Binding SelectedReviewItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserSortColumns="True"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Priorität" Binding="{Binding PriorityLabel}" Width="80"/>
                            <DataGridTextColumn Header="Befund" Binding="{Binding Label}" Width="*"/>
                            <DataGridTextColumn Header="Vorgeschlagen" Binding="{Binding SuggestedCode}" Width="100"/>
                            <DataGridTextColumn Header="Konfidenz" Binding="{Binding Confidence, StringFormat=P0}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Actions -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Akzeptieren" x:Name="ReviewApproveBtn"
                                Click="ReviewApprove_Click"
                                Padding="12,4" Margin="0,0,8,0"
                                IsEnabled="{Binding SelectedReviewItem, Converter={StaticResource NotNullToBool}, FallbackValue=False}"/>
                        <Button Content="Ablehnen + Korrektur" x:Name="ReviewRejectBtn"
                                Click="ReviewReject_Click"
                                Padding="12,4"
                                IsEnabled="{Binding SelectedReviewItem, Converter={StaticResource NotNullToBool}, FallbackValue=False}"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Progress Bar (sichtbar wenn Busy) -->
        <Grid Grid.Row="3" Margin="0,8,0,0"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <ProgressBar Height="20" Minimum="0"
                         Maximum="{Binding ProgressMax}"
                         Value="{Binding ProgressValue}"/>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="11">
                <Run Text="{Binding ProgressValue, Mode=OneWay}"/>
                <Run Text="/"/>
                <Run Text="{Binding ProgressMax, Mode=OneWay}"/>
            </TextBlock>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="4" Padding="8" CornerRadius="6" Margin="0,4,0,0"
                Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}" DockPanel.Dock="Left" TextWrapping="Wrap"/>
                <TextBlock Text="Busy..." DockPanel.Dock="Right"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
