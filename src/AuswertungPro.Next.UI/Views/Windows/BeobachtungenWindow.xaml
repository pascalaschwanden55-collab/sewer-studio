<Window x:Class="AuswertungPro.Next.UI.Views.Windows.BeobachtungenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:AuswertungPro.Next.UI.Views.Pages"
        Title="Beobachtungen"
        Width="1120"
        Height="460"
        MinWidth="760"
        MinHeight="260"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True">
    <Window.Resources>
        <pages:PathToFileNameConverter x:Key="PathToFileName"/>
        <pages:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyVisible"/>
        <pages:AnyValueToVisibilityConverter x:Key="AnyValueVisible"/>

        <SolidColorBrush x:Key="PanelBgBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7DEE8"/>
        <SolidColorBrush x:Key="HeaderBgBrush" Color="#EEF5FB"/>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource NeonCyanBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                Background="{StaticResource PanelBgBrush}"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,8">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="HeaderText"
                           Text="Beobachtungen"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Margin="0,0,12,0"
                           DockPanel.Dock="Left"/>

                <WrapPanel DockPanel.Dock="Right">
                    <Button x:Name="ProtocolButton" Content="Protokoll bearbeiten..." Style="{StaticResource ActionButtonStyle}"/>
                    <Button x:Name="VsaUpdateButton" Content="VSA Zustand aktualisieren" Style="{StaticResource ActionButtonStyle}"/>
                    <Button x:Name="SyncHoldingFieldsButton" Content="Haltungen-Feld aktualisieren" Style="{StaticResource ActionButtonStyle}" Margin="0"/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="White">
            <DataGrid x:Name="EntriesGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="All"
                      GridLinesVisibility="Horizontal"
                      VerticalGridLinesBrush="#E5EAF1"
                      HorizontalGridLinesBrush="#E5EAF1"
                      AlternationCount="2"
                      MinRowHeight="28">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Background" Value="{StaticResource HeaderBgBrush}"/>
                        <Setter Property="Foreground" Value="#1E293B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderBrush" Value="#D7DEE8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="6,4"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#FBFDFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="m+" Binding="{Binding MeterStart, StringFormat=F2}" Width="60"/>
                    <DataGridTextColumn Header="m-" Binding="{Binding MeterEnd, StringFormat=F2}" Width="60"/>
                    <DataGridTextColumn Header="OP Kuerzel" Binding="{Binding Code}" Width="80"/>
                    <DataGridTextColumn Header="Zustand" Binding="{Binding Beschreibung}" Width="*" MinWidth="180"/>
                    <DataGridTemplateColumn Header="Fotos" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding FotoPaths}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Converter={StaticResource PathToFileName}}"
                                                    Style="{StaticResource LinkButtonStyle}"
                                                    Margin="0,0,8,4"
                                                    Click="OpenPhotoLink_Click"
                                                    Tag="{Binding}"
                                                    ToolTip="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Film" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Video"
                                        Style="{StaticResource LinkButtonStyle}"
                                        Click="OpenFilmLink_Click"
                                        Tag="{Binding}"
                                        ToolTip="{Binding Mpeg}">
                                    <Button.Visibility>
                                        <MultiBinding Converter="{StaticResource AnyValueVisible}">
                                            <Binding Path="Mpeg"/>
                                            <Binding Path="Zeit"/>
                                        </MultiBinding>
                                    </Button.Visibility>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="MPEG" Binding="{Binding Mpeg}" Width="90"/>
                    <DataGridTextColumn Header="Zeit" Binding="{Binding Zeit, StringFormat={}{0:hh\\:mm\\:ss}}" Width="80"/>
                    <DataGridTextColumn Header="Anzahl" Binding="{Binding FotoPaths.Count}" Width="55"/>
                    <DataGridTextColumn Header="Bemerkung" Binding="{Binding CodeMeta.Notes}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
