<Window x:Class="AuswertungPro.Next.UI.Views.Windows.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SewerStudio"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Topmost="True"
        Opacity="0">
    <Grid Background="#0B1020">
        <!-- Centered animation content -->
        <Grid Width="900" Height="500" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border CornerRadius="18" Background="#0B1020">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#00E5FF" Opacity="0.25"/>
                </Border.Effect>
            </Border>

            <Canvas Opacity="0.12">
                <Rectangle Width="900" Height="500" Fill="#0B1020"/>
                <Path Stroke="#5AC8FF" StrokeThickness="1" Data="M0,60 H900 M0,120 H900 M0,180 H900 M0,240 H900 M0,300 H900 M0,360 H900 M0,420 H900"/>
                <Path Stroke="#5AC8FF" StrokeThickness="1" Data="M90,0 V500 M180,0 V500 M270,0 V500 M360,0 V500 M450,0 V500 M540,0 V500 M630,0 V500 M720,0 V500 M810,0 V500"/>
            </Canvas>

            <Grid>
                <Ellipse x:Name="GlowRing"
                         Width="260"
                         Height="260"
                         HorizontalAlignment="Left"
                         Margin="110,0,0,0"
                         Stroke="#00E5FF"
                         StrokeThickness="10"
                         Opacity="0.9">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="45" ShadowDepth="0" Color="#00E5FF" Opacity="0.9"/>
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="RingScale" ScaleX="0.2" ScaleY="0.2" CenterX="130" CenterY="130"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Canvas x:Name="DataCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Rectangle x:Name="B1" Width="14" Height="10" Fill="#FF3B5C" Opacity="0" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="B2" Width="10" Height="10" Fill="#FF3B5C" Opacity="0" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="B3" Width="18" Height="12" Fill="#FF3B5C" Opacity="0" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="B4" Width="12" Height="8" Fill="#FF3B5C" Opacity="0" RadiusX="2" RadiusY="2"/>
                </Canvas>

                <StackPanel HorizontalAlignment="Left" Margin="430,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               Text="SEWER STUDIO"
                               Foreground="White"
                               FontSize="54"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               Margin="0"
                               Opacity="0"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="TitleScale" ScaleX="1.12" ScaleY="1.12"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>

                    <TextBlock x:Name="SubText"
                               Text="AI-Powered Infrastructure Analytics"
                               Foreground="#C9D3E6"
                               FontSize="20"
                               Margin="0,10,0,0"
                               Opacity="0"/>

                    <TextBlock x:Name="StatusText"
                               Text="Initialisiere Anwendung..."
                               Foreground="#8EA1BF"
                               FontSize="13"
                               Margin="0,18,0,0"
                               Opacity="0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
