<Window x:Class="AuswertungPro.Next.UI.Views.Windows.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SewerStudio"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Topmost="True"
        Opacity="0">
    <Grid Background="#FF0A0E17">
        <!-- Vollbild dunkler Hintergrund mit subtiler Vignette -->
        <Border>
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Color="#FF0F1520" Offset="0"/>
                    <GradientStop Color="#FF060A10" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Zentraler Content-Bereich -->
        <Grid Width="1000" Height="560" HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- Aeusserer Rahmen mit Glow -->
            <Border CornerRadius="20" Background="#FF0D1117" BorderBrush="#1800D4FF" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="60" ShadowDepth="0" Color="#0088FF" Opacity="0.15"/>
                </Border.Effect>
            </Border>

            <!-- Neural Network Canvas — Pipeline-Stages: Input → YOLO → DINO → SAM → Qwen → Output -->
            <!-- Canvas wird im Code-Behind mit benannten Schichten + gestaffelter Datenfluss-Animation gefuellt -->
            <Canvas x:Name="NeuralCanvas" ClipToBounds="True" Margin="20"/>

            <!-- Ehem. Glow-Ring wurde entfernt — die Pipeline-Visualisierung
                 auf dem NeuralCanvas ist jetzt das zentrale KI-Symbol. -->

            <!-- Text rechts -->
            <StackPanel HorizontalAlignment="Left" Margin="440,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText"
                           Text="SEWER STUDIO"
                           Foreground="#FFFAFCFF"
                           FontSize="52"
                           FontWeight="Bold"
                           FontFamily="Consolas"
                           Opacity="0"
                           RenderTransformOrigin="0,0.5">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="TitleSlide" X="30"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock x:Name="SubText"
                           Text="Neural Sewer Inspection Engine"
                           FontSize="17"
                           Margin="2,6,0,0"
                           Opacity="0">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF0088CC" Offset="0"/>
                            <GradientStop Color="#FF00CCAA" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <!-- Versions-Info -->
                <TextBlock x:Name="VersionText"
                           Text="v4.2  ·  Qwen3-VL + YOLO26m + DINO 1.5 + SAM 2"
                           Foreground="#80FFFFFF"
                           FontSize="12"
                           FontFamily="Consolas"
                           Margin="2,4,0,0"
                           Opacity="0"/>

                <!-- Status mit Lade-Indikator -->
                <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="#0088FF" Margin="0,3,8,0" Opacity="0"/>
                    <TextBlock x:Name="StatusText"
                               Text="Initialisiere Anwendung..."
                               Foreground="#FF8B9BB5"
                               FontSize="13"
                               FontFamily="Segoe UI"
                               Opacity="0"/>
                </StackPanel>
            </StackPanel>

            <!-- Untere Fortschrittsleiste -->
            <Border Height="2" VerticalAlignment="Bottom" Margin="40,0,40,30"
                    CornerRadius="1" Background="#10FFFFFF">
                <Border x:Name="ProgressBar"
                        Height="2" HorizontalAlignment="Left" Width="0"
                        CornerRadius="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF0066CC" Offset="0"/>
                            <GradientStop Color="#FF00BBFF" Offset="0.5"/>
                            <GradientStop Color="#FF00CCAA" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Border>

        </Grid>
    </Grid>
</Window>
