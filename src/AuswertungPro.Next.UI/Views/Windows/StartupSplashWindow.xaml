<Window x:Class="AuswertungPro.Next.UI.Views.Windows.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SewerStudio"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Topmost="True"
        Opacity="0">
    <Grid Background="#FF080B12">
        <!-- Full-screen dark background with subtle vignette. -->
        <Border>
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Color="#FF101722" Offset="0"/>
                    <GradientStop Color="#FF05070B" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <Grid Width="1000" Height="560" HorizontalAlignment="Center" VerticalAlignment="Center">

            <Border CornerRadius="18" Background="#FF0B1018" BorderBrush="#243A465A" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="48" ShadowDepth="0" Color="#5C7EA0" Opacity="0.20"/>
                </Border.Effect>
            </Border>

            <Canvas x:Name="NeuralCanvas" ClipToBounds="True" Margin="20"/>

            <StackPanel HorizontalAlignment="Left" Margin="440,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText"
                           Text="SEWER STUDIO"
                           Foreground="#FFFAFCFF"
                           FontSize="50"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           Opacity="0"
                           RenderTransformOrigin="0,0.5">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="TitleSlide" X="30"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock x:Name="SubText"
                           Text="3D Neural Inspection Core"
                           FontSize="17"
                           Margin="2,6,0,0"
                           Foreground="#FF91A8BD"
                           Opacity="0"/>

                <TextBlock x:Name="VersionText"
                           Text="v4.3  |  Neural Network Core  |  VSA-KEK 2023  |  Local AI"
                           Foreground="#86C3D0DE"
                           FontSize="{StaticResource TypeSmall}"
                           FontFamily="Consolas"
                           Margin="2,4,0,0"
                           Opacity="0"/>

                <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="#FF7EA7C9" Margin="0,3,8,0" Opacity="0"/>
                    <TextBlock x:Name="StatusText"
                               Text="Initialisiere Anwendung..."
                               Foreground="#FF8B9BB5"
                               FontSize="{StaticResource TypeBody}"
                               FontFamily="Segoe UI"
                               Opacity="0"/>
                </StackPanel>
            </StackPanel>

            <Border Height="2" VerticalAlignment="Bottom" Margin="40,0,40,30"
                    CornerRadius="1" Background="#10FFFFFF">
                <Border x:Name="ProgressBar"
                        Height="2" HorizontalAlignment="Left" Width="0"
                        CornerRadius="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF5E7E9F" Offset="0"/>
                            <GradientStop Color="#FF7EA7C9" Offset="0.55"/>
                            <GradientStop Color="#FF8BC2B6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Border>

        </Grid>
    </Grid>
</Window>
