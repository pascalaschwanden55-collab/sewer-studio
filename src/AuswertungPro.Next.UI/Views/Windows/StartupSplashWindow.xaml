<Window x:Class="AuswertungPro.Next.UI.Views.Windows.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sewer Studio"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Topmost="True"
        Opacity="0">
    <Grid Background="#F2F5FA">
        <Grid Width="760"
              Height="360"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Border x:Name="Shell"
                    CornerRadius="10"
                    Background="#FCFDFF"
                    BorderBrush="#C4D0E0"
                    BorderThickness="1"
                    Opacity="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="8" Direction="270" Color="#6B7A90" Opacity="0.18"/>
                </Border.Effect>
            </Border>

            <Grid Margin="44">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="LogoMark"
                          Width="112"
                          Height="112"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="LogoScale" ScaleX="0.92" ScaleY="0.92"/>
                        </Grid.RenderTransform>

                        <Border CornerRadius="8"
                                Background="#E8F0FF"
                                BorderBrush="#2563EB"
                                BorderThickness="1"/>

                        <Canvas Width="82" Height="82" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Stroke="#0F172A"
                                  StrokeThickness="5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M8,54 C26,54 28,28 45,28 C58,28 62,45 74,45"/>
                            <Ellipse Canvas.Left="6" Canvas.Top="50" Width="10" Height="10" Fill="#2563EB"/>
                            <Ellipse Canvas.Left="40" Canvas.Top="23" Width="10" Height="10" Fill="#2563EB"/>
                            <Ellipse Canvas.Left="70" Canvas.Top="40" Width="10" Height="10" Fill="#2563EB"/>
                            <Rectangle Canvas.Left="10" Canvas.Top="66" Width="60" Height="4" RadiusX="2" RadiusY="2" Fill="#94A3B8"/>
                        </Canvas>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   Text="Sewer Studio"
                                   Foreground="#0A0F1A"
                                   FontSize="42"
                                   FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Opacity="0"/>

                        <TextBlock x:Name="SubText"
                                   Text="VSA-Auswertung, Medien und KI-Assistenz"
                                   Foreground="#334155"
                                   FontSize="17"
                                   Margin="0,8,0,0"
                                   Opacity="0"/>

                        <TextBlock x:Name="StatusText"
                                   Text="Starte Anwendung..."
                                   Foreground="#475569"
                                   FontSize="13"
                                   Margin="0,22,0,0"
                                   Opacity="0"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,28,0,0">
                    <Border Height="5"
                            CornerRadius="3"
                            Background="#E2E8F0"/>
                    <Border x:Name="ProgressFill"
                            Height="5"
                            Width="160"
                            HorizontalAlignment="Left"
                            CornerRadius="3"
                            Background="#2563EB"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="ProgressTranslate" X="-170"/>
                        </Border.RenderTransform>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
