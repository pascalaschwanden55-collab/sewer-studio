<Window x:Class="AuswertungPro.Next.UI.Views.Windows.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SewerStudio"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Topmost="True"
        Opacity="0">

    <Window.Resources>
        <Storyboard x:Key="StartAnimation">
            <!-- 1. Orange Header slide-in (0-1s) -->
            <DoubleAnimation Storyboard.TargetName="HeaderBorder"
                             Storyboard.TargetProperty="Height"
                             From="0" To="80" Duration="0:0:1" />

            <!-- 2. Logo-Text fade + scale (0.8s - 2.3s) -->
            <DoubleAnimation Storyboard.TargetName="LogoText"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" BeginTime="0:0:0.8" Duration="0:0:1.5" />
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.7" To="1" BeginTime="0:0:0.8" Duration="0:0:1.5" />
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.7" To="1" BeginTime="0:0:0.8" Duration="0:0:1.5" />

            <!-- 3. Subtitle fade-in (2s - 3.5s) -->
            <DoubleAnimation Storyboard.TargetName="SubtitleText"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" BeginTime="0:0:2" Duration="0:0:1.5" />

            <!-- 4. KI-Pipeline-Animation (2.5s - 5s) -->
            <DoubleAnimation Storyboard.TargetName="PipeProgress"
                             Storyboard.TargetProperty="Width"
                             From="0" To="420" BeginTime="0:0:2.5" Duration="0:0:2.5" />

            <!-- 5. Version-Tag fade-in (4s) -->
            <DoubleAnimation Storyboard.TargetName="VersionText"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" BeginTime="0:0:4" Duration="0:0:1" />
        </Storyboard>
    </Window.Resources>

    <Grid Background="#001F3F">
        <!-- Centered animation content -->
        <Grid Width="800" Height="500" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border CornerRadius="18" Background="#001F3F">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#FF9500" Opacity="0.15"/>
                </Border.Effect>
            </Border>

            <Grid>
                <!-- Orangener Header -->
                <Border x:Name="HeaderBorder" Height="0" VerticalAlignment="Top"
                        Background="#FF9500" CornerRadius="18,18,12,12">
                    <TextBlock Text="SewerStudio" FontSize="42" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Logo-Text (mit ScaleTransform) -->
                <TextBlock x:Name="LogoText"
                           Text="KI-gestützte Kanalinspektion"
                           FontSize="28" FontWeight="SemiBold" Foreground="#E0F0FF"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,80,0,0"
                           Opacity="0"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <ScaleTransform x:Name="LogoScale" />
                    </TextBlock.RenderTransform>
                </TextBlock>

                <!-- Subtitle -->
                <TextBlock x:Name="SubtitleText"
                           Text="Vollständige Projektdokumentation • Abwasser Uri"
                           FontSize="16" Foreground="#A0C0E0"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,160,0,0" Opacity="0" />

                <!-- Version -->
                <TextBlock x:Name="VersionText"
                           Text="Version 2026-03"
                           FontSize="14" Foreground="#FF9500"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Margin="0,0,0,40" Opacity="0" />

                <!-- KI-Pipeline Animation -->
                <Border Width="440" Height="12" Background="#334455"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,120"
                        CornerRadius="6">
                    <Border x:Name="PipeProgress"
                            Width="0" Height="12" Background="#FF9500"
                            HorizontalAlignment="Left" CornerRadius="6" />
                </Border>

                <!-- Kleiner Hinweis unten -->
                <TextBlock Text="Lokal • Datenschutzkonform • Open Source"
                           FontSize="11" Foreground="#6688AA"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
