<Window x:Class="AuswertungPro.Next.UI.Views.Windows.BenchmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AuswertungPro.Next.UI.ViewModels.Windows"
        Title="Benchmark — KI-Fortschrittsmessung"
        Width="1100" Height="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Zeile 0: Steuerung -->
        <Border Grid.Row="0" Background="{DynamicResource CardBrush}" CornerRadius="6"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Padding="12,8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="Benchmark starten" Command="{Binding RunBenchmarkCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                <Button Content="Abbrechen" Command="{Binding CancelBenchmarkCommand}"
                        Padding="12,6" Margin="0,0,16,0"/>
                <Button Content="Haltung hinzufuegen" Command="{Binding AddHaltungCommand}"
                        Background="{DynamicResource SuccessBrush}" Foreground="White"
                        Padding="12,6" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <Button Content="Haltung entfernen" Command="{Binding RemoveHaltungCommand}"
                        Style="{StaticResource ToolbarButtonDanger}" Padding="12,6"/>
            </StackPanel>
        </Border>

        <!-- Zeile 1: Benchmark-Set -->
        <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="6"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Padding="0" Margin="0,0,0,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}"
                        CornerRadius="6,6,0,0" Padding="12,6">
                    <TextBlock Text="Benchmark-Haltungen" FontWeight="SemiBold" FontSize="{StaticResource TypeBody}"
                               Foreground="{DynamicResource TextBrush}"/>
                </Border>

                <ListBox Grid.Row="1" ItemsSource="{Binding Haltungen}"
                         SelectedItem="{Binding SelectedHaltung}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource TextBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <TextBlock Text="{Binding HaltungId}" FontWeight="Bold" Width="200"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="{Binding Rohrmaterial}" Width="100"
                                           Foreground="{DynamicResource MutedBrush}"/>
                                <TextBlock Foreground="{DynamicResource MutedBrush}">
                                    <Run Text="DN"/><Run Text="{Binding NennweiteMm, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Zeile 2: Metriken-Zusammenfassung -->
        <Border Grid.Row="2" Background="{DynamicResource HeaderBrush}" CornerRadius="6"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Padding="12,8" Margin="0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock FontSize="15" Margin="0,0,24,0"
                               Foreground="{DynamicResource TextBrush}">
                        <Run Text="Precision: "/><Run Text="{Binding PrecisionText, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock FontSize="15" Margin="0,0,24,0"
                               Foreground="{DynamicResource TextBrush}">
                        <Run Text="Recall: "/><Run Text="{Binding RecallText, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock FontSize="{StaticResource TypeH3}" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}">
                        <Run Text="F1: "/><Run Text="{Binding F1Text, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Regressions-Alarm -->
                <Border Grid.Column="1" Background="{DynamicResource DangerBrush}"
                        CornerRadius="4" Padding="12,4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasRegression}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding RegressionText}" Foreground="White" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <!-- Zeile 3: Per-Code Metriken -->
        <Border Grid.Row="3" Background="{DynamicResource CardBrush}" CornerRadius="6"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Padding="0" Margin="0,4,0,0">
            <DataGrid ItemsSource="{Binding PerCodeMetrics}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      FontSize="{StaticResource TypeBody}">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="VSA-Code" Binding="{Binding VsaCodePrefix}" Width="100"/>
                    <DataGridTextColumn Header="TP" Binding="{Binding TP}" Width="60"/>
                    <DataGridTextColumn Header="FP" Binding="{Binding FP}" Width="60"/>
                    <DataGridTextColumn Header="FN" Binding="{Binding FN}" Width="60"/>
                    <DataGridTextColumn Header="Precision" Binding="{Binding Precision, StringFormat=P1}" Width="90"/>
                    <DataGridTextColumn Header="Recall" Binding="{Binding Recall, StringFormat=P1}" Width="90"/>
                    <DataGridTextColumn Header="F1" Binding="{Binding F1, StringFormat=P1}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Zeile 4: Status -->
        <Border Grid.Row="4" Background="{DynamicResource HeaderBrush}" CornerRadius="6"
                Padding="12,6" Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ProgressBar Grid.Column="0" Height="4"
                             Minimum="0" Maximum="{Binding ProgressMax}"
                             Value="{Binding ProgressValue}"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource BorderLightBrush}"/>

                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           Foreground="{DynamicResource MutedBrush}"
                           Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
