<Window x:Class="AuswertungPro.Next.UI.Views.Windows.VideoAnalysisPipelineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AuswertungPro.Next.UI.Views.Windows"
        Title="Sewer Studio — Pipeline Analysis" Height="860" Width="1320"
        WindowStartupLocation="CenterOwner"
        WindowState="Normal"
        Background="#0C1019"
        ResizeMode="CanResize"
        MinWidth="900" MinHeight="600">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Sci-Fi Engineering Dark — Blue-steel palette -->
        <SolidColorBrush x:Key="BgMain"       Color="#0C1019"/>
        <SolidColorBrush x:Key="BgCard"       Color="#131825"/>
        <SolidColorBrush x:Key="BgCardHover"  Color="#1A2030"/>
        <SolidColorBrush x:Key="Border1"      Color="#243049"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#F0F4FA"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#7B8DA6"/>
        <SolidColorBrush x:Key="TextSub"      Color="#94A3B8"/>
        <SolidColorBrush x:Key="Accent"       Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentLight"  Color="#60A5FA"/>
        <SolidColorBrush x:Key="Green"        Color="#16A34A"/>
        <SolidColorBrush x:Key="Amber"        Color="#F59E0B"/>
        <SolidColorBrush x:Key="Red"          Color="#DC2626"/>

        <!-- Gemeinsame Styles -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background"       Value="#131825"/>
            <Setter Property="BorderBrush"      Value="#243049"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="14"/>
        </Style>

        <Style x:Key="LabelSmall" TargetType="TextBlock">
            <Setter Property="FontSize"         Value="10"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="Foreground"       Value="#94A3B8"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="ValueLarge" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="#F0F4FA"/>
        </Style>

        <!-- Phase-Button -->
        <Style x:Key="PhaseCard" TargetType="Border">
            <Setter Property="Background"      Value="#131825"/>
            <Setter Property="BorderBrush"     Value="#243049"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="14,10"/>
        </Style>

        <!-- Primär-Button -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#2563EB"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="20,9"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Abbrechen-Button -->
        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Background"   Value="#1A2030"/>
            <Setter Property="Foreground"   Value="#94A3B8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"  Value="#2A3A55"/>
            <Setter Property="Padding"      Value="20,9"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Detection ListBox -->
        <Style x:Key="DetectionItem" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Margin"          Value="0,0,0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ProgressBar -->
        <Style x:Key="ThinProgress" TargetType="ProgressBar">
            <Setter Property="Height"          Value="3"/>
            <Setter Property="Background"      Value="#1A2538"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="2" Background="{TemplateBinding Background}">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        CornerRadius="2"
                                        HorizontalAlignment="Left">
                                    <Border.Background>
                                        <SolidColorBrush Color="#2563EB"/>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="56"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="#0C1019"
                BorderBrush="#243049" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Branding -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0">
                    <!-- Blue accent bar -->
                    <Border Width="4" Height="28" CornerRadius="2" Margin="0,0,10,0"
                            Background="#2563EB"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="S E W E R  S T U D I O" FontWeight="Bold" FontSize="11"
                                   FontFamily="Consolas" Foreground="#60A5FA" Margin="0,0,0,1"/>
                        <TextBlock Text="PIPELINE ANALYSIS" FontSize="8" FontWeight="SemiBold"
                                   FontFamily="Consolas" Foreground="#4A5F7A"/>
                    </StackPanel>
                </StackPanel>

                <!-- Titel -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding PhaseLabel}"
                               FontSize="13" FontWeight="SemiBold"
                               FontFamily="Consolas" Foreground="#94A3B8"/>
                    <TextBlock Text="  //  " Foreground="#2A3A55" FontSize="13" FontFamily="Consolas"/>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12" Foreground="#7B8DA6" FontFamily="Consolas"
                               MaxWidth="400" TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Multi-Model Badge + Meter Badge -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Multi-Model Badge -->
                    <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,0"
                            Background="#16A34A15" BorderBrush="#16A34A40" BorderThickness="1"
                            Visibility="{Binding IsMultiModelActive,
                                Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MM" FontFamily="Consolas" FontSize="10"
                                       FontWeight="Bold" Foreground="#16A34A"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock FontFamily="Consolas" FontSize="10"
                                       Foreground="#7B8DA6" VerticalAlignment="Center">
                                <Run Text="Skip "/>
                                <Run Text="{Binding YoloSkippedFrames}" FontWeight="Bold"
                                     Foreground="#F59E0B"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <!-- Meter Badge -->
                    <Border CornerRadius="4" Padding="10,4"
                            Background="#131825" BorderBrush="#243049" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="● " Foreground="#2563EB" FontSize="8"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding VideoPhaseActive,
                                           Converter={StaticResource BoolToVis}}"/>
                            <TextBlock FontFamily="Consolas" FontSize="12"
                                       Foreground="#60A5FA">
                                <Run Text="Meter "/>
                                <Run Text="{Binding CurrentMeter}" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Content ── -->
        <Grid Grid.Row="1" Margin="16,12,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- Linke Spalte -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Phase-Karten -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- Stats-Leiste kompakt -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*" MinHeight="200"/>   <!-- Live-Frame (groß) -->
                    <RowDefinition Height="Auto"/>  <!-- Warnungen -->
                </Grid.RowDefinitions>

                <!-- Drei-Säulen-Karten (Pallon-Style) -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Pillar Cards -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Säule 1: ERKENNEN -->
                        <Grid Grid.Column="0">
                            <Border Style="{StaticResource PhaseCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="2"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Style="{StaticResource LabelSmall}" Text="ERKENNEN"/>
                                    <TextBlock Grid.Row="2" FontSize="9" Foreground="#4A5F7A" Text="Detection"/>
                                    <TextBlock Grid.Row="4" Style="{StaticResource ValueLarge}"
                                               Text="{Binding PillarDetectionCount}"
                                               Foreground="#60A5FA"/>
                                    <ProgressBar Grid.Row="6"
                                                 Style="{StaticResource ThinProgress}"
                                                 Value="{Binding VideoProgressPct}"
                                                 Maximum="100"/>
                                    <TextBlock Grid.Row="8" FontSize="10" Foreground="#94A3B8">
                                        <Run Text="{Binding PillarDetectionCount}"/>
                                        <Run Text=" Schäden"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                            <!-- Top accent line -->
                            <Border Height="3" VerticalAlignment="Top" CornerRadius="8,8,0,0"
                                    Background="#2563EB" Margin="1,1,1,0"/>
                        </Grid>

                        <!-- Säule 2: QUANTIFIZIERUNG -->
                        <Grid Grid.Column="2">
                            <Border Style="{StaticResource PhaseCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="2"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Style="{StaticResource LabelSmall}" Text="QUANTIFIZIERUNG"/>
                                    <TextBlock Grid.Row="2" FontSize="9" Foreground="#4A5F7A" Text="Messung"/>
                                    <TextBlock Grid.Row="4" Style="{StaticResource ValueLarge}"
                                               Text="{Binding PillarQuantCount}"
                                               Foreground="#16A34A"/>
                                    <ProgressBar Grid.Row="6"
                                                 Style="{StaticResource ThinProgress}"
                                                 Value="{Binding MappingProgressPct}"
                                                 Maximum="100"/>
                                    <TextBlock Grid.Row="8" FontSize="10" Foreground="#94A3B8">
                                        <Run Text="{Binding PillarQuantCount}"/>
                                        <Run Text=" quantifiziert"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                            <!-- Top accent line (green) -->
                            <Border Height="3" VerticalAlignment="Top" CornerRadius="8,8,0,0"
                                    Background="#16A34A" Margin="1,1,1,0"/>
                        </Grid>

                        <!-- Säule 3: LOKALISIERUNG -->
                        <Grid Grid.Column="4">
                            <Border Style="{StaticResource PhaseCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="2"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Style="{StaticResource LabelSmall}" Text="LOKALISIERUNG"/>
                                    <TextBlock Grid.Row="2" FontSize="9" Foreground="#4A5F7A" Text="Position"/>
                                    <TextBlock Grid.Row="4" Style="{StaticResource ValueLarge}"
                                               Text="{Binding PillarLocalCount}"
                                               Foreground="#F59E0B"/>
                                    <ProgressBar Grid.Row="6"
                                                 Style="{StaticResource ThinProgress}">
                                        <ProgressBar.Value>
                                            <Binding Path="IsDone">
                                                <Binding.Converter>
                                                    <local:BoolToDoubleConverter TrueValue="100" FalseValue="0"/>
                                                </Binding.Converter>
                                            </Binding>
                                        </ProgressBar.Value>
                                    </ProgressBar>
                                    <TextBlock Grid.Row="8" FontSize="10" Foreground="#94A3B8">
                                        <Run Text="{Binding PillarLocalCount}"/>
                                        <Run Text=" lokalisiert"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                            <!-- Top accent line (amber) -->
                            <Border Height="3" VerticalAlignment="Top" CornerRadius="8,8,0,0"
                                    Background="#F59E0B" Margin="1,1,1,0"/>
                        </Grid>
                    </Grid>

                    <!-- Compact Phase Strip -->
                    <Border Grid.Row="2" CornerRadius="6" Padding="10,5"
                            Background="#0E1320" BorderBrush="#243049" BorderThickness="1">
                        <DockPanel LastChildFill="True">
                            <!-- Speed Selector (rechts) -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock Text="Tempo" FontSize="9" Foreground="#7B8DA6"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="SpeedModeCombo"
                                          Width="58" Height="22"
                                          SelectedIndex="0"
                                          Background="#131825"
                                          Foreground="#60A5FA"
                                          BorderBrush="#243049"
                                          BorderThickness="1"
                                          FontSize="11"
                                          FontWeight="SemiBold"
                                          FontFamily="Consolas">
                                    <ComboBoxItem Content="x1" Tag="1" Foreground="#E0E8F0"/>
                                    <ComboBoxItem Content="x2" Tag="2" Foreground="#E0E8F0"/>
                                    <ComboBoxItem Content="x4" Tag="4" Foreground="#E0E8F0"/>
                                    <ComboBoxItem Content="x6" Tag="6" Foreground="#E0E8F0"/>
                                </ComboBox>
                                <Button x:Name="StartButton"
                                        Content="▶ Start"
                                        Margin="8,0,0,0"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Padding="12,2"
                                        Cursor="Hand"
                                        Click="Start_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#2563EB"/>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- Video-Analyse -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <TextBlock FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="●"/>
                                            <Setter Property="Foreground" Value="#2563EB"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding VideoPhaseDone}" Value="True">
                                                    <Setter Property="Text" Value="✓"/>
                                                    <Setter Property="Foreground" Value="#16A34A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="Video" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <TextBlock FontSize="10" Foreground="#7B8DA6" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <Run Text="{Binding FramesAnalyzed}"/>/<Run Text="{Binding TotalFrames}"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="→" Foreground="#4A5F7A" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <!-- Code-Mapping -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <TextBlock FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="○"/>
                                            <Setter Property="Foreground" Value="#334155"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MappingPhaseDone}" Value="True">
                                                    <Setter Property="Text" Value="✓"/>
                                                    <Setter Property="Foreground" Value="#16A34A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding VideoPhaseDone}" Value="True">
                                                    <Setter Property="Text" Value="●"/>
                                                    <Setter Property="Foreground" Value="#2563EB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="Mapping" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <TextBlock FontSize="10" Foreground="#7B8DA6" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <Run Text="{Binding DetectionCount}"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="→" Foreground="#4A5F7A" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <!-- Protokoll -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="○"/>
                                            <Setter Property="Foreground" Value="#334155"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                    <Setter Property="Text" Value="✓"/>
                                                    <Setter Property="Foreground" Value="#16A34A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="Protokoll" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <TextBlock FontSize="10" Foreground="#7B8DA6" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <Run Text="{Binding HighConfidenceCount}"/>
                                    <Run Text=" HC"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- Kompakte Stats-Leiste -->
                <Border Grid.Row="2" CornerRadius="8" Padding="12,7"
                        Background="#131825" BorderBrush="#243049" BorderThickness="1">
                    <DockPanel>
                        <!-- Status rechts -->
                        <TextBlock DockPanel.Dock="Right" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Läuft"/>
                                    <Setter Property="Foreground" Value="#2563EB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                            <Setter Property="Text" Value="Fertig ✓"/>
                                            <Setter Property="Foreground" Value="#16A34A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                            <Setter Property="Text" Value="Fehler"/>
                                            <Setter Property="Foreground" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Stats inline -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontSize="11" Foreground="#7B8DA6" Margin="0,0,4,0" Text="Frames"/>
                            <TextBlock FontSize="13" FontWeight="Bold" Foreground="#F0F4FA"
                                       Margin="0,0,16,0" Text="{Binding FramesAnalyzed}"/>
                            <TextBlock FontSize="11" Foreground="#7B8DA6" Margin="0,0,4,0" Text="Schäden"/>
                            <TextBlock FontSize="13" FontWeight="Bold" Foreground="#60A5FA"
                                       Margin="0,0,16,0" Text="{Binding DetectionCount}"/>
                            <TextBlock FontSize="11" Foreground="#7B8DA6" Margin="0,0,4,0" Text="Hohe Konf."/>
                            <TextBlock FontSize="13" FontWeight="Bold" Foreground="#16A34A"
                                       Text="{Binding HighConfidenceCount}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Live-Frame Vorschau (groß) -->
                <Border Grid.Row="4" Style="{StaticResource CardBorder}" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <TextBlock DockPanel.Dock="Left"
                                       Style="{StaticResource LabelSmall}"
                                       Text="LIVE-FRAME / ANALYSE"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right"
                                    x:Name="UndockButton"
                                    Content="⬜ Abdocken"
                                    FontSize="10"
                                    Foreground="#94A3B8"
                                    Background="#1A2030"
                                    BorderBrush="#243049"
                                    BorderThickness="1"
                                    Padding="8,2"
                                    Cursor="Hand"
                                    HorizontalAlignment="Right"
                                    Click="Undock_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DockPanel>

                        <Border Grid.Row="2"
                                CornerRadius="8"
                                Background="#080C14"
                                BorderBrush="#243049"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <Grid>
                                <Image Source="{Binding LiveFrameImage}"
                                       Stretch="Uniform"
                                       StretchDirection="Both"/>
                                <Canvas x:Name="LiveFrameOverlayCanvas"
                                        Background="Transparent"
                                        IsHitTestVisible="False"/>
                                <TextBlock Text="Noch kein Frame verfügbar"
                                           Foreground="#7B8DA6"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LiveFrameImage}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="4">
                            <TextBlock Text="{Binding LiveFrameStatus}"
                                       FontSize="11"
                                       Foreground="#60A5FA"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding LiveFrameInfo}"
                                       FontSize="10"
                                       Foreground="#94A3B8"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding LiveFrameQuantSummary}"
                                       FontSize="10"
                                       Foreground="#8B95A8"
                                       Margin="0,2,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Fehlermeldung -->
                <Border Grid.Row="5" CornerRadius="8" Padding="12,8" Margin="0,4,0,0"
                        Background="#DC262610" BorderBrush="#DC262630" BorderThickness="1"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Foreground="#F87171" FontSize="12"
                               Text="{Binding ErrorText}" TextWrapping="Wrap"/>
                </Border>
            </Grid>

            <!-- Rechte Spalte: Live-Feed -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto" MinHeight="220"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Style="{StaticResource LabelSmall}"
                                   Text="ERKENNUNGS-OVERLAY"/>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <ComboBox x:Name="OverlayModeCombo"
                                      Width="100"
                                      Height="24"
                                      Margin="0,0,6,0"
                                      SelectionChanged="OverlayModeCombo_SelectionChanged"
                                      SelectedIndex="1"
                                      Background="#0E1620"
                                      Foreground="#C0D4E8"
                                      BorderBrush="#243049"
                                      BorderThickness="1"
                                      FontSize="11">
                                <ComboBoxItem Content="Kompakt" Foreground="#E0E8F0"/>
                                <ComboBoxItem Content="Detail" Foreground="#E0E8F0"/>
                            </ComboBox>

                            <Border CornerRadius="10" Padding="6,1"
                                    Background="#2563EB15">
                                <TextBlock FontSize="11" FontWeight="Bold" Foreground="#60A5FA"
                                           Text="{Binding DetectionCount}"/>
                            </Border>
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="2"
                            CornerRadius="8"
                            Background="#0A1928"
                            BorderBrush="#243049"
                            BorderThickness="1"
                            Padding="6">
                        <Grid>
                            <Canvas x:Name="PipeRadarCanvas"
                                    MinHeight="200"
                                    Background="Transparent"
                                    ClipToBounds="True"/>
                            <TextBlock x:Name="PipeRadarEmptyText"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="#7B8DA6"
                                       FontSize="11"
                                       Text="Noch keine Erkennungen"
                                       Visibility="Collapsed"
                                       Opacity="0.8"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="4"
                             ItemsSource="{Binding Detections}"
                             ItemContainerStyle="{StaticResource DetectionItem}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,5" CornerRadius="7" Padding="10,8"
                                        Background="#151C2A"
                                        BorderThickness="1">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{Binding SeverityColor}" Opacity="0.2"/>
                                    </Border.BorderBrush>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="4"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="3"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="5"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                        <!-- Titel-Zeile -->
                                        <DockPanel Grid.Row="0">
                                            <!-- Traffic Light Dot -->
                                            <Ellipse Width="8" Height="8" Margin="0,0,5,0"
                                                     VerticalAlignment="Center"
                                                     ToolTip="{Binding TrafficLightLabel}">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding TrafficLightColor}"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#D0D9E8"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="160"/>
                                            <!-- Code-Badge -->
                                            <Border HorizontalAlignment="Right"
                                                    CornerRadius="4" Padding="5,1"
                                                    Background="#2563EB15">
                                                <TextBlock Text="{Binding Code}"
                                                           FontFamily="Consolas" FontSize="10"
                                                           FontWeight="Bold" Foreground="#60A5FA"/>
                                            </Border>
                                        </DockPanel>

                                        <TextBlock Grid.Row="2"
                                                   FontSize="10"
                                                   Foreground="#94A3B8"
                                                   Text="{Binding PositionSummary}"/>

                                        <!-- Quantifizierung (nur wenn vorhanden) -->
                                        <TextBlock Grid.Row="4"
                                                   FontSize="9"
                                                   Foreground="#8B95A8"
                                                   Text="{Binding QuantSummary}"
                                                   Visibility="{Binding HasQuantification,
                                                       Converter={StaticResource BoolToVis}}"/>

                                        <!-- Meter + Konfidenz -->
                                        <Grid Grid.Row="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="#7B8DA6"
                                                       Text="{Binding MeterRange}"/>

                                            <!-- Konfidenz-Bar -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <ProgressBar Width="44" Height="3"
                                                             Background="#1A2538"
                                                             BorderThickness="0"
                                                             Maximum="1"
                                                             Value="{Binding Confidence}">
                                                    <ProgressBar.Foreground>
                                                        <SolidColorBrush Color="{Binding SeverityColor}"/>
                                                    </ProgressBar.Foreground>
                                                </ProgressBar>
                                                <TextBlock Margin="5,0,0,0"
                                                           FontFamily="Consolas" FontSize="10"
                                                           FontWeight="Bold"
                                                           Text="{Binding ConfidencePct}">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="{Binding SeverityColor}"/>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Footer ── -->
        <Border Grid.Row="2" Background="#0C1019"
                BorderBrush="#243049" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <!-- Stats links -->
                <TextBlock VerticalAlignment="Center" FontSize="11"
                           Foreground="#4A5F7A" FontFamily="Consolas"
                           Text="{Binding StatsText}"/>

                <!-- Buttons rechts -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,0,0">
                    <Button Style="{StaticResource BtnCancel}"
                            Content="Abbrechen" Margin="0,0,8,0"
                            Click="Cancel_Click"/>
                    <Button x:Name="AcceptButton"
                            Style="{StaticResource BtnPrimary}"
                            Content="Protokoll übernehmen"
                            IsEnabled="{Binding IsDone}"
                            Click="Accept_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
