<Window x:Class="AuswertungPro.Next.UI.Views.Windows.DossierPrintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Haltungsdossier - Druckoptionen"
        Width="480" Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF0D1117">

    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Bd" Width="18" Height="18"
                                    Background="#21262D" BorderBrush="#30363D" BorderThickness="1"
                                    CornerRadius="3" VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock x:Name="CheckMark" Text="&#x2713;"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="#58A6FF"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1A3A5C"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Dossier-Inhalte auswaehlen"
                       FontSize="14" FontWeight="SemiBold" Foreground="#E6EDF3"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Die Reihenfolge entspricht der Ausgabe im PDF."
                       FontSize="11" Foreground="#8B949E"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
            <StackPanel Margin="8,0,0,0">
                <TextBlock Text="1) Haltung"
                           FontSize="12" FontWeight="SemiBold" Foreground="#58A6FF" Margin="0,0,0,2"/>
                <CheckBox x:Name="ChkDeckblatt" Content="Deckblatt (Projekt- und Haltungsuebersicht)" IsChecked="True"/>
                <CheckBox x:Name="ChkHaltungsprotokoll" Content="Haltungsprotokoll (Beobachtungen / Codes)" IsChecked="True"/>
                <CheckBox x:Name="ChkFotos" Content="Fotos aus Haltungsprotokoll" IsChecked="True"/>

                <Border Height="1" Background="#30363D" Margin="0,8,0,8"/>

                <TextBlock Text="2) Schaechte"
                           FontSize="12" FontWeight="SemiBold" Foreground="#58A6FF" Margin="0,0,0,2"/>
                <CheckBox x:Name="ChkSchachtVon" Content="Schacht Von (Stammdaten + Befunde)" IsChecked="True"/>
                <CheckBox x:Name="ChkSchachtBis" Content="Schacht Bis (Stammdaten + Befunde)" IsChecked="True"/>

                <Border Height="1" Background="#30363D" Margin="0,8,0,8"/>

                <TextBlock Text="3) Auswertung"
                           FontSize="12" FontWeight="SemiBold" Foreground="#58A6FF" Margin="0,0,0,2"/>
                <CheckBox x:Name="ChkHydraulik" Content="Hydraulik-Berechnung" IsChecked="True"/>
                <CheckBox x:Name="ChkKostenschaetzung" Content="Kostenschaetzung / Massnahmen" IsChecked="True"/>

                <Border Height="1" Background="#30363D" Margin="0,8,0,8"/>

                <TextBlock Text="4) Anhaenge"
                           FontSize="12" FontWeight="SemiBold" Foreground="#58A6FF" Margin="0,0,0,2"/>
                <CheckBox x:Name="ChkOriginalProtokolle" Content="Original-Protokolle als PDF-Anhang" IsChecked="True"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Info-Labels -->
        <StackPanel Grid.Row="2" Margin="8,12,0,0">
            <TextBlock Text="Verfuegbarkeit in den aktuellen Daten:"
                       FontSize="11" FontWeight="SemiBold" Foreground="#C9D1D9" Margin="0,0,0,4"/>
            <TextBlock x:Name="InfoSchachtVon" FontSize="11" Foreground="#8B949E" Margin="0,2"/>
            <TextBlock x:Name="InfoSchachtBis" FontSize="11" Foreground="#8B949E" Margin="0,2"/>
            <TextBlock x:Name="InfoHydraulik" FontSize="11" Foreground="#8B949E" Margin="0,2"/>
            <TextBlock x:Name="InfoKosten" FontSize="11" Foreground="#8B949E" Margin="0,2"/>
            <TextBlock x:Name="InfoOriginalPdf" FontSize="11" Foreground="#8B949E" Margin="0,2"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="90" Height="30" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="#21262D" Foreground="#C9D1D9" BorderBrush="#30363D"/>
            <Button Content="Dossier erstellen" Width="130" Height="30"
                    Click="Ok_Click"
                    Background="#238636" Foreground="White" BorderBrush="#2EA043" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
