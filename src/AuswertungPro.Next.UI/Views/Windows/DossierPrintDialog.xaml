<Window x:Class="AuswertungPro.Next.UI.Views.Windows.DossierPrintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Haltungsdossier - Druckoptionen"
        Width="520" Height="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14" Padding="18,16">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <Border Width="6" Height="26" CornerRadius="3" Background="{StaticResource NeonGradient}" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Dossier-Inhalte waehlen" FontSize="19" FontWeight="SemiBold"/>
                        <TextBlock Text="Die Reihenfolge entspricht der Ausgabe im PDF." Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="18,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="1. Haltung">
                            <StackPanel>
                                <CheckBox x:Name="ChkDeckblatt" Content="Deckblatt (Projekt- und Haltungsubersicht)" IsChecked="True"/>
                                <CheckBox x:Name="ChkHaltungsprotokoll" Content="Haltungsprotokoll (Beobachtungen / Codes)" IsChecked="True"/>
                                <CheckBox x:Name="ChkFotos" Content="Fotos aus Haltungsprotokoll" IsChecked="True"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="2. Schaechte" Margin="0,12,0,0">
                            <StackPanel>
                                <CheckBox x:Name="ChkSchachtVon" Content="Schacht Von (Stammdaten + Befunde)" IsChecked="True"/>
                                <CheckBox x:Name="ChkSchachtBis" Content="Schacht Bis (Stammdaten + Befunde)" IsChecked="True"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="3. Auswertung" Margin="0,12,0,0">
                            <StackPanel>
                                <CheckBox x:Name="ChkHydraulik" Content="Hydraulik-Berechnung" IsChecked="True"/>
                                <CheckBox x:Name="ChkKostenschaetzung" Content="Kostenschaetzung / Massnahmen" IsChecked="True"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="4. Anhaenge" Margin="0,12,0,0">
                            <StackPanel>
                                <CheckBox x:Name="ChkOriginalProtokolle" Content="Original-Protokolle als PDF-Anhang" IsChecked="True"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="1" Margin="0,14,0,0" Background="{StaticResource HeaderBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="Verfuegbarkeit in den aktuellen Daten" FontWeight="SemiBold"/>
                        <TextBlock x:Name="InfoSchachtVon" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                        <TextBlock x:Name="InfoSchachtBis" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        <TextBlock x:Name="InfoHydraulik" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        <TextBlock x:Name="InfoKosten" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        <TextBlock x:Name="InfoOriginalPdf" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Abbrechen" Width="110" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Dossier erstellen" Width="150" Click="Ok_Click" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
