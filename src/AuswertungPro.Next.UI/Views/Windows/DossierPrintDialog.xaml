<Window x:Class="AuswertungPro.Next.UI.Views.Windows.DossierPrintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Haltungsdossier - Druckoptionen"
        Width="480" Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Dossier-Inhalte auswaehlen"
                       FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Die Reihenfolge entspricht der Ausgabe im PDF."
                       FontSize="11" Foreground="{StaticResource MutedBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
            <StackPanel Margin="8,0,0,0">
                <TextBlock Text="1) Haltung"
                           FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2"/>
                <CheckBox x:Name="ChkDeckblatt" Content="Deckblatt (Projekt- und Haltungsuebersicht)" IsChecked="True"/>
                <CheckBox x:Name="ChkHaltungsprotokoll" Content="Haltungsprotokoll (Beobachtungen / Codes)" IsChecked="True"/>
                <CheckBox x:Name="ChkFotos" Content="Fotos aus Haltungsprotokoll" IsChecked="True"/>

                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,8,0,8"/>

                <TextBlock Text="2) Schaechte"
                           FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2"/>
                <CheckBox x:Name="ChkSchachtVon" Content="Schacht Von (Stammdaten + Befunde)" IsChecked="True"/>
                <CheckBox x:Name="ChkSchachtBis" Content="Schacht Bis (Stammdaten + Befunde)" IsChecked="True"/>

                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,8,0,8"/>

                <TextBlock Text="3) Auswertung"
                           FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2"/>
                <CheckBox x:Name="ChkHydraulik" Content="Hydraulik-Berechnung" IsChecked="True"/>
                <CheckBox x:Name="ChkKostenschaetzung" Content="Kostenschaetzung / Massnahmen" IsChecked="True"/>

                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,8,0,8"/>

                <TextBlock Text="4) Anhaenge"
                           FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2"/>
                <CheckBox x:Name="ChkOriginalProtokolle" Content="Original-Protokolle als PDF-Anhang" IsChecked="True"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Info-Labels -->
        <StackPanel Grid.Row="2" Margin="8,12,0,0">
            <TextBlock Text="Verfuegbarkeit in den aktuellen Daten:"
                       FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
            <TextBlock x:Name="InfoSchachtVon" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,2"/>
            <TextBlock x:Name="InfoSchachtBis" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,2"/>
            <TextBlock x:Name="InfoHydraulik" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,2"/>
            <TextBlock x:Name="InfoKosten" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,2"/>
            <TextBlock x:Name="InfoOriginalPdf" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,2"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="90" Height="30" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}"
                    ToolTip="Dossier-Erstellung abbrechen"/>
            <Button Content="Dossier erstellen" Width="130" Height="30"
                    Click="Ok_Click"
                    Background="{StaticResource AccentBrush}" Foreground="White" BorderBrush="#2EA043" FontWeight="SemiBold"
                    ToolTip="Haltungsdossier-PDF mit den gewaehlten Abschnitten erzeugen"/>
        </StackPanel>
    </Grid>
</Window>
