<Window x:Class="AuswertungPro.Next.UI.Views.Windows.HydraulikPrintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hydraulik-PDF - Druckoptionen"
        Width="420" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14" Padding="18,16">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <Border Width="6" Height="24" CornerRadius="3" Background="{StaticResource NeonGradient}" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Hydraulik-Abschnitte waehlen" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="Nur ausgewaehlte Kennzahlen werden ins PDF uebernommen." Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="18,16">
            <GroupBox Header="Druckinhalt">
                <StackPanel>
                    <CheckBox x:Name="ChkTeilfuellung" Content="Teilfuellung (v, Q, A, Lu, Rhy, Bsp)" IsChecked="True"/>
                    <CheckBox x:Name="ChkVollfuellung" Content="Vollfuellung (v_V, Q_V)" IsChecked="True"/>
                    <CheckBox x:Name="ChkKennzahlen" Content="Kennzahlen (Re, Fr, Lambda, Ny, Tau)" IsChecked="True"/>
                    <CheckBox x:Name="ChkAblagerung" Content="Ablagerungsgefahr (v_c, I_c, Tau_c)" IsChecked="True"/>
                    <CheckBox x:Name="ChkAuslastung" Content="Auslastung (h/D)" IsChecked="True"/>
                    <CheckBox x:Name="ChkBewertung" Content="Bewertung (Ampel-Uebersicht)" IsChecked="True"/>
                </StackPanel>
            </GroupBox>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Abbrechen" Width="110" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource SecondaryButton}"/>
            <Button Content="PDF erstellen" Width="130" Click="Ok_Click" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
