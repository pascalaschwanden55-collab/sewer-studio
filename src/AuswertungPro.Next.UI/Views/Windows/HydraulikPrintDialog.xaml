<Window x:Class="AuswertungPro.Next.UI.Views.Windows.HydraulikPrintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hydraulik-PDF — Druckoptionen"
        Width="380" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Abschnitte fuer den Druck auswaehlen:"
                   FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Margin="8,0,0,0">
            <CheckBox x:Name="ChkTeilfuellung" Content="Teilfuellung (v, Q, A, Lu, Rhy, Bsp)"
                      IsChecked="True"/>
            <CheckBox x:Name="ChkVollfuellung" Content="Vollfuellung (v_V, Q_V)"
                      IsChecked="True"/>
            <CheckBox x:Name="ChkKennzahlen" Content="Kennzahlen (Re, Fr, Lambda, Ny, Tau)"
                      IsChecked="True"/>
            <CheckBox x:Name="ChkAblagerung" Content="Ablagerungsgefahr (v_c, I_c, Tau_c)"
                      IsChecked="True"/>
            <CheckBox x:Name="ChkAuslastung" Content="Auslastung (h/D)"
                      IsChecked="True"/>
            <CheckBox x:Name="ChkBewertung" Content="Bewertung (Ampel-Uebersicht)"
                      IsChecked="True"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="90" Height="30" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="{StaticResource CardBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}"
                    ToolTip="PDF-Erstellung abbrechen"/>
            <Button Content="PDF erstellen" Width="110" Height="30"
                    Click="Ok_Click"
                    Background="{StaticResource AccentBrush}" Foreground="White" BorderBrush="#2EA043" FontWeight="SemiBold"
                    ToolTip="Hydraulik-Bericht als PDF mit den gewaehlten Abschnitten erzeugen"/>
        </StackPanel>
    </Grid>
</Window>
