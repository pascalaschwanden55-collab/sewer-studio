<Window x:Class="AuswertungPro.Next.UI.Views.Windows.SanierungRuleEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sanierungsregel bearbeiten"
        Width="780" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
        <StackPanel>

            <TextBlock Text="WENN diese Bedingungen alle erfüllt sind ..."
                       FontSize="{StaticResource TypeBody}" FontWeight="Bold" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Regel-Name:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="NameBox" Padding="4"/>
            </Grid>
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" x:Name="EnabledBox" Content="Aktiv" VerticalAlignment="Center"/>
            </Grid>

            <Border Margin="0,8,0,8" Padding="10" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="Bedingungen (alle gesetzten muessen zutreffen, leer = nicht geprueft)"
                               FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{StaticResource AccentBrush}"/>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Material enthaelt:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="MaterialContainsBox" Padding="4"/>
                        <TextBlock Grid.Column="2" Text="z.B. 'GFK', 'Steinzeug', 'Asbest'"
                                   FontSize="{StaticResource TypeCaption}" Foreground="Gray" VerticalAlignment="Center" Margin="6,0"/>
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Material ohne:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="MaterialNotContainsBox" Padding="4"/>
                        <TextBlock Grid.Column="2" Text="(Negation, Material darf NICHT enthalten)"
                                   FontSize="{StaticResource TypeCaption}" Foreground="Gray" VerticalAlignment="Center" Margin="6,0"/>
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="DN-Bereich (mm):" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="DnMinBox" Padding="4"/>
                        <TextBlock Grid.Column="2" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBox Grid.Column="3" x:Name="DnMaxBox" Padding="4"/>
                        <TextBlock Grid.Column="4" Text="(min - max, leer = unbegrenzt)"
                                   FontSize="{StaticResource TypeCaption}" Foreground="Gray" VerticalAlignment="Center" Margin="6,0"/>
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Bogen mind. (Grad):" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="BendDegBox" Padding="4"/>
                        <TextBlock Grid.Column="2" Text="z.B. 15 (= moderat) oder 30 (= stark)"
                                   FontSize="{StaticResource TypeCaption}" Foreground="Gray" VerticalAlignment="Center" Margin="6,0"/>
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Schadensgruppen:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="DamageGroupsBox" Padding="4"/>
                        <TextBlock Grid.Column="2" Text="komma-getrennt: cracks, joints, breaks, ..."
                                   FontSize="{StaticResource TypeCaption}" Foreground="Gray" VerticalAlignment="Center" Margin="6,0"/>
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="VSA-Code beginnt mit:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="VsaCodeBox" Padding="4"/>
                        <TextBlock Grid.Column="2" Text="z.B. 'BAC' fuer alle Bruch-Codes"
                                   FontSize="{StaticResource TypeCaption}" Foreground="Gray" VerticalAlignment="Center" Margin="6,0"/>
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Zustandsklasse max.:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="ZkMaxBox" Padding="4"/>
                        <TextBlock Grid.Column="2" Text="VSA 2023: 0=Ausfall, 4=neu (max bedeutet schwerer/gleich)"
                                   FontSize="{StaticResource TypeCaption}" Foreground="Gray" VerticalAlignment="Center" Margin="6,0"/>
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Grundwasser:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="GroundwaterBox" Padding="4">
                            <ComboBoxItem Content="(egal)" IsSelected="True"/>
                            <ComboBoxItem Content="ja"/>
                            <ComboBoxItem Content="nein"/>
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Nutzungsart enthaelt:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="NutzungsartBox" Padding="4"/>
                        <TextBlock Grid.Column="2" Text="z.B. 'Schmutz', 'Misch', 'Regen'"
                                   FontSize="{StaticResource TypeCaption}" Foreground="Gray" VerticalAlignment="Center" Margin="6,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="DANN diese Verfahren ausschliessen ..."
                       FontSize="{StaticResource TypeBody}" FontWeight="Bold" Margin="0,8,0,4"/>
            <TextBlock Text="Komma-getrennte Verfahrens-IDs:" FontSize="{StaticResource TypeCaption}" Foreground="Gray" Margin="0,0,0,2"/>
            <TextBox x:Name="ExcludeIdsBox" Padding="4"/>
            <TextBlock Text="Verfuegbare IDs: cipp_inliner, short_liner, robotic_milling, robotic_repair, mechanical_sleeve, berstlining, close_fit_lining, injection_grouting, open_excavation, shaft_rehabilitation"
                       FontSize="{StaticResource TypeCaption}" Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,0"/>

            <TextBlock Text="WEIL (Begruendung fuer KI + Anwender):"
                       FontSize="{StaticResource TypeBody}" FontWeight="Bold" Margin="0,12,0,4"/>
            <TextBox x:Name="ReasonBox" Padding="6" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"/>

            <TextBlock Text="Notiz (optional, intern):"
                       FontSize="{StaticResource TypeSmall}" FontWeight="SemiBold" Margin="0,12,0,4"/>
            <TextBox x:Name="NoteBox" Padding="4" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="40"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Abbrechen" Click="Cancel_Click" Padding="14,6" Margin="0,0,8,0"/>
                <Button Content="Speichern" Click="Ok_Click" Padding="14,6" FontWeight="Bold"
                        Background="{StaticResource AccentBrush}" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
