<Window x:Class="AuswertungPro.Next.UI.Views.Windows.OfferCalculatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Kostenrechner &#x2014; SewerStudio"
        Height="650" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <!-- Konverter: true = Visible, false = Collapsed -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Modus-Auswahl -->
            <RowDefinition Height="Auto"/>  <!-- Massnahmen-Zeile (nur Kombiniert) -->
            <RowDefinition Height="Auto"/>  <!-- Eingabefelder -->
            <RowDefinition Height="Auto"/>  <!-- Warnung -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Summen-Bereich -->
        </Grid.RowDefinitions>

        <!-- ═══════════ Zeile 0: Modus-Auswahl + Aktions-Buttons ═══════════ -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
            <DockPanel>
                <!-- Modus-Radiobuttons links -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Modus:" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                    <RadioButton x:Name="RadioSingle" Content="Einzelkalkulation"
                                 Foreground="{StaticResource TextBrush}"
                                 IsChecked="True" GroupName="CalcMode"
                                 VerticalAlignment="Center" Margin="0,0,16,0"
                                 Checked="ModeRadio_Checked"/>
                    <RadioButton x:Name="RadioCombined" Content="Kombinierte Offerte"
                                 Foreground="{StaticResource TextBrush}"
                                 GroupName="CalcMode"
                                 VerticalAlignment="Center"
                                 Checked="ModeRadio_Checked"/>
                </StackPanel>

                <!-- Aktions-Buttons rechts -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding CalculateCommand}"
                            Content="Berechnen" MinWidth="100" Padding="12,5"
                            Style="{StaticResource ToolbarButtonAccent}"
                            ToolTip="Kostenberechnung mit den aktuellen Eingabewerten durchfuehren"
                            Margin="0,0,6,0"/>
                    <Button Command="{Binding OpenPriceEditorCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="Preise..." MinWidth="90" Padding="12,5"
                            Style="{StaticResource ToolbarButton}"
                            ToolTip="Preiskatalog oeffnen um Einheitspreise zu bearbeiten"
                            Margin="0,0,6,0"/>
                    <Button Command="{Binding CopyToClipboardCommand}"
                            Content="Offerte kopieren" MinWidth="120" Padding="12,5"
                            Style="{StaticResource ToolbarButton}"
                            ToolTip="Berechnete Offerte in die Zwischenablage kopieren"
                            Margin="0,0,6,0"/>
                    <Button Command="{Binding ExportPdfCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="PDF exportieren" MinWidth="120" Padding="12,5"
                            Style="{StaticResource ToolbarButton}"
                            ToolTip="Kostenzusammenstellung als PDF-Dokument exportieren"
                            Margin="0,0,6,0"/>
                    <Button Command="{Binding InstallChromiumCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="Chromium installieren" MinWidth="150" Padding="12,5"
                            Style="{StaticResource ToolbarButton}"
                            ToolTip="Chromium-Browser fuer die PDF-Erzeugung herunterladen und installieren"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════ Zeile 1: Massnahmen-Auswahl (nur Kombinierte Offerte) ═══════════ -->
        <Border x:Name="MeasureSelectionPanel" Grid.Row="1"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="10,6" Margin="0,0,0,6"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding SelectMeasuresCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="Massnahmen auswaehlen..." MinWidth="170" Padding="12,5"
                        Style="{StaticResource ToolbarButton}"
                        ToolTip="Sanierungsmassnahmen fuer diese Haltung aus dem Katalog auswaehlen"
                        Margin="0,0,10,0"/>
                <TextBlock Text="Ausgewaehlt:" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ItemsControl ItemsSource="{Binding SelectedMeasures}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource AccentBrush}" Padding="6,3"
                                    Margin="0,0,4,0" CornerRadius="3">
                                <TextBlock Text="{Binding Name}" Foreground="White"
                                           FontWeight="SemiBold" FontSize="{StaticResource TypeSmall}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ═══════════ Zeile 1 (Einzelkalkulation): Massnahmen-Name ═══════════ -->
        <Border x:Name="SingleMeasurePanel" Grid.Row="1"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="10,6" Margin="0,0,0,6"
                Visibility="Visible">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Massnahme:" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding MeasureName}" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ═══════════ Zeile 2: Gemeinsame Eingabefelder ═══════════ -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
            <WrapPanel Orientation="Horizontal">
                <!-- DN -->
                <StackPanel Orientation="Horizontal" Margin="0,0,14,4">
                    <TextBlock Text="DN:" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding Dn}" Width="80"/>
                </StackPanel>

                <!-- Laenge -->
                <StackPanel Orientation="Horizontal" Margin="0,0,14,4">
                    <TextBlock Text="Laenge (m):" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding LengthM, StringFormat=F2}" Width="90"/>
                </StackPanel>

                <!-- Anschluesse -->
                <StackPanel Orientation="Horizontal" Margin="0,0,14,4">
                    <TextBlock Text="Anschluesse (Stk):" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding Connections}" Width="70"/>
                </StackPanel>

                <!-- Endmanschetten -->
                <StackPanel Orientation="Horizontal" Margin="0,0,14,4">
                    <TextBlock Text="Endmanschetten (Stk):" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding EndCuffs}" Width="70"/>
                </StackPanel>

                <!-- Wasserhaltung -->
                <CheckBox IsChecked="{Binding Waterholding}"
                          Content="Wasserhaltung"
                          Foreground="{StaticResource TextBrush}"
                          VerticalAlignment="Center" Margin="0,0,14,4"/>

                <!-- Rabatt (nur Kombinierte Offerte) -->
                <StackPanel x:Name="RabattPanel" Orientation="Horizontal" Margin="0,0,14,4"
                            Visibility="Collapsed">
                    <TextBlock Text="Rabatt %:" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding RabattPct}" Width="60"/>
                </StackPanel>

                <!-- Skonto (nur Kombinierte Offerte) -->
                <StackPanel x:Name="SkontoPanel" Orientation="Horizontal" Margin="0,0,14,4"
                            Visibility="Collapsed">
                    <TextBlock Text="Skonto %:" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding SkontoPct}" Width="60"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ═══════════ Zeile 3: Warnungstext ═══════════ -->
        <TextBlock Grid.Row="3" Text="{Binding WarningText}"
                   Foreground="{StaticResource NeonPinkBrush}" Margin="0,0,0,4"
                   TextWrapping="Wrap"/>

        <!-- ═══════════ Zeile 4: Positions-DataGrid ═══════════ -->
        <DataGrid Grid.Row="4" ItemsSource="{Binding Lines}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                  Background="{StaticResource CardBrush}"
                  RowBackground="{StaticResource CardBrush}"
                  AlternatingRowBackground="{StaticResource BackgroundBrush}"
                  Foreground="{StaticResource TextBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Gruppe" Binding="{Binding Group}" Width="150"/>
                <DataGridTextColumn Header="Position" Binding="{Binding Label}" Width="*"/>
                <DataGridTextColumn Header="Einheit" Binding="{Binding Unit}" Width="70"/>
                <DataGridTextColumn Header="Menge" Binding="{Binding Qty, StringFormat=N3}" Width="80"/>
                <DataGridTextColumn Header="EP" Binding="{Binding UnitPrice, StringFormat=N2}" Width="90"/>
                <DataGridTextColumn Header="Betrag" Binding="{Binding Amount, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Quelle" Binding="{Binding Source}" Width="220"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══════════ Zeile 5: Summen-Bereich ═══════════ -->
        <Border Grid.Row="5" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="12,10" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Hinweistext links -->
                <TextBlock Text="Hinweis: Wenn DN-Preise fehlen (z.B. DN500), im Preiskatalog eine Zeile mit dn_min=500, dn_max=500 erfassen."
                           TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <!-- Einzelkalkulation: Summen rechts -->
                <StackPanel x:Name="SingleTotalsPanel" Grid.Column="1"
                            HorizontalAlignment="Right" Visibility="Visible">
                    <TextBlock Text="{Binding SubTotalText}" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding MwstText}" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding TotalText}" FontWeight="Bold" FontSize="{StaticResource TypeBodyLarge}"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>

                <!-- Kombinierte Offerte: Summen rechts (mit Rabatt/Skonto) -->
                <StackPanel x:Name="CombinedTotalsPanel" Grid.Column="1"
                            HorizontalAlignment="Right" Visibility="Collapsed">
                    <TextBlock Text="{Binding RabattText}" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding SubTotalNettoText}" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding SkontoText}" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding TotalNettoText}" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding MwstText}" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding TotalBruttoText}" FontWeight="Bold" FontSize="{StaticResource TypeBodyLarge}"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
