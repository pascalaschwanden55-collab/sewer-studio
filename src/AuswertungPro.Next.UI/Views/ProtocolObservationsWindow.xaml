<Window x:Class="AuswertungPro.Next.UI.Views.ProtocolObservationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beobachtungen / Schaeden"
        Width="980"
        Height="620"
        MinWidth="900"
        MinHeight="600"
        ResizeMode="CanResizeWithGrip"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBgBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7DEE8"/>
        <SolidColorBrush x:Key="HeaderBgBrush" Color="#EEF5FB"/>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                Background="{StaticResource PanelBgBrush}"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Vertical">
                    <TextBlock x:Name="HeaderText"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock x:Name="RevisionText"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>

                <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                    <Button x:Name="StartNachprotokollButton" Content="Nachprotokoll starten" Style="{StaticResource ToolbarButtonStyle}"/>
                    <Button x:Name="StartNeuButton" Content="Neu-Protokoll" Style="{StaticResource ToolbarButtonStyle}"/>
                    <Button x:Name="RestoreOriginalButton" Content="Original wiederherstellen" Style="{StaticResource ToolbarButtonStyle}"/>
                    <Button x:Name="HistoryButton" Content="Historie..." Style="{StaticResource ToolbarButtonStyle}" Margin="0"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="White">
            <DataGrid x:Name="EntriesGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      IsReadOnly="True"
                      SelectionChanged="EntriesGrid_SelectionChanged"
                      AlternationCount="2"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E5EAF1"
                      VerticalGridLinesBrush="#E5EAF1"
                      MinRowHeight="30">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Background" Value="{StaticResource HeaderBgBrush}"/>
                        <Setter Property="Foreground" Value="#1E293B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderBrush" Value="#D7DEE8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="6,4"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#FBFDFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="110"/>
                    <DataGridTextColumn Header="m+" Binding="{Binding MeterStart, StringFormat=F2}" Width="90"/>
                    <DataGridTextColumn Header="m-" Binding="{Binding MeterEnd, StringFormat=F2}" Width="90"/>
                    <DataGridCheckBoxColumn Header="Strecke" Binding="{Binding IsStreckenschaden}" Width="80"/>
                    <DataGridTextColumn Header="Zustand / Beschreibung" Binding="{Binding Beschreibung}" Width="*"/>
                    <DataGridTextColumn Header="Zeit" Binding="{Binding Zeit, StringFormat={}{0:hh\\:mm\\:ss}}" Width="110"/>
                    <DataGridTextColumn Header="MPEG" Binding="{Binding Mpeg}" Width="110"/>
                    <DataGridTextColumn Header="Fotos" Binding="{Binding FotoPaths.Count}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,10,0,0"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                Background="{StaticResource PanelBgBrush}"
                CornerRadius="8"
                Padding="8">
            <WrapPanel HorizontalAlignment="Right">
                <Button x:Name="NewButton" Content="Neu" Width="100" Style="{StaticResource FooterButtonStyle}"/>
                <Button x:Name="CopyButton" Content="Kopieren" Width="110" Style="{StaticResource FooterButtonStyle}"/>
                <Button x:Name="DeleteButton" Content="Loeschen" Width="100" Style="{StaticResource FooterButtonStyle}"/>
                <Button x:Name="OverlayButton" Content="Im Video einblenden" Width="160" Style="{StaticResource FooterButtonStyle}"/>
                <Button x:Name="TrainButton" Content="Als Training speichern" Width="160" Style="{StaticResource FooterButtonStyle}"/>
                <Button x:Name="ExportPdfButton" Content="Haltungsprotokoll PDF" Width="180" Style="{StaticResource FooterButtonStyle}"/>
                <Button x:Name="CloseButton" Content="Schliessen" Width="110" Style="{StaticResource FooterButtonStyle}" Margin="0" IsCancel="True"/>
            </WrapPanel>
        </Border>
    </Grid>
</Window>
