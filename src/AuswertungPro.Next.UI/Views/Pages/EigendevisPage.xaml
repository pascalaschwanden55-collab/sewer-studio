<UserControl x:Class="AuswertungPro.Next.UI.Views.Pages.EigendevisPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AuswertungPro.Next.UI.ViewModels.Pages"
             xmlns:ctrl="clr-namespace:AuswertungPro.Next.UI.Views.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Phase 3.3: PageHeader-Control. -->
        <ctrl:PageHeader Grid.Row="0"
                         Title="Eigendevis"
                         Subtitle="Automatisierte Kostenschaetzungen (Baumeister + Rohrleitungsbau) basierend auf erkannten Schaeden."/>

        <!-- Action Card -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="10" Padding="0" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="10,0,0,10"/>

                <StackPanel Grid.Column="1" Margin="16,14">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource TypeIcon}"
                                   Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Eigendevis" FontSize="{StaticResource TypeH4}" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Generiert automatisch Kostenschaetzungen (Baumeister + Rohrleitungsbau) basierend auf erkannten Schaeden und konfigurierbaren Mapping-Regeln."
                               TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}"
                               Margin="0,0,0,12"/>
                    <Button Command="{Binding GenerateCommand}" Style="{StaticResource ActionCardButton}" HorizontalAlignment="Left" ToolTip="Kostenschaetzung automatisch aus Schadencodes und Mapping-Regeln berechnen">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource TypeBodyLarge}"
                                       Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Eigendevis generieren" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Total Banner -->
        <Border Grid.Row="2" Background="{StaticResource HeaderBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,10"
                Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Baumeister" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeCaption}"/>
                    <TextBlock Text="{Binding TotalBaumeister}" FontSize="{StaticResource TypeH4}" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Rohrleitungsbau" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeCaption}"/>
                    <TextBlock Text="{Binding TotalRohrleitungsbau}" FontSize="{StaticResource TypeH4}" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Text="Gesamt inkl. MWSt." Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeCaption}"/>
                    <TextBlock Text="{Binding TotalGesamt}" FontSize="{StaticResource TypeIcon}" FontWeight="Bold"
                               Foreground="{StaticResource NeonCyanBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Summary -->
        <Border Grid.Row="3" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="14" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource TypeBodyLarge}"
                               Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Ergebnis" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                </StackPanel>
                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Tab Control: Baumeister / Rohrleitungsbau -->
        <TabControl Grid.Row="4" SelectedIndex="{Binding SelectedTabIndex}" Margin="0,0,0,8"
                    Background="Transparent" BorderThickness="0"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">

            <TabControl.Resources>
                <HierarchicalDataTemplate DataType="{x:Type local:DevisTreeNode}"
                                          ItemsSource="{Binding Children}">
                    <Grid Margin="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding PositionNr}" Foreground="{StaticResource MutedBrush}" FontSize="{StaticResource TypeCaption}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Label}" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGruppe}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsAbschnitt}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Grid.Column="2" Text="{Binding Menge, StringFormat={}{0:N1}}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Grid.Column="3" Text="{Binding Einheit}" Margin="4,0,0,0"
                                   VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Grid.Column="4" Text="{Binding Einheitspreis, StringFormat={}{0:N2}}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Grid.Column="5" Text="{Binding BetragFormatiert}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    </Grid>
                </HierarchicalDataTemplate>
            </TabControl.Resources>

            <TabItem Header="Baumeister">
                <TreeView ItemsSource="{Binding BaumeisterNodes}" Background="Transparent" BorderThickness="0"/>
            </TabItem>
            <TabItem Header="Rohrleitungsbau">
                <TreeView ItemsSource="{Binding RohrleitungsbauNodes}" Background="Transparent" BorderThickness="0"/>
            </TabItem>
        </TabControl>

        <!-- Export Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
            <Button Command="{Binding ExportOhnePreisCommand}" Style="{StaticResource ActionCardButton}" Margin="0,0,8,0" ToolTip="Eigendevis als Excel exportieren, ohne Einheitspreise anzuzeigen">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource TypeBodyLarge}"
                               Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Excel Export (ohne Preise)" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding ExportMitKVCommand}" Style="{StaticResource ActionCardButton}" ToolTip="Eigendevis als Excel exportieren, inklusive Kostenvoranschlag und Preisen">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource TypeBodyLarge}"
                               Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Excel Export (mit KV)" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
