<UserControl x:Class="AuswertungPro.Next.UI.Views.Pages.DiagnosticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:AuswertungPro.Next.UI.Views.Controls">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Phase 3.3: PageHeader-Control mit Action-Button rechts. -->
        <ctrl:PageHeader Title="Diagnose"
                         Subtitle="Log-Tail aus der Protokolldatei lesen und Fehlercodes nachschlagen.">
            <ctrl:PageHeader.Actions>
                <Button Content="Log aktualisieren"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButton}"
                        ToolTip="Aktuelle Log-Eintraege aus der Protokolldatei neu laden"/>
            </ctrl:PageHeader.Actions>
        </ctrl:PageHeader>

        <TextBox Grid.Row="1" Text="{Binding LogTail}" AcceptsReturn="True" IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
    </Grid>
</UserControl>
