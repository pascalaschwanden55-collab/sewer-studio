<UserControl x:Class="AuswertungPro.Next.UI.Views.Pages.DiagnosticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:AuswertungPro.Next.UI.Views.Controls">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Phase 3.3: PageHeader-Control mit Action-Button rechts. -->
        <ctrl:PageHeader Title="Diagnose"
                         Subtitle="KB-Dashboard, Wartungs-Tools, KB-Mirror-Status, Frame-Cleanup, Versions-Pruning + Log-Tail.">
            <ctrl:PageHeader.Actions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="KB-Dashboard aktualisieren"
                            Command="{Binding RefreshDashboardCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"
                            ToolTip="KB-Statistiken (Quality, Accuracy, Problemcodes) neu laden"/>
                    <Button Content="Log aktualisieren"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="Aktuelle Log-Eintraege aus der Protokolldatei neu laden"/>
                </StackPanel>
            </ctrl:PageHeader.Actions>
        </ctrl:PageHeader>

        <!-- Wartungs-Tools (Audit-Tab, 2026-05-07) -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- KB-Mirror Health -->
            <Border Grid.Column="0" Margin="0,0,8,0" Padding="12"
                    BorderBrush="{DynamicResource MutedBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Brain-Mirror Health" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="Prueft ob C:\KI_BRAIN nach E:\Brain gespiegelt ist."
                               Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,2,0,8"
                               TextWrapping="Wrap"/>
                    <Button Content="Pruefen"
                            Command="{Binding CheckMirrorHealthCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Padding="16,4"/>
                    <TextBlock Text="{Binding MirrorHealthStatus}" FontWeight="Bold" FontSize="13"
                               Foreground="{Binding MirrorHealthBrush}" Margin="0,8,0,2"/>
                    <TextBlock Text="{Binding MirrorHealthMessage}" TextWrapping="Wrap" FontSize="11"/>
                </StackPanel>
            </Border>

            <!-- Frame-Cleanup -->
            <Border Grid.Column="1" Margin="4,0,4,0" Padding="12"
                    BorderBrush="{DynamicResource MutedBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Frame-Cleanup" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="Loescht verwaiste PNGs unter frames/ die zu keinem TrainingSample mehr gehoeren. Schont Frames juenger als 7 Tage."
                               Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,2,0,8"
                               TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Pruefen (DryRun)"
                                Command="{Binding FrameCleanupDryRunCommand}"
                                Style="{StaticResource SecondaryButton}"
                                IsEnabled="{Binding IsFrameCleanupRunning, Converter={StaticResource InvertedBoolConverter}}"
                                Padding="12,4" Margin="0,0,4,0"/>
                        <Button Content="Loeschen"
                                Command="{Binding FrameCleanupExecuteCommand}"
                                Style="{StaticResource PrimaryButton}"
                                IsEnabled="{Binding IsFrameCleanupRunning, Converter={StaticResource InvertedBoolConverter}}"
                                Padding="12,4"/>
                    </StackPanel>
                    <TextBlock Text="{Binding FrameCleanupResult}" TextWrapping="Wrap"
                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Versions-Pruning -->
            <Border Grid.Column="2" Margin="8,0,0,0" Padding="12"
                    BorderBrush="{DynamicResource MutedBrush}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="KB-Versionen aufraeumen" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="Loescht alte Versions-Snapshots in der Knowledge Base. Behaelt: letzte 20 + alle juenger als 30 Tage."
                               Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,2,0,8"
                               TextWrapping="Wrap"/>
                    <Button Content="Aufraeumen"
                            Command="{Binding VersionsPruneCommand}"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="{Binding IsVersionsPruneRunning, Converter={StaticResource InvertedBoolConverter}}"
                            HorizontalAlignment="Left" Padding="16,4"/>
                    <TextBlock Text="{Binding VersionsPruneResult}" TextWrapping="Wrap"
                               FontFamily="Consolas" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- KB-Dashboard (P1.4 Roadmap, 2026-05-08) -->
        <Border Grid.Row="2" Margin="0,0,0,16" Padding="12"
                BorderBrush="{DynamicResource MutedBrush}" BorderThickness="1" CornerRadius="6">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="KB-Dashboard"
                               FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding DashboardStatus}"
                               Foreground="{DynamicResource MutedBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                </Grid>

                <!-- Stat-Cards: Total Samples, Total Validations, Overall Accuracy, Review-Queue -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,4,0" Padding="10"
                            Background="{DynamicResource AccentSubtleBrush}" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="Samples in KB" FontSize="11"
                                       Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock Text="{Binding TotalSamplesText}"
                                       FontWeight="Bold" FontSize="20"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="4,0,4,0" Padding="10"
                            Background="{DynamicResource AccentSubtleBrush}" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="Validierungen" FontSize="11"
                                       Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock Text="{Binding TotalValidationsText}"
                                       FontWeight="Bold" FontSize="20"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Margin="4,0,4,0" Padding="10"
                            Background="{DynamicResource AccentSubtleBrush}" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="Trefferquote (KI vs Mensch)" FontSize="11"
                                       Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock Text="{Binding OverallAccuracyText}"
                                       FontWeight="Bold" FontSize="20"
                                       Foreground="{Binding OverallAccuracyBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Margin="4,0,0,0" Padding="10"
                            Background="{DynamicResource AccentSubtleBrush}" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="Review-Queue (offen)" FontSize="11"
                                       Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock Text="{Binding ReviewQueueLengthText}"
                                       FontWeight="Bold" FontSize="20"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Quality-Verteilung als horizontale Bar -->
                <TextBlock Text="Quality-Verteilung der KB-Samples"
                           FontWeight="SemiBold" FontSize="12" Margin="0,4,0,4"/>
                <Grid Height="22" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding GreenStarWidth}"/>
                        <ColumnDefinition Width="{Binding YellowStarWidth}"/>
                        <ColumnDefinition Width="{Binding RedStarWidth}"/>
                        <ColumnDefinition Width="{Binding UnknownStarWidth}"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#22C55E"/>
                    <Border Grid.Column="1" Background="#F59E0B"/>
                    <Border Grid.Column="2" Background="#EF4444"/>
                    <Border Grid.Column="3" Background="#94A3B8"/>
                </Grid>
                <TextBlock Text="{Binding QualityDistributionText}"
                           FontSize="11" Foreground="{DynamicResource MutedBrush}"
                           Margin="0,0,0,12"/>

                <!-- Zwei Tabellen nebeneinander: Top-Problemcodes + Unterrepraesentiert -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Top-Problemcodes -->
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Top-Problemcodes (niedrige Trefferquote, ausreichend Stichproben)"
                                   FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                        <DataGrid ItemsSource="{Binding TopProblemCodes}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  MaxHeight="220" CanUserAddRows="False"
                                  RowHeaderWidth="0" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding VsaCode}" Width="80"/>
                                <DataGridTextColumn Header="Samples" Binding="{Binding SampleCount}" Width="70"/>
                                <DataGridTextColumn Header="Validiert" Binding="{Binding ValidationTotal}" Width="70"/>
                                <DataGridTextColumn Header="Trefferquote" Binding="{Binding AccuracyText}" Width="90"/>
                                <DataGridTextColumn Header="Score" Binding="{Binding ProblemScoreText}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <!-- Unterrepraesentierte Codes -->
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Unterrepraesentierte Codes (Long-Tail, &lt; 50 Samples)"
                                   FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                        <DataGrid ItemsSource="{Binding UnderRepresentedCodes}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  MaxHeight="220" CanUserAddRows="False"
                                  RowHeaderWidth="0" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding VsaCode}" Width="80"/>
                                <DataGridTextColumn Header="Samples" Binding="{Binding SampleCount}" Width="70"/>
                                <DataGridTextColumn Header="Validiert" Binding="{Binding ValidationTotal}" Width="70"/>
                                <DataGridTextColumn Header="Trefferquote" Binding="{Binding AccuracyText}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>

                <!-- Review-Export-Button -->
                <Border Margin="0,12,0,0" Padding="10"
                        Background="{DynamicResource AccentSubtleBrush}" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Wochen-Review-Liste"
                                   FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="Erzeugt eine CSV-Datei mit den unsichersten Samples (60% Uncertainty + 40% Diversity nach ActiveLearningSelector). Datei landet im KnowledgeRoot und kann in Excel geoeffnet werden."
                                   FontSize="11" Foreground="{DynamicResource MutedBrush}"
                                   TextWrapping="Wrap" Margin="0,2,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Anzahl:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                            <TextBox Text="{Binding ReviewExportCount, UpdateSourceTrigger=PropertyChanged}"
                                     Width="60" Margin="0,0,12,0" VerticalContentAlignment="Center"/>
                            <Button Content="Review-Liste exportieren"
                                    Command="{Binding ExportReviewListCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    IsEnabled="{Binding IsReviewExportRunning, Converter={StaticResource InvertedBoolConverter}}"
                                    Padding="14,4"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ReviewExportResult}" TextWrapping="Wrap"
                                   FontFamily="Consolas" FontSize="11" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <TextBox Grid.Row="3" Text="{Binding LogTail}" AcceptsReturn="True" IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="11" MinHeight="120"/>
    </Grid>
</UserControl>
