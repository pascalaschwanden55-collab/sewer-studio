<UserControl x:Class="AuswertungPro.Next.UI.Views.Pages.ProjectPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:AuswertungPro.Next.UI.Views.Controls">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Phase 3.3: PageHeader-Control mit Action-Buttons rechts. -->
        <ctrl:PageHeader Title="Projekt"
                         Subtitle="Projekt-Datei verwalten: Neu, Oeffnen, Speichern, Schliessen.">
            <ctrl:PageHeader.Actions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Neues Projekt" Command="{Binding NewCommand}"
                            Style="{StaticResource PrimaryButton}" Padding="16,8"
                            ToolTip="Neues leeres Projekt erstellen und vorheriges schliessen"/>
                    <Button Content="Oeffnen" Command="{Binding OpenCommand}"
                            Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                            ToolTip="Bestehendes Projekt aus JSON-Datei oeffnen"/>
                    <Button Content="Speichern unter" Command="{Binding SaveAsCommand}"
                            Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                            ToolTip="Projekt unter neuem Dateinamen speichern"/>
                    <Button Content="Projekt speichern" Command="{Binding SaveCommand}"
                            Margin="16,0,8,0" Style="{StaticResource SecondaryButton}"
                            ToolTip="Aktuelle Projektdaten in die vorhandene Datei speichern"/>
                    <Button Content="Programm schliessen" Click="CloseButton_Click"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="SewerStudio beenden und alle offenen Fenster schliessen"/>
                </StackPanel>
            </ctrl:PageHeader.Actions>
        </ctrl:PageHeader>

        <Border Grid.Row="1" Style="{StaticResource Card}" Background="{StaticResource CardBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Projekt-Infos" FontSize="{StaticResource TypeH4}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Name" Margin="0,12,0,4" Foreground="{StaticResource MutedBrush}"/>
                    <TextBox Text="{Binding Project.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Beschreibung" Margin="0,12,0,4" Foreground="{StaticResource MutedBrush}"/>
                    <TextBox Text="{Binding Project.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120"/>

                    <TextBlock Text="Projektdaten" Margin="0,16,0,6" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Auftraggeber" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,4"/>
                        <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Project.Metadata[Auftraggeber], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Auftrag Nr." Foreground="{StaticResource MutedBrush}" Margin="0,8,0,4"/>
                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Project.Metadata[AuftragNr], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Gemeinde" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,4"/>
                        <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding Project.Metadata[Gemeinde], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Zone" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,4"/>
                        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding Project.Metadata[Zone], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Strasse" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,4"/>
                        <TextBox Grid.Row="5" Grid.Column="0" Text="{Binding Project.Metadata[Strasse], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="Bearbeiter" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,4"/>
                        <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding Project.Metadata[Bearbeiter], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Inspektionsdatum" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,4"/>
                        <TextBox Grid.Row="7" Grid.Column="0" Text="{Binding Project.Metadata[InspektionsDatum], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="6" Grid.Column="2" Text="Firma" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,4"/>
                        <TextBox Grid.Row="7" Grid.Column="2" Text="{Binding Project.Metadata[FirmaName], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- Sanieren & Eigentuemer entfernt -->

                    <TextBlock Text="Firma &amp; Kontakt" Margin="0,12,0,6" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Adresse" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,4"/>
                    <TextBox Text="{Binding Project.Metadata[FirmaAdresse], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Telefon" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,4"/>
                    <TextBox Text="{Binding Project.Metadata[FirmaTelefon], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="E-Mail" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,4"/>
                    <TextBox Text="{Binding Project.Metadata[FirmaEmail], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="{Binding Project.Data.Count, StringFormat=Records: {0}}" Margin="0,12,0,0" Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
