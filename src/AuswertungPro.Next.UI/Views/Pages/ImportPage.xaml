<UserControl x:Class="AuswertungPro.Next.UI.Views.Pages.ImportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <!-- Import Toolbar Card -->
            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Padding="6,4" CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding ImportPdfCommand}"
                            Style="{StaticResource ToolbarButtonAccent}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Import PDF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="4,4"/>

                    <Button Click="DropdownButton_Click"
                            Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"
                            ToolTip="XTF/M150/MDB, WinCan, IBAK, KINS importieren">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource NeonGreenBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Weitere Quellen" VerticalAlignment="Center"/>
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="9" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Command="{Binding ImportXtfCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="XTF / M150 / MDB" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding ImportWinCanCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="WinCan-Projekte" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding ImportIbakCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="IBAK-Projekte" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding ImportKinsCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="KINS-Projekte" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="4,4"/>

                    <Button Command="{Binding ExportImportSummaryCommand}"
                            Style="{StaticResource ToolbarButton}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Import-Report" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding OpenLastReportCommand}"
                            Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"
                            ToolTip="Letzten Import-Bericht oeffnen">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource InfoBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Letzter Bericht" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding OpenReportFolderCommand}"
                            Style="{StaticResource ToolbarButton}"
                            ToolTip="Bericht-Ordner oeffnen">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Berichte" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <CheckBox Content="Nur fehlende Felder ergaenzen (vorhandene Daten nicht ueberschreiben)"
                          IsChecked="{Binding FillMissingOnly}"
                          Foreground="{StaticResource TextBrush}"
                          ToolTip="Beim Re-Import werden nur leere Felder aufgefuellt. Bereits vorhandene Werte bleiben unveraendert."/>

                <CheckBox Content="Erst Vorschau anzeigen"
                          IsChecked="{Binding ShowPreviewFirst}"
                          Foreground="{StaticResource TextBrush}"
                          Margin="16,0,0,0"
                          ToolTip="Fuehrt einen Dry-Run durch und zeigt die erwarteten Aenderungen, bevor der eigentliche Import startet."/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="8" Margin="0,0,0,8" CornerRadius="8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsImportInProgress}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <DockPanel Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right" Command="{Binding CancelImportCommand}"
                            Content="Abbrechen" Margin="8,0,0,0" Padding="12,2"
                            IsEnabled="{Binding CanCancel}"
                            Style="{StaticResource ToolbarButton}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource InfoBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ImportPhase}" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ImportProgress}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
                <ProgressBar Height="6" Maximum="100" Value="{Binding ImportProgressPercent}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Zusammenfassung" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox Text="{Binding SummaryText}" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     MinHeight="120"/>
            <Expander Header="Details" Margin="0,8,0,0">
                <TextBox Text="{Binding DetailsText}" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         MinHeight="160"/>
            </Expander>
        </StackPanel>
    </Grid>
</UserControl>
