<UserControl x:Class="AuswertungPro.Next.UI.Views.Pages.VsaPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- VSA-Bewertung Card -->
        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="10" Padding="0" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Accent Strip -->
                <Border Background="{StaticResource NeonCyanBrush}" CornerRadius="10,0,0,10"/>

                <StackPanel Grid.Column="1" Margin="16,14">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="&#xE8EF;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="VSA-Bewertung" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Berechnet die VSA-Zustandsbewertung für alle Haltungen und Schächte basierend auf den erfassten Schadencodes und dem Regelwerk (SN EN 13508-2)."
                               TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                               Margin="0,0,0,12"/>
                    <Button Command="{Binding RunCommand}" Style="{StaticResource ActionCardButton}" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="VSA-Bewertung starten" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Ergebnis -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="14" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Ergebnis" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                </StackPanel>
                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Hinweis -->
        <Border Grid.Row="2" VerticalAlignment="Top"
                Background="{StaticResource HeaderBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="{StaticResource WarningBrush}" VerticalAlignment="Top" Margin="0,0,8,0"/>
                <TextBlock Text="Tipp: Für echte VSA-Klassifizierung müssen die Mapping-JSONs (Anhang C/D) vollständig gepflegt sein."
                           TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
