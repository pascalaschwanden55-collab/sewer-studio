<UserControl x:Class="AuswertungPro.Next.UI.Views.Pages.OverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AuswertungPro.Next.UI.Views.Pages"
             xmlns:ctrl="clr-namespace:AuswertungPro.Next.UI.Views.Controls"
             AllowDrop="True" Drop="OverviewPage_Drop" DragOver="OverviewPage_DragOver">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER (Phase 3.3: PageHeader-Control mit Action-Buttons rechts) ═══ -->
        <ctrl:PageHeader Title="Projektuebersicht"
                         Subtitle="Projekt oeffnen, erstellen oder fortsetzen">
            <ctrl:PageHeader.Actions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Neues Projekt" Command="{Binding NewCommand}"
                            Style="{StaticResource PrimaryButton}" Padding="16,8"
                            ToolTip="Neues leeres Projekt erstellen und Speicherort waehlen"/>
                    <Button Content="Projekt oeffnen" Command="{Binding OpenCommand}"
                            Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                            ToolTip="Vorhandene Projektdatei (.json) oeffnen"/>
                    <Button Content="Letztes Projekt fortsetzen" Command="{Binding ContinueCommand}"
                            Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                            ToolTip="Zuletzt bearbeitetes Projekt wieder oeffnen und weiterarbeiten"/>
                    <Button Content="Aktualisieren" Command="{Binding RefreshCommand}"
                            Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                            ToolTip="Projektliste und Statistiken neu laden"/>
                </StackPanel>
            </ctrl:PageHeader.Actions>
        </ctrl:PageHeader>

        <!-- ═══ HAUPTBEREICH ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LINKS: Projektliste ── -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Titel -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Alle Projekte" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <Border Background="{DynamicResource AccentSubtleBrush}" CornerRadius="10"
                                Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ProjectEntries.Count}" FontSize="{StaticResource TypeCaption}" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Suchfeld -->
                    <Border Grid.Row="1" CornerRadius="6" BorderThickness="1"
                            BorderBrush="{DynamicResource BorderLightBrush}"
                            Background="{DynamicResource BgLightBrush}" Margin="0,0,0,10">
                        <Grid>
                            <TextBlock Text="Projekt suchen..." FontSize="{StaticResource TypeSmall}"
                                       Foreground="{DynamicResource MutedBrush}"
                                       VerticalAlignment="Center" Margin="10,0"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding FilterText, Converter={x:Static local:StringToVisibilityConverter.Instance}, ConverterParameter=invert}"/>
                            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="{StaticResource TypeSmall}" Padding="8,6"
                                     Foreground="{DynamicResource TextBrush}"/>
                        </Grid>
                    </Border>

                    <!-- Projektliste mit Karten -->
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding ProjectEntries}"
                             SelectedItem="{Binding SelectedProjectEntry, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="ProjectListBox_MouseDoubleClick">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" CornerRadius="8"
                                                    BorderThickness="1" Padding="0"
                                                    BorderBrush="{DynamicResource BorderLightBrush}"
                                                    Background="{DynamicResource CardBrush}"
                                                    Cursor="Hand">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background"
                                                            Value="{DynamicResource AccentSubtleBrush}"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush"
                                                            Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background"
                                                            Value="{DynamicResource AccentSubtleBrush}"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush"
                                                            Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Farbbalken links -->
                                    <Border Grid.Column="0" CornerRadius="4,0,0,4"
                                            Width="5" HorizontalAlignment="Stretch">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLastProject}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <!-- Inhalt -->
                                    <StackPanel Grid.Column="1" Margin="10,8,10,8">
                                        <DockPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="{StaticResource TypeBody}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <!-- Badge: Haltungen -->
                                            <Border DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                    Background="{DynamicResource AccentSubtleBrush}"
                                                    CornerRadius="8" Padding="6,2" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding StatsText}" FontSize="{StaticResource TypeMicro}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                        </DockPanel>
                                        <TextBlock FontSize="{StaticResource TypeCaption}" Foreground="{DynamicResource MutedBrush}" Margin="0,3,0,0">
                                            <Run Text="{Binding ModifiedAtDisplay, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding FolderName, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Buttons unten -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Oeffnen" Command="{Binding OpenSelectedCommand}"
                                Style="{StaticResource PrimaryButton}" Padding="14,6"
                                ToolTip="Ausgewaehltes Projekt aus der Liste oeffnen"/>
                        <Button Content="Loeschen" Command="{Binding DeleteSelectedCommand}"
                                Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                                Foreground="{DynamicResource DangerBrush}"
                                ToolTip="Ausgewaehltes Projekt dauerhaft loeschen (nicht umkehrbar)"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── RECHTS: Projektinfo ── -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Projektinfo" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>

                    <!-- Info-Karte: Aktuelles Projekt -->
                    <Border CornerRadius="8" BorderThickness="1"
                            BorderBrush="{DynamicResource BorderLightBrush}"
                            Background="{DynamicResource BgLightBrush}" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{Binding Project.Name}" FontSize="{StaticResource TypeH4}" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <Border DockPanel.Dock="Right" HorizontalAlignment="Right"
                                        CornerRadius="6" Padding="8,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProjectStatus}" Value="Projekt noch nicht gespeichert">
                                                    <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding ProjectStatus}" FontSize="{StaticResource TypeMicro}" FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>
                            </DockPanel>
                            <TextBlock Text="{Binding Project.Description}" TextWrapping="Wrap"
                                       FontSize="{StaticResource TypeSmall}" Foreground="{DynamicResource MutedBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock FontSize="{StaticResource TypeCaption}" Foreground="{DynamicResource MutedBrush}">
                                <Run Text="{Binding LastProjectPath, TargetNullValue=-, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Statistiken -->
                    <TextBlock Text="Statistiken" FontSize="{StaticResource TypeBody}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Haltungen -->
                        <Border Grid.Column="0" CornerRadius="8" Padding="12,10"
                                Background="{DynamicResource AccentSubtleBrush}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Project.Data.Count, StringFormat={}{0}}"
                                           FontSize="{StaticResource TypeH2}" FontWeight="Bold" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock Text="Haltungen" FontSize="{StaticResource TypeMicro}" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Gespeichert -->
                        <Border Grid.Column="2" CornerRadius="8" Padding="12,10"
                                Background="{DynamicResource BgLightBrush}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Project.ModifiedAtUtc, StringFormat={}{0:dd.MM.yyyy}}"
                                           FontSize="{StaticResource TypeBodyLarge}" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Zuletzt gespeichert" FontSize="{StaticResource TypeMicro}" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Version -->
                        <Border Grid.Column="4" CornerRadius="8" Padding="12,10"
                                Background="{DynamicResource BgLightBrush}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Project.AppVersion, TargetNullValue=—}"
                                           FontSize="{StaticResource TypeBodyLarge}" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="App-Version" FontSize="{StaticResource TypeMicro}" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource MutedBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Schnellaktionen -->
                    <TextBlock Text="Schnellaktionen" FontSize="{StaticResource TypeBody}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,4,0,8"/>
                    <WrapPanel>
                        <Button Content="Import starten" Margin="0,0,6,6"
                                Command="{Binding ContinueCommand}" Style="{StaticResource SecondaryButton}"
                                ToolTip="Projekt oeffnen und direkt zur Import-Seite wechseln"/>
                    </WrapPanel>

                    <!-- Drag & Drop Hinweis -->
                    <Border CornerRadius="8" Padding="12" Margin="0,12,0,0"
                            BorderThickness="2" BorderBrush="{DynamicResource BorderLightBrush}"
                            Background="Transparent">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderLightBrush}"/>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Projekt-Datei hierher ziehen" FontSize="{StaticResource TypeSmall}"
                                       HorizontalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock Text=".json Datei oder Ordner" FontSize="{StaticResource TypeMicro}"
                                       HorizontalAlignment="Center" Foreground="{DynamicResource MutedBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
