                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="20. KI-Konfiguration und Tastaturkuerzel" FontSize="15" FontWeight="Bold"
