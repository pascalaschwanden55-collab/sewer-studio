                        Click="OpenSanierungRules_Click" HorizontalAlignment="Left"
                        Padding="14,6" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- ── 16b. Marktdaten-Import (Submission Buerglen 2026) ─────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="16b. Marktdaten-Import" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
