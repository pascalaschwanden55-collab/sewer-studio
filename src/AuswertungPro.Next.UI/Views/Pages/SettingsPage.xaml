                <TextBlock Text="11. Knowledge Base (Wissensbank)" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource TypeSmall}" LineHeight="20">
                    SQLite mit Vektor-Embeddings (nomic-embed-text) fuer semantische Suche.
                    RAG: Aehnliche fruehere Faelle als Kontext fuer die KI-Bewertung.
                    Diagnostik, Deduplizierung, Anreicherung und Backup als ZIP.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 12. Selbstlernendes System ─────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="12. Selbstlernendes System" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,2">
                    Auto-Approval: Gruene Ampel wird automatisch in die KB aufgenommen.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,2">
                    Review-Queue: Gelb/Rot zur manuellen Pruefung. Active Learning waehlt unsicherste Samples.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,0">
                    Feedback-Ingestion: Nutzerkorrekturen (Accept/Edit/Reject) werden als Training erfasst.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 13. Training Center ────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="13. Training Center" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,2">
                    Selbsttraining: Ground-Truth-Samples aus Inspektionsergebnissen und PDF-Protokollen.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,2">
                    Video-Blindtest: KI analysiert Videos ohne Vorwissen, Vergleich mit Protokoll.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,2">
                    Batch-Nachtbetrieb: Automatisierte Verarbeitung grosser Videomengen ueber Nacht.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,2">
