<UserControl x:Class="AuswertungPro.Next.UI.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="True"
                  Padding="0,0,8,0">
        <StackPanel>
            <TextBlock Text="Einstellungen" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <CheckBox Content="Diagnose aktiv (Fehlercodes anzeigen)" IsChecked="{Binding EnableDiagnostics}"/>

        <TextBlock Text="pdftotext.exe Pfad" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <DockPanel>
            <TextBox Text="{Binding PdfToTextPath}" MinWidth="400" />
            <Button Content="..." Command="{Binding BrowsePdfToTextCommand}" Margin="8,0,0,0" Width="44"/>
        </DockPanel>

        <TextBlock Text="Projektpfad (*.json)" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <DockPanel>
            <TextBox Text="{Binding ProjectPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="400" />
            <Button Content="..." Command="{Binding BrowseProjectPathCommand}" Margin="8,0,0,0" Width="44"/>
        </DockPanel>

        <TextBlock Text="Video-Ordner (Haltungen)" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <DockPanel>
            <TextBox Text="{Binding VideoFolder}" MinWidth="400" />
            <Button Content="..." Command="{Binding BrowseVideoFolderCommand}" Margin="8,0,0,0" Width="44"/>
        </DockPanel>

        <TextBlock Text="Automatisches Speichern" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <ComboBox ItemsSource="{Binding AutoSaveModeOptions}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Label"
                  SelectedValue="{Binding DataAutoSaveMode, Mode=TwoWay}"
                  MinWidth="260"/>

        <TextBlock Text="Sicherheit" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <StackPanel>
            <CheckBox Content="Wiederherstellungspunkte vor dem Speichern erstellen" IsChecked="{Binding EnableRestorePoints}"/>
            <DockPanel Margin="0,6,0,0">
                <TextBox Text="{Binding RestorePointsFolderPath}" MinWidth="400" IsReadOnly="True" />
                <Button Content="Wiederherstellung oeffnen" Command="{Binding OpenRestorePointsFolderCommand}" Margin="8,0,0,0" Width="180"/>
            </DockPanel>
        </StackPanel>

        <TextBlock Text="Video-Player" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <StackPanel>
            <CheckBox Content="Hardware-Decoding aktiv" IsChecked="{Binding VideoHwDecoding}"/>
            <CheckBox Content="Drop late frames" IsChecked="{Binding VideoDropLateFrames}" Margin="0,4,0,0"/>
            <CheckBox Content="Skip frames" IsChecked="{Binding VideoSkipFrames}" Margin="0,4,0,0"/>

            <WrapPanel Margin="0,8,0,0">
                <TextBlock Text="Video Output:" VerticalAlignment="Center" Width="120"/>
                <ComboBox Width="220"
                          ItemsSource="{Binding VideoOutputOptions}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Label"
                          SelectedValue="{Binding VideoOutput, Mode=TwoWay}"/>
            </WrapPanel>

            <WrapPanel Margin="0,8,0,0">
                <TextBlock Text="File Caching:" VerticalAlignment="Center" Width="120"/>
                <ComboBox Width="140"
                          ItemsSource="{Binding VideoCacheOptions}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Label"
                          SelectedValue="{Binding VideoFileCachingMs, Mode=TwoWay}"/>

                <TextBlock Text="Network Caching:" VerticalAlignment="Center" Width="130" Margin="16,0,0,0"/>
                <ComboBox Width="140"
                          ItemsSource="{Binding VideoCacheOptions}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Label"
                          SelectedValue="{Binding VideoNetworkCachingMs, Mode=TwoWay}"/>
            </WrapPanel>

            <WrapPanel Margin="0,8,0,0">
                <TextBlock Text="Codec Threads:" VerticalAlignment="Center" Width="120"/>
                <ComboBox Width="140"
                          ItemsSource="{Binding VideoCodecThreadOptions}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Label"
                          SelectedValue="{Binding VideoCodecThreads, Mode=TwoWay}"/>
            </WrapPanel>
        </StackPanel>

        <TextBlock Text="Datenordner (Settings/Logs)" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <DockPanel>
            <TextBox Text="{Binding DataFolderPath}" MinWidth="400" IsReadOnly="True" />
            <Button Content="Ordner oeffnen" Command="{Binding OpenDataFolderCommand}" Margin="8,0,0,0" Width="120"/>
        </DockPanel>

        <TextBlock Text="Logs" Margin="0,10,0,6" Foreground="{StaticResource MutedBrush}"/>
        <DockPanel>
            <TextBox Text="{Binding LogsFolderPath}" MinWidth="400" IsReadOnly="True" />
            <Button Content="Logs oeffnen" Command="{Binding OpenLogsFolderCommand}" Margin="8,0,0,0" Width="120"/>
        </DockPanel>

        <TextBlock Text="KI-Wissen Backup" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <TextBlock Text="Exportiert alle KI-Lerndaten, Trainingssamples, Einstellungen und Frames als ZIP. Fuer Backup oder PC-Migration."
                   TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,8"/>
        <StackPanel Orientation="Horizontal">
            <Button Content="KI-Wissen exportieren" Command="{Binding ExportBackupCommand}" Width="180"/>
            <Button Content="KI-Wissen importieren" Command="{Binding ImportBackupCommand}" Margin="8,0,0,0" Width="180"/>
        </StackPanel>
        <TextBlock Text="{Binding BackupStatusText}" Margin="0,6,0,0"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>

            <Button Content="Speichern" Command="{Binding SaveCommand}" Margin="0,18,0,0" Width="160"/>

        <!-- ═══════════════════════════════════════════════════════════════════
             PROGRAMM-ANLEITUNG
             ═══════════════════════════════════════════════════════════════════ -->
        <Border Margin="0,32,0,0" Padding="0,0,0,4"
                BorderThickness="0,0,0,2" BorderBrush="{StaticResource NeonCyanBrush}">
            <TextBlock Text="Programm-Anleitung  SewerStudio"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource NeonCyanBrush}"/>
        </Border>

        <TextBlock Text="Vollstaendige Dokumentation aller Funktionen, KI-Module und Workflows."
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,20" FontSize="12"/>

        <!-- ── 1. Uebersicht ──────────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="1. Programmueberblick" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="12" LineHeight="20">
                    SewerStudio ist eine professionelle Anwendung fuer die Kanalinspektion und
                    Zustandsbewertung nach dem Schweizer Standard SN EN 13508-2 (bzw. DIN EN 13508-2).
                    Die Software vereint Datenerfassung, Videoanalyse, KI-gestuetzte Schadenserkennung,
                    VSA-Zustandsbewertung und Sanierungskostenberechnung in einer einzigen Plattform.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="12" LineHeight="20" Margin="0,8,0,0">
                    Der typische Arbeitsablauf: Projekt erstellen, Inspektionsdaten importieren (PDF/XTF/WinCan/IBAK),
                    Videos verknuepfen, KI-Analyse durchfuehren, VSA-Bewertung berechnen, Sanierungsmassnahmen
                    vorschlagen und Ergebnisse als Excel/PDF exportieren.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 2. Seitennavigation ────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="2. Seiten und Navigation" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>

                <TextBlock Text="Uebersicht" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Startseite mit Projektverwaltung. Zeigt alle gespeicherten Projekte, ermoeglicht das Erstellen
                    neuer Projekte und das Oeffnen vorhandener *.json-Projektdateien. Das zuletzt geoeffnete Projekt
                    kann per Schnellzugriff fortgesetzt werden.
                </TextBlock>

                <TextBlock Text="Projekt" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Metadaten des aktuellen Projekts: Name, Beschreibung, Auftraggeber, Gemeinde, Inspektionsdatum,
                    Firma und Kontaktperson. Diese Angaben erscheinen auf allen exportierten Berichten und Protokollen.
                </TextBlock>

                <TextBlock Text="Haltungen" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Zentrale Datenseite fuer alle Kanalsegmente (Haltungen). Bearbeitbares DataGrid mit Suche,
                    Zoom, Zeilenhoehe, Spaltenausrichtung und Multi-Monitor-Support (Abdocken auf zweiten Bildschirm).
                    Kontextmenue bietet Zugriff auf Protokolle, Videoanalyse, Sanierungsmassnahmen und Kostenrechner.
                    Toolbar-Dropdowns: KI-Tools (Protokoll, KI-Status, Videoanalyse, KI-Sanierung),
                    Sanierungsmassnahmen (Kostenrechner, Vorschlag aus Schadenscodes, Alle Massnahmen vorschlagen)
                    und Medien suchen (automatische Video/PDF-Verknuepfung).
                </TextBlock>

                <TextBlock Text="Schaechte" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Verwaltung der Schacht-Inspektionspunkte. Gleiche Funktionen wie Haltungen: Hinzufuegen,
                    Loeschen, Verschieben, Suchen, Spaltenbearbeitung und Detailansicht.
                    Unterstuetzt PDF-Protokollgenerierung und Foto-Verwaltung.
                </TextBlock>

                <TextBlock Text="Import" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Importiert Inspektionsdaten aus verschiedenen Quellen:
                    PDF (OCR via pdftotext oder Formularfelder), XTF/M150/MDB (Austauschformat fuer Kanalinspektion),
                    WinCan (TV-Inspektionssoftware), IBAK (Roboter-Inspektionssystem) und KINS (Kombinationsformat).
                    Option "Nur fehlende Felder auffuellen" ergaenzt Daten ohne vorhandene zu ueberschreiben.
                </TextBlock>

                <TextBlock Text="Export" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Exportiert Haltungen und Schaechte als Excel-Dateien mit konfigurierbaren Vorlagen.
                    Verteilungsfunktion sortiert exportierte Dateien in Ordnerstrukturen
                    nach Haltung, Schacht oder Pruefstatus.
                </TextBlock>

                <TextBlock Text="Medienkonflikte" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Zeigt mehrdeutige oder fehlende Zuordnungen zwischen Videos/PDFs und Haltungen an.
                    Ermoeglicht das manuelle Aufloesen von Konflikten bei der automatischen Medienverknuepfung.
                </TextBlock>

                <TextBlock Text="Druckcenter" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Filterbare Druckansicht mit Kosten-, Eigentuemer- und Positionszusammenfassung.
                    Komplexe Filteroptionen (Suche, Eigentuemer, Material, Status, Jahr) mit
                    Statistiken zu Rehabilitationsquoten und Kostenverteilung. Export als PDF moeglich.
                </TextBlock>

                <TextBlock Text="VSA" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Berechnet die VSA-Zustandsbewertung (Klassen 0-4) fuer alle Haltungen und Schaechte
                    basierend auf den erfassten Schadencodes. Verwendet den Klassifikationskatalog nach
                    SN EN 13508-2 mit separaten Regeln fuer Kanaele und Schaechte.
                </TextBlock>

                <TextBlock Text="Diagnose" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Live-Protokoll mit Anwendungsmeldungen, Fehlern und KI-Diagnosen. Nuetzlich fuer
                    Fehlersuche und Ueberwachung der KI-Pipeline-Ausfuehrung.
                </TextBlock>

                <TextBlock Text="Einstellungen" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                    Diese Seite. Konfiguration aller Anwendungsparameter: Dateipfade, Autospeicherung,
                    Wiederherstellungspunkte, Video-Player-Tuning und Datenordner.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 3. Fenster und Dialoge ─────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="3. Fenster und Dialoge" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>

                <TextBlock Text="Videoplayer" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    VLC-basierter Player fuer Inspektionsvideos. Unterstuetzt variable Geschwindigkeit (0.5x-8x),
                    Live-Scrubbing (Schieberegler ziehen zeigt Bild in Echtzeit), Tastatursteuerung
                    (Leertaste=Pause, Pfeile=+/-5s, +/-=Geschwindigkeit) und Schadenscode-Marker auf der Zeitleiste.
                    Klick auf einen Code-Marker springt direkt zur Schadenstelle im Video.
                </TextBlock>

                <TextBlock Text="Sanierungsmassnahmen" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Vereinheitlichtes Fenster fuer Kostenberechnung und KI-Optimierung.
                    Linkes Panel: Haltungskontext (DN, Material, Laenge, Zustandsklasse), regelbasierte
                    Empfehlung, KI-Optimierung mit Konfidenz und Kostenband, Risikobewertung.
                    Rechtes Panel: Vollstaendiger Kostenrechner mit 5-Spalten-Layout (Massnahmen, Kalkulation,
                    Katalogpositionen). Drag-and-Drop von Katalogpositionen in Massnahmen-Bloecke.
                    Footer: Netto/MWST/Total-Summen, Uebernehmen, PDF-Export, Speichern.
                </TextBlock>

                <TextBlock Text="Videoanalyse-Pipeline (KI)" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Orchestriert die Multi-Model KI-Pipeline zur automatischen Schadenserkennung in Videos.
                    Zeigt Fortschritt der einzelnen Phasen (Frame-Extraktion, YOLO-Detektion, DINO-Beschreibung,
                    SAM-Segmentierung, Qwen Vision-LLM), detektierte Schaeden mit Konfidenzwerten und
                    generiert automatisch VSA-konforme Schadencodes. Quality-Gate filtert unsichere Ergebnisse.
                </TextBlock>

                <TextBlock Text="Medien-Suchprogramm" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Batch-Suche fuer Videos und PDFs mit automatischer Verknuepfung zu Haltungen.
                    Durchsucht rekursiv Ordner, erkennt Haltungsnamen in Dateinamen und verknuepft
                    gefundene Medien. Filtermodus: Gefunden, Mehrdeutig, Nicht gefunden.
                </TextBlock>

                <TextBlock Text="Training Center" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Verwaltung der KI-Trainingsdaten. Scannt PDF/Video-Ordner, generiert Ground-Truth-Samples
                    aus bestehenden Inspektionsergebnissen, fuehrt Batch-Import durch und indexiert die
                    Knowledge Base mit Embeddings. Auto-Approval-Funktion fuer hochkonfidente Ergebnisse.
                </TextBlock>

                <TextBlock Text="Beobachtungen" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Detailansicht fuer Inspektionsergebnisse einer Haltung mit Foto-Galerie (bis 3 Fotos),
                    Beobachtungsliste und Kontext-Informationen. Direkter Zugang zur Bearbeitung und
                    Verwaltung von Schadenfeststellungen.
                </TextBlock>

                <TextBlock Text="Haltungsdetails" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Kompakte Detailansicht einer einzelnen Haltung mit allen Feldern gruppiert nach
                    Kategorie (Stammdaten, Inspektion, VSA, Kosten). Direktlink zu Sanierungsmassnahmen.
                </TextBlock>

                <TextBlock Text="Beobachtungskatalog" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Nachschlagewerk aller definierten Schadencodes mit VSA-Klassifizierung.
                    Suchfunktion, Filterung nach Kategorien und Detailansicht mit Beschreibung,
                    Quantifizierung und Zustandsklassen-Auswirkung.
                </TextBlock>

                <TextBlock Text="Abgedocktes DataGrid" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                    Separates Fenster fuer das DataGrid bei Multi-Monitor-Setups. Das Grid wird aus der
                    Hauptansicht herausgeloest und kann auf einem zweiten Bildschirm platziert werden.
                    Alle Bearbeitungsfunktionen bleiben erhalten.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 4. KI-Module ───────────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="4. KI-Module und Pipeline" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>

                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="12" LineHeight="20" Margin="0,0,0,12">
                    SewerStudio verwendet eine Multi-Model KI-Pipeline, die vollstaendig lokal laeuft
                    (keine Cloud-Anbindung noetig). Die KI-Funktionen erfordern einen laufenden
                    Ollama-Service und optional den Python-Sidecar-Service fuer die Vision-Pipeline.
                </TextBlock>

                <TextBlock Text="4.1 Multi-Model Vision-Pipeline" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4">
                    Die Pipeline verarbeitet Inspektionsvideos in mehreren Stufen:
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2">
                    1. Frame-Extraktion: FFmpeg extrahiert Einzelbilder aus dem Video in konfigurierbaren Intervallen.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2">
                    2. YOLO-Detektion: Erkennt und lokalisiert Schaeden in jedem Frame (Bounding Boxes).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2">
                    3. DINO-Beschreibung: Beschreibungsbasierte Erkennung mit natuerlichsprachlichen Prompts
                    (z.B. "Riss", "Wurzeleinwuchs", "Rohrbruch") fuer praezisere Klassifikation.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2">
                    4. SAM-Segmentierung: Pixel-genaue Segmentierung der erkannten Schaeden fuer
                    Flaechenberechnung und Quantifizierung.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2">
                    5. Qwen Vision-LLM: Multimodales Sprachmodell bewertet jeden Befund im Kontext
                    (Material, Uhrzeit, Position) und ordnet VSA-konforme Schadencodes zu.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,10">
                    6. Quality-Gate: Kalman-Filter-basierte Fusion aller Modellergebnisse mit
                    Unsicherheitsschaetzung und automatischer Filterung unplausibler Detektionen.
                </TextBlock>

                <TextBlock Text="4.2 Ollama-Integration (Lokales LLM)" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Ollama laeuft als lokaler Service und stellt Vision- und Text-Modelle bereit.
                    Konfigurierbar ueber Umgebungsvariablen: SEWERSTUDIO_AI_ENABLED (0/1),
                    SEWERSTUDIO_OLLAMA_URL (Standard: http://localhost:11434), SEWERSTUDIO_AI_VISION_MODEL,
                    SEWERSTUDIO_AI_TEXT_MODEL und SEWERSTUDIO_AI_EMBED_MODEL. Timeout und Keep-Alive sind einstellbar.
                    Wird verwendet fuer: Protokolltexte, Schadensbeschreibungen, Code-Zuordnung und Embeddings.
                </TextBlock>

                <TextBlock Text="4.3 Knowledge Base (Wissensbank)" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    SQLite-basierter Speicher mit Vektor-Embeddings fuer semantische Suche.
                    Indexiert Trainingsbeispiele, Best Practices und historische Inspektionsergebnisse.
                    Retrieval-Augmented Generation (RAG): Bei neuen Inspektionen werden aehnliche
                    frueherer Faelle als Kontext fuer die KI-Bewertung herangezogen.
                    Der Knowledge-Base-Manager fuehrt Batch-Indexing und Wartung durch.
                </TextBlock>

                <TextBlock Text="4.4 Quality-Gate (Qualitaetssicherung)" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Mehrstufige Qualitaetspruefung der KI-Ergebnisse:
                    Evidence-Fusion kombiniert Konfidenzwerte aller Modelle mittels Kalman-Filter.
                    Monte-Carlo-Dropout schaetzt Unsicherheit durch mehrfache Inferenz.
                    Adaptive Gewichtung lernt automatisch, welchen Modellen bei welchen Schadenstypen
                    am meisten vertraut werden kann. Kalibrierungsmetriken ueberwachen die Zuverlaessigkeit.
                    Ergebnisse werden mit Ampelsystem (gruen/gelb/rot) klassifiziert.
                </TextBlock>

                <TextBlock Text="4.5 Selbstlernende Pipeline" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Auto-Approval: Hochkonfidente Ergebnisse (gruene Ampel) werden automatisch validiert
                    und in die Knowledge Base aufgenommen.
                    Review-Queue: Unsichere Ergebnisse (gelb/rot) werden zur manuellen Pruefung vorgelegt.
                    Feedback-Ingestion: Nutzerkorrekturen werden als Trainingsbeispiele erfasst.
                    KB-Quality: Automatische Bereinigung und Validierung der Wissensbank-Eintraege.
                </TextBlock>

                <TextBlock Text="4.6 KI-Sanierungsoptimierung" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10">
                    Kombiniert regelbasierte und KI-gestuetzte Empfehlungen fuer Sanierungsmassnahmen.
                    Regelbasiert: Ableitung aus Schadenscodes, Zustandsklasse, Material und DN.
                    KI-Optimierung: Lokales LLM bewertet Kontext und empfiehlt kostenoptimale Massnahmen
                    mit Konfidenzwert und Kostenband (Min/Erwartet/Max).
                    Validierung: Jeder KI-Vorschlag wird gegen VSA-Regelwerk geprueft.
                    Fallback: Bei Regelverstoessen wird der KI-Vorschlag verworfen und die
                    regelbasierte Empfehlung verwendet.
                </TextBlock>

                <TextBlock Text="4.7 Monitoring und Modellverwaltung" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                    Accuracy-Dashboard: Echtzeit-Metriken fuer die Modell-Performance.
                    Konfidenzverteilung: Histogramm der Vorhersage-Konfidenzwerte zur Drift-Erkennung.
                    Modell-Registry: Versionierung und Tracking aller eingesetzten KI-Modelle.
                    Pipeline-Telemetrie: Latenz, Durchsatz und Ressourcenverbrauch der KI-Pipeline.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 5. Import-Formate ──────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="5. Unterstuetzte Import-Formate" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>

                <TextBlock Text="PDF-Import" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8">
                    Inspektionsprotokolle aus PDF-Dateien. Verwendet pdftotext fuer OCR-Extraktion
                    oder liest strukturierte Formularfelder direkt. Automatisches Feldmapping erkennt
                    Haltungsnamen, DN, Material, Laenge und Schadencodes aus dem PDF-Text.
                </TextBlock>

                <TextBlock Text="XTF / M150 / MDB" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8">
                    Standard-Austauschformat fuer Kanalinspektion (eXtensible Transport Format).
                    Unterstuetzt auch Legacy-Formate: M150-Standard und Microsoft Access MDB-Datenbanken
                    aelterer Inspektionssysteme.
                </TextBlock>

                <TextBlock Text="WinCan" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8">
                    Import kompletter WinCan-Projekte (Windows-basiertes TV-Inspektionssystem)
                    mit allen Haltungen, Schaechten, Schadencodes und Medienverknuepfungen.
                </TextBlock>

                <TextBlock Text="IBAK" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8">
                    Import von IBAK-Projekten (deutsches Roboter-Inspektionssystem) mit
                    strukturierten Exporten inklusive Schadensdokumentation.
                </TextBlock>

                <TextBlock Text="KINS" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8">
                    Kombinationsformat das WinCan- und IBAK-Import-Services zusammenfuehrt.
                </TextBlock>

                <TextBlock Text="Merge-Engine" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                    Alle Importformate verwenden die gleiche Merge-Engine: Importierte Daten werden
                    intelligent mit lokalen Daten zusammengefuehrt. Option "Nur fehlende Felder auffuellen"
                    ergaenzt leere Felder ohne vorhandene Werte zu ueberschreiben.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 6. Export und Berichte ─────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="6. Export und Berichte" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>

                <TextBlock Text="Excel-Export" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8">
                    Template-basierter Export aller Haltungen und Schaechte nach Excel.
                    Benutzerdefinierte Vorlagen steuern Spaltenzuordnung und Formatierung.
                </TextBlock>

                <TextBlock Text="Inspektionsprotokoll PDF" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8">
                    Generiert professionelle PDF-Inspektionsprotokolle mit VSA-Codes, Fotos,
                    Beobachtungen und KI-generierten Beschreibungen.
                </TextBlock>

                <TextBlock Text="Kostenzusammenstellung PDF" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8">
                    Exportiert die Sanierungskostenberechnung als PDF mit Positionsaufstellung,
                    Einzelpreisen, Mengen und Gesamtkosten inkl. MWST.
                </TextBlock>

                <TextBlock Text="KI-Dokumentation PDF" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8">
                    Detaillierte Dokumentation der KI-Erkennung mit Evidence-Vektoren,
                    Quality-Gate-Metriken und Modellkonfidenz fuer Nachvollziehbarkeit.
                </TextBlock>

                <TextBlock Text="Verteilung" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                    Verteilt exportierte Dateien in Ordnerstrukturen sortiert nach Haltung,
                    Schacht oder Pruefstatus fuer organisierte Archivierung.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 7. VSA-Zustandsbewertung ───────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="7. VSA-Zustandsbewertung" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="12" LineHeight="20">
                    Die VSA-Bewertung klassifiziert den baulichen und betrieblichen Zustand von
                    Kanaelen und Schaechten in 5 Klassen (0-4) gemaess SN EN 13508-2:
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,8,0,2">
                    Klasse 0: Kein Schaden - Kein Handlungsbedarf
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2">
                    Klasse 1: Leichter Schaden - Langfristiger Handlungsbedarf
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2">
                    Klasse 2: Mittlerer Schaden - Mittelfristiger Handlungsbedarf
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2">
                    Klasse 3: Schwerer Schaden - Kurzfristiger Handlungsbedarf
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,10">
                    Klasse 4: Sehr schwerer Schaden - Sofortiger Handlungsbedarf
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="12" LineHeight="20">
                    Die Berechnung basiert auf dem Klassifikationskatalog mit separaten Regelwerken
                    fuer Kanaele (classification_channels.json) und Schaechte (classification_manholes.json).
                    Jeder erfasste Schadencode wird anhand seines Schweregrad-Faktors, der Quantifizierung
                    und des Rohr-Materials/DN bewertet. Der schlechteste Einzelwert bestimmt die Gesamtklasse.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 8. Kostenrechner ───────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="8. Kostenrechner und Sanierung" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="12" LineHeight="20">
                    Der integrierte Kostenrechner kalkuliert Sanierungskosten auf Basis eines
                    konfigurierbaren Katalogs mit Einheitspreisen.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,8,0,2">
                    Massnahmen-Vorlagen: Vordefinierte Sanierungsverfahren (z.B. Inliner GFK, Inliner Nadelfilz,
                    Kurzliner, Manschetten, Robotersanierung) mit voreingestellten Positionen.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,2">
                    Katalogpositionen: Einzelne Leistungspositionen mit Einheit und Preis.
                    Per Drag-and-Drop in Massnahmen-Bloecke ziehbar.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,2">
                    Automatische Preisberechnung: DN-abhaengige Preise, laengenabhaengige Mengen
                    und Anschluss-Zuschlaege werden automatisch berechnet.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,2">
                    Vorlagen speichern: Angepasste Positionen koennen als neue Vorlage gespeichert werden.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0">
                    Transfer-Markierung: Rechtsklick auf Positionen markiert sie gruen fuer den
                    selektiven Uebertrag in andere Systeme.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 9. Tastaturkuerzel ─────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="9. Tastaturkuerzel" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>

                <TextBlock Text="Allgemein" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="F11          Fokusmodus ein/aus"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,8"
                           FontFamily="Consolas" Text="Doppelklick  Protokoll/KI oeffnen (auf Haltung)"/>

                <TextBlock Text="Videoplayer" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="Leertaste    Play/Pause umschalten"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="Pfeil rechts +5 Sekunden vorspulen"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="Pfeil links  -5 Sekunden zurueckspulen"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="+            Geschwindigkeit erhoehen (+0.25x)"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="-            Geschwindigkeit verringern (-0.25x)"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="S            Video stoppen"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="P            Video pausieren"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="12,0,0,0"
                           FontFamily="Consolas" Text="R            Video fortsetzen"/>
            </StackPanel>
        </Border>

        <!-- ── 10. Umgebungsvariablen ─────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="10. KI-Konfiguration (Umgebungsvariablen)" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>

                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="12" LineHeight="20" Margin="0,0,0,8">
                    Die KI-Module werden ueber Umgebungsvariablen konfiguriert.
                    Alle Variablen sind optional - Standardwerte werden verwendet wenn nicht gesetzt.
                </TextBlock>

                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,3" FontFamily="Consolas"
                           Text="SEWERSTUDIO_AI_ENABLED=1"/>
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="12,0,0,8"
                           Text="KI-Funktionen aktivieren (0=deaktiviert, 1=aktiviert)"/>

                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,3" FontFamily="Consolas"
                           Text="SEWERSTUDIO_OLLAMA_URL=http://localhost:11434"/>
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="12,0,0,8"
                           Text="Adresse des Ollama-Service"/>

                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,3" FontFamily="Consolas"
                           Text="SEWERSTUDIO_AI_VISION_MODEL=qwen3.5:27b"/>
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="12,0,0,8"
                           Text="Vision-Modell fuer Bildanalyse (Multimodal)"/>

                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,3" FontFamily="Consolas"
                           Text="SEWERSTUDIO_AI_TEXT_MODEL=qwen3.5:27b"/>
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="12,0,0,8"
                           Text="Text-Modell fuer Protokolle und Beschreibungen"/>

                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,3" FontFamily="Consolas"
                           Text="SEWERSTUDIO_AI_EMBED_MODEL=nomic-embed-text"/>
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="12,0,0,8"
                           Text="Embedding-Modell fuer Knowledge Base (Semantische Suche)"/>

                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,3" FontFamily="Consolas"
                           Text="SEWERSTUDIO_SIDECAR_URL=http://localhost:8100"/>
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="12,0,0,8"
                           Text="Python-Sidecar fuer YOLO/DINO/SAM Vision-Pipeline"/>

                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,3" FontFamily="Consolas"
                           Text="SEWERSTUDIO_FFMPEG=ffmpeg"/>
                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="12,0,0,0"
                           Text="Pfad zu FFmpeg fuer Video-Frame-Extraktion"/>
            </StackPanel>
        </Border>

        <!-- ── Version ────────────────────────────────────────────────── -->
        <Border Margin="0,0,0,20" Padding="14,10"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" TextAlignment="Center">
                SewerStudio - Professionelle Kanalinspektion und KI-Analyse
            </TextBlock>
        </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
