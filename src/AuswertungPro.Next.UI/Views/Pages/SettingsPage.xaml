                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="15. Kostenrechner und Sanierung" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,2">
                    Massnahmen-Vorlagen: Inliner GFK/Nadelfilz, Kurzliner, Manschetten, Robotersanierung.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,2">
                    Katalogpositionen per Drag-and-Drop. DN-abhaengige Preise, laengenabhaengige Mengen.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,2">
                    KI-Optimierung: LLM empfiehlt kostenoptimale Massnahmen mit Konfidenz und Kostenband.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,0">
                    Kombinierte Offerte fuer mehrere Haltungen (Netto/MWST/Total). PDF-Export.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 16. Eigendevis ─────────────────────────────────────────── -->
