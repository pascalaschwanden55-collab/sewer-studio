<UserControl x:Class="AuswertungPro.Next.UI.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="True"
                  Padding="0,0,8,0">
        <StackPanel>
            <!-- Phase 3.2: Typography-Token TypeH4 (16) — vorher Inline FontSize="{StaticResource TypeH4}". -->
            <TextBlock Text="Einstellungen" FontSize="{StaticResource TypeH4}" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <TextBlock Text="Design" Margin="0,0,0,6" Foreground="{StaticResource MutedBrush}"/>
        <DockPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Hell" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <ToggleButton IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" Width="64" Height="30">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Track"
                                    Background="{StaticResource SurfaceSubtleBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="15">
                                <Grid>
                                    <Ellipse x:Name="Thumb"
                                             Width="24"
                                             Height="24"
                                             Margin="3"
                                             HorizontalAlignment="Left"
                                             Fill="{StaticResource CardBrush}"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <TextBlock Text="Dunkel" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0"/>
            </StackPanel>
            <Button Content="Design anwenden"
                    Command="{Binding ApplyThemeCommand}"
                    Margin="8,0,0,0"
                    Width="150"
                    ToolTip="Gewaehltes Farbschema (Hell/Dunkel) sofort anwenden"/>
        </DockPanel>
        <!-- Phase 3.2: Typography-Token TypeCaption (11) — vorher Inline FontSize="{StaticResource TypeCaption}". -->
        <TextBlock Text="Hinweis: fuer volle Umstellung ist ein Neustart noetig."
                   Margin="0,4,0,0"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="{StaticResource TypeCaption}"/>

        <CheckBox Content="Diagnose aktiv (Fehlercodes anzeigen)" IsChecked="{Binding EnableDiagnostics}"/>

        <!-- Phase 1.4: Expertenmodus-Toggle. Default = aktiv (alles sichtbar wie heute). -->
        <CheckBox Content="Expertenmodus: Eigendevis + Hydraulik im Hauptmenue/Toolbar"
                  IsChecked="{Binding ShowExpertenmodusFeatures}"
                  ToolTip="Bei aus: Eigendevis-Page wird aus dem Hauptmenue ausgeblendet, Hydraulik-Toolbar-Buttons in der Haltungen-Page werden versteckt. Aenderung greift nach Neustart."
                  Margin="0,8,0,0"/>

        <TextBlock Text="pdftotext.exe Pfad" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <DockPanel>
            <TextBox Text="{Binding PdfToTextPath}" MinWidth="400" />
            <Button Content="..." Command="{Binding BrowsePdfToTextCommand}" Margin="8,0,0,0" Width="44" ToolTip="Pfad zur pdftotext.exe per Dialog auswaehlen"/>
        </DockPanel>

        <TextBlock Text="Projektpfad (*.json)" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <DockPanel>
            <TextBox Text="{Binding ProjectPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="400" />
            <Button Content="..." Command="{Binding BrowseProjectPathCommand}" Margin="8,0,0,0" Width="44" ToolTip="Projektdatei (JSON) per Dialog auswaehlen"/>
        </DockPanel>

        <TextBlock Text="Video-Ordner (Haltungen)" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <DockPanel>
            <TextBox Text="{Binding VideoFolder}" MinWidth="400" />
            <Button Content="..." Command="{Binding BrowseVideoFolderCommand}" Margin="8,0,0,0" Width="44" ToolTip="Video-Ordner mit Haltungsvideos per Dialog auswaehlen"/>
        </DockPanel>

        <TextBlock Text="Automatisches Speichern" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <ComboBox ItemsSource="{Binding AutoSaveModeOptions}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Label"
                  SelectedValue="{Binding DataAutoSaveMode, Mode=TwoWay}"
                  MinWidth="260"/>

        <TextBlock Text="Sicherheit" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <StackPanel>
            <CheckBox Content="Wiederherstellungspunkte vor dem Speichern erstellen" IsChecked="{Binding EnableRestorePoints}"/>
            <DockPanel Margin="0,6,0,0">
                <TextBox Text="{Binding RestorePointsFolderPath}" MinWidth="400" IsReadOnly="True" />
                <Button Content="Wiederherstellung oeffnen" Command="{Binding OpenRestorePointsFolderCommand}" Margin="8,0,0,0" Width="180" ToolTip="Ordner mit gespeicherten Wiederherstellungspunkten im Explorer oeffnen"/>
            </DockPanel>
        </StackPanel>

        <TextBlock Text="Video-Player" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <StackPanel>
            <CheckBox Content="Hardware-Decoding aktiv" IsChecked="{Binding VideoHwDecoding}"/>
            <CheckBox Content="Drop late frames" IsChecked="{Binding VideoDropLateFrames}" Margin="0,4,0,0"/>
            <CheckBox Content="Skip frames" IsChecked="{Binding VideoSkipFrames}" Margin="0,4,0,0"/>

            <WrapPanel Margin="0,8,0,0">
                <TextBlock Text="Video Output:" VerticalAlignment="Center" Width="120"/>
                <ComboBox Width="220"
                          ItemsSource="{Binding VideoOutputOptions}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Label"
                          SelectedValue="{Binding VideoOutput, Mode=TwoWay}"/>
            </WrapPanel>

            <WrapPanel Margin="0,8,0,0">
                <TextBlock Text="File Caching:" VerticalAlignment="Center" Width="120"/>
                <ComboBox Width="140"
                          ItemsSource="{Binding VideoCacheOptions}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Label"
                          SelectedValue="{Binding VideoFileCachingMs, Mode=TwoWay}"/>

                <TextBlock Text="Network Caching:" VerticalAlignment="Center" Width="130" Margin="16,0,0,0"/>
                <ComboBox Width="140"
                          ItemsSource="{Binding VideoCacheOptions}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Label"
                          SelectedValue="{Binding VideoNetworkCachingMs, Mode=TwoWay}"/>
            </WrapPanel>

            <WrapPanel Margin="0,8,0,0">
                <TextBlock Text="Codec Threads:" VerticalAlignment="Center" Width="120"/>
                <ComboBox Width="140"
                          ItemsSource="{Binding VideoCodecThreadOptions}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Label"
                          SelectedValue="{Binding VideoCodecThreads, Mode=TwoWay}"/>
            </WrapPanel>
        </StackPanel>

        <TextBlock Text="Datenordner (Settings/Logs)" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <DockPanel>
            <TextBox Text="{Binding DataFolderPath}" MinWidth="400" IsReadOnly="True" />
            <Button Content="Ordner oeffnen" Command="{Binding OpenDataFolderCommand}" Margin="8,0,0,0" Width="120" ToolTip="Datenordner mit Einstellungen und Logs im Explorer oeffnen"/>
        </DockPanel>

        <TextBlock Text="Logs" Margin="0,10,0,6" Foreground="{StaticResource MutedBrush}"/>
        <DockPanel>
            <TextBox Text="{Binding LogsFolderPath}" MinWidth="400" IsReadOnly="True" />
            <Button Content="Logs oeffnen" Command="{Binding OpenLogsFolderCommand}" Margin="8,0,0,0" Width="120" ToolTip="Log-Dateien im Explorer anzeigen fuer Fehleranalyse"/>
        </DockPanel>

        <TextBlock Text="KI-Wissen Backup" Margin="0,14,0,6" Foreground="{StaticResource MutedBrush}"/>
        <TextBlock Text="Exportiert alle KI-Lerndaten, Trainingssamples, Einstellungen und Frames als ZIP. Fuer Backup oder PC-Migration."
                   TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeCaption}" Margin="0,0,0,8"/>
        <StackPanel Orientation="Horizontal">
            <Button Content="KI-Wissen exportieren" Command="{Binding ExportBackupCommand}" Width="180" ToolTip="Alle KI-Lerndaten und Trainingssamples als ZIP-Datei sichern"/>
            <Button Content="KI-Wissen importieren" Command="{Binding ImportBackupCommand}" Margin="8,0,0,0" Width="180" ToolTip="KI-Lerndaten aus einer ZIP-Backup-Datei wiederherstellen"/>
        </StackPanel>
        <TextBlock Text="{Binding BackupStatusText}" Margin="0,6,0,0"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeCaption}"/>

            <Button Content="Speichern" Command="{Binding SaveCommand}" Margin="0,18,0,0" Width="160" ToolTip="Alle Einstellungen dauerhaft speichern"/>

        <!-- Phase 3.5: Anleitungstexte aus Settings ausgeblendet — User kann sie
             via Expander einklappen. Default eingeklappt: Settings-UI bleibt
             schlank, Anleitung bleibt fuer Bedarfsfall zugaenglich. Audit:
             Anleitungstexte aus Settings in eigene Hilfe-Seite (UI-Aufraeumen). -->
        <Expander Margin="0,32,0,0"
                  IsExpanded="False"
                  Header="Programm-Anleitung — SewerStudio (20 Module, KI-Pipeline, Workflows)">
            <StackPanel Margin="0,12,0,0">

        <TextBlock Text="Vollstaendige Dokumentation aller 20 Module, KI-Pipeline, Workflows und Konfiguration."
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,20" FontSize="{StaticResource TypeSmall}"/>

        <!-- ── 1. Uebersicht ──────────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="1. Programmueberblick" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource TypeSmall}" LineHeight="20">
                    SewerStudio ist eine professionelle WPF-Anwendung fuer die Kanalinspektion und
                    Zustandsbewertung nach SN EN 13508-2 und VSA-KEK Schweiz 2023. Die Software vereint
                    Datenerfassung, Videoanalyse, KI-gestuetzte Schadenserkennung (YOLO, Grounding DINO,
                    SAM, Qwen Vision-LLM), VSA-Zustandsbewertung, Sanierungskostenberechnung und
                    automatisiertes Selbsttraining in einer einzigen lokalen Plattform — ohne Cloud-Anbindung.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource TypeSmall}" LineHeight="20" Margin="0,8,0,0">
                    Typischer Arbeitsablauf: Projekt erstellen → Inspektionsdaten importieren (PDF/XTF/WinCan/IBAK/KINS) →
                    Videos verknuepfen → KI-Analyse oder manueller Codier-Modus → VSA-Bewertung berechnen →
                    Sanierungsmassnahmen vorschlagen → Ergebnisse als Excel/PDF exportieren.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 2. Seitennavigation ────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="2. Seiten und Navigation" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>

                <TextBlock Text="Uebersicht" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,10">
                    Startseite mit Projektverwaltung. Zeigt alle Projekte mit Statistiken,
                    Schnellzugriff auf das zuletzt bearbeitete Projekt. Drag-and-Drop von Projektdateien unterstuetzt.
                </TextBlock>

                <TextBlock Text="Projekt" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,10">
                    Metadaten: Name, Beschreibung, Auftraggeber, Gemeinde, Zone, Inspektionsdatum, Firma.
                    Diese Angaben erscheinen auf allen exportierten Berichten und Protokollen.
                </TextBlock>

                <TextBlock Text="Haltungen" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,10">
                    Zentrale Datenseite mit 25-Spalten DataGrid, Suche, Zoom, Multi-Monitor-Support (Abdocken).
                    Toolbar-Dropdowns: KI-Tools, Sanierungsmassnahmen, Medien suchen, Hydraulik.
                    Kontextmenue: Protokoll, Videoanalyse, Kostenrechner, Detailansicht.
                </TextBlock>

                <TextBlock Text="Schaechte · Import · Export · Medienkonflikte · Druckcenter · VSA · Eigendevis · Diagnose · Einstellungen"
                           FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}">
                    Weitere Seiten fuer Schacht-Verwaltung, Datenimport (Sektion 5), Datenexport (Sektion 6),
                    Medien-Konfliktloesung (Sektion 19), Druckansicht mit Filteroptionen, VSA-Bewertung (Sektion 15),
                    Eigendevis (Sektion 17), Live-Diagnoseprotokoll und diese Einstellungsseite.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 3. Projekt-Management ──────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="3. Projekt-Management" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource TypeSmall}" LineHeight="20">
                    Projekte werden als JSON-Dateien gespeichert (atomarer Schreibvorgang mit Backup).
                    AutoSave speichert automatisch im konfigurierbaren Intervall. Wiederherstellungspunkte
                    werden vor jedem Speichern optional erstellt. KI-Wissen (Trainingssamples, Frames,
                    Knowledge Base) kann als ZIP exportiert und auf einen anderen PC importiert werden.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 4. Haltungen und Schaechte ─────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="4. Haltungen und Schaechte" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource TypeSmall}" LineHeight="20">
                    Jede Haltung ist ein Kanalsegment zwischen zwei Schaechten (typisch 30-80m). DataGrid
                    mit 25 Spalten: Name, Anfangs-/Endschacht, DN, Material, Laenge, Baujahr, Nutzungsart,
                    Eigentuemer, Zustandsklasse, Sanierungsmassnahme, Kosten, Video, PDF etc.
                    Inline-Editing, Suche, Filter, Multi-Monitor-Abdocken. Doppelklick oeffnet das Protokoll.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 5. Fenster und Dialoge ─────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="5. Fenster und Dialoge" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>

                <TextBlock Text="Videoplayer" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,8">
                    VLC-basierter Player mit variabler Geschwindigkeit (0.5x-8x), Live-Scrubbing,
                    Schadenscode-Marker auf der Zeitleiste, Accept/Edit/Reject-Workflow fuer KI-Vorschlaege,
                    PipeGraph-Timeline und Inline-Codierung waehrend der Wiedergabe.
                </TextBlock>

                <TextBlock Text="Codier-Modus" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,8">
                    Dediziertes Fenster fuer manuelle Codierung waehrend der Video-Wiedergabe.
                    Schnelltasten fuer haeufige Codes, manuelles Markieren (Punkt, Ellipse, Freihand, Rechteck),
                    OSD-Meterstand-Erkennung und Session-Tracking fuer KI-Training.
                </TextBlock>

                <TextBlock Text="Sanierungsmassnahmen" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,8">
                    Vereinheitlichtes Fenster: Links Haltungskontext und KI-Empfehlung, rechts Kostenrechner
                    mit Drag-and-Drop von Katalogpositionen. Footer: Netto/MWST/Total, PDF-Export.
                </TextBlock>

                <TextBlock Text="Videoanalyse-Pipeline · Training Center · Medien-Suchprogramm · Beobachtungen · Kataloge"
                           FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}">
                    Weitere Fenster: KI-Pipeline-Monitor (Sektion 10), Training Center (Sektion 14),
                    Batch-Mediensuche, Beobachtungskatalog mit VSA-Codes, Haltungsdetails, VSA-Code-Explorer,
                    Hydraulik-Panel, Fotovermessung, Abgedocktes DataGrid fuer Multi-Monitor und Dossier-Druck.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 6. Import-System ───────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="6. Import-System" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,4">
                    PDF-Import (OCR via pdftotext, Formularfelder, Fretz AG/KIT/Abwasser Uri Formate).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,4">
                    XTF/M150/MDB (SIA 405 Austauschformat), WinCan, IBAK, KINS.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}">
                    Merge-Engine mit Prioritaetsregeln und Konfliktbehandlung. Import-Vorschau und Bericht.
                    Option "Nur fehlende Felder auffuellen" ergaenzt ohne zu ueberschreiben.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 7. Export und Berichte ─────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="7. Export und Berichte" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,4">
                    Excel-Export mit konfigurierbaren Vorlagen. Haltungsdossier PDF mit VSA-Codes und Fotos.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,4">
                    Hydraulik-Bericht PDF (DWA-A 110). KI-Dokumentation PDF mit Evidence-Vektoren.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}">
                    Kostenzusammenstellung PDF mit Positionsaufstellung und MWST.
                    Verteilung sortiert Dateien in Ordnerstrukturen nach Haltung/Schacht/Status.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 8. Protokoll-System ────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="8. Protokoll-System" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource TypeSmall}" LineHeight="20">
                    Jede Haltung hat ein Inspektionsprotokoll mit Revisionen und Aenderungshistorie.
                    Eintraege bestehen aus: VSA-Schadencode, Meterstand, Uhrlage, Quantifizierung,
                    Beschreibungstext, Foto und Quelle (Importiert/Manuell/KI).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,8,0,0">
                    Code-Picker mit hierarchischem VSA-Code-Browser. KI-Vorschlaege (Accept/Edit/Reject).
                    Jede Bearbeitung wird mit Zeitstempel und Vorher/Nachher-Wert protokolliert.
                    Boundary-Erkennung fuer Anfangs- und End-Fotos der Haltung.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 9. KI-Pipeline ─────────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="9. KI-Pipeline (Multi-Model)" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>

                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource TypeSmall}" LineHeight="20" Margin="0,0,0,8">
                    Vollstaendig lokale Multi-Model KI-Pipeline zur automatischen Schadenserkennung:
                </TextBlock>

                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,2">
                    1. Frame-Extraktion: FFmpeg extrahiert Einzelbilder (konfigurierbar, Standard 1.5s).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,2">
                    2. YOLO26m-seg: Echtzeit-Objekterkennung und Segmentierung (~1.5GB VRAM, permanent).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,2">
                    3. Grounding DINO 1.5: Textbasierte Erkennung mit Prompts (~2GB VRAM).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,2">
                    4. SAM 3: Pixel-genaue Segmentierung fuer Quantifizierung (~2.5GB VRAM).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,2">
                    5. Qwen3-VL-8B (FastModel): Vision-LLM fuer Code-Zuordnung (~10GB VRAM via Ollama).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,2">
                    6. Qwen3-VL-32B (ReferenceModel): Eskalation bei Severity>=4 oder Unsicherheit (~22GB VRAM).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,8">
                    7. ByteTrack/OC-SORT: Temporal Tracking fuer konsistente Detektionen (CPU).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}">
                    Python-Sidecar (FastAPI, Port 8100) hostet YOLO/DINO/SAM/VSR. Ollama hostet Qwen-Modelle.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 10. KI-Qualitaetssicherung ─────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="10. KI-Qualitaetssicherung (Quality Gate)" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="{StaticResource TypeSmall}" LineHeight="20">
                    Ampelsystem (Gruen/Gelb/Rot) fuer alle KI-Ergebnisse:
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,8,0,2">
                    Evidence-Vektor: Kombiniert Konfidenzwerte aller Modelle zu einem Gesamtscore.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,2">
                    Monte-Carlo-Dropout und Temperatur-Skalierung fuer Unsicherheitsschaetzung.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,0">
                    Adaptive Gewichtung lernt, welchen Modellen pro Schadenstyp am meisten vertraut wird.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 11. Knowledge Base ─────────────────────────────────────── -->
        <Border Margin="0,0,0,16" Padding="14,12"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource CardBrush}" CornerRadius="6">
