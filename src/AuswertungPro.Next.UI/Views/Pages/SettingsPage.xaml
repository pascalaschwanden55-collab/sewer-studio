                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,0">
                    YOLO-Dataset-Export und Protokoll-Training mit Few-Shot-Beispielen.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 14. VSA-Zustandsbewertung ──────────────────────────────── -->
