                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,3" FontFamily="Consolas"
                           Text="SEWERSTUDIO_SIDECAR_URL=localhost:8100   Python-Sidecar"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,14" FontFamily="Consolas"
                           Text="SEWERSTUDIO_FFMPEG=ffmpeg                FFmpeg-Pfad"/>

                <TextBlock Text="Tastaturkuerzel" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="F11          Fokusmodus ein/aus"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="Doppelklick  Protokoll/KI oeffnen"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="Leertaste    Play/Pause umschalten"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="Pfeiltasten  +/-5 Sekunden spulen"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,2"
                           FontFamily="Consolas" Text="+/-          Geschwindigkeit aendern"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="12,0,0,0"
                           FontFamily="Consolas" Text="S/P/R        Stoppen/Pausieren/Fortsetzen"/>
            </StackPanel>
        </Border>

        <!-- ── Version ────────────────────────────────────────────────── -->
        <Border Margin="0,0,0,20" Padding="14,10"
                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
