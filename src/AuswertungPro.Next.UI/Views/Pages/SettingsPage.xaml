                <TextBlock Text="Umgebungsvariablen" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,3" FontFamily="Consolas"
                           Text="SEWERSTUDIO_AI_ENABLED=1                  KI aktivieren (0/1)"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,3" FontFamily="Consolas"
                           Text="SEWERSTUDIO_OLLAMA_URL=localhost:11434    Ollama-Adresse"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,3" FontFamily="Consolas"
                           Text="SEWERSTUDIO_AI_VISION_MODEL=qwen3-vl:8b  FastModel (~10GB VRAM)"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,0,0,3" FontFamily="Consolas"
