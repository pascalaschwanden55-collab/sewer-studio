                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,2">
                    Konfidenzverteilung: Histogramm der Vorhersage-Konfidenzwerte ueber alle Modelle.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource TypeSmall}" Margin="0,2,0,0">
                    Modell-Registry: Versionierung aller KI-Modelle. Pipeline-Telemetrie: Latenz und VRAM.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── 20. KI-Konfiguration und Tastaturkuerzel ──────────────── -->
