<Window x:Class="AuswertungPro.Next.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:AuswertungPro.Next.UI.Controls"
        x:Name="RootWindow"
        Title="{Binding Title}" Width="1200" Height="750" MinWidth="1000" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Closing="MainWindow_Closing">
    <Window.Resources>
        <ctrl:PercentToWidthConverter x:Key="PercentToWidthConverter"/>
        <ctrl:PercentToColorConverter x:Key="PercentToColorConverter"/>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="F11" Command="{Binding ToggleFocusModeCommand}"/>
    </Window.InputBindings>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <Menu.Style>
                <Style TargetType="Menu">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFocusMode}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Menu.Style>
            <MenuItem Header="_Datei">
                <MenuItem Header="Neues Projekt" Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="Projekt öffnen..." Command="{Binding OpenProjectCommand}"/>
                <MenuItem Header="Speichern" Command="{Binding SaveCommand}"/>
                <MenuItem Header="Speichern unter..." Command="{Binding SaveAsProjectCommand}"/>
                <Separator/>
                <MenuItem Header="Beenden" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Werkzeuge">
                <MenuItem Header="Code-Katalog..." Click="OpenCodeCatalog_Click"/>
                <Separator/>
                <MenuItem Header="KI Videoanalyse – Training Center..." Click="OpenTrainingCenter_Click"/>
            </MenuItem>
            <MenuItem Header="_Ansicht">
                <MenuItem Header="Fokusmodus (F11)" IsCheckable="True" IsChecked="{Binding IsFocusMode, Mode=TwoWay}" />
            </MenuItem>

        </Menu>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition>
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="220"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsFocusMode, ElementName=RootWindow}" Value="True">
                                <Setter Property="Width" Value="0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource NavPanelBrush}" BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource BorderBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.IsFocusMode, ElementName=RootWindow}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,8">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="4" Height="20" CornerRadius="2" Margin="0,0,10,0"
                                Background="{StaticResource AccentBrush}"/>
                        <TextBlock Text="SEWER STUDIO" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   FontFamily="Consolas, Segoe UI"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Subtitle}" Margin="14,3,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <Border Height="2" Margin="0,12,0,0" CornerRadius="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{StaticResource ColorAccent}" Offset="0"/>
                                <GradientStop Color="{StaticResource ColorAccentLight}" Offset="0.4"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <!-- System Monitor -->
                <Border DockPanel.Dock="Bottom" Margin="12,4,12,12" Padding="10,8" CornerRadius="6"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                    <Border.Background>
                        <SolidColorBrush Color="#FFF0F3F8"/>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="LEISTUNGSMONITOR" FontSize="9" FontWeight="Bold" FontFamily="Consolas"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>

                        <!-- ═══════════════ CPU ═══════════════ -->
                        <TextBlock FontSize="8" FontFamily="Consolas" Foreground="{StaticResource MutedBrush}" Opacity="0.6"
                                   Text="{Binding Monitor.CpuName, Mode=OneWay}" TextTrimming="CharacterEllipsis" Margin="0,0,0,3"/>
                        <!-- CPU Bar -->
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CPU" FontSize="10" FontWeight="SemiBold" FontFamily="Consolas"
                                       Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Height="5" CornerRadius="2.5"
                                    Background="#FFDAE1ED" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Border CornerRadius="2.5" HorizontalAlignment="Left"
                                        Background="{Binding DataContext.Monitor.CpuPercent, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PercentToColorConverter}}">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                            <Binding Path="DataContext.Monitor.CpuPercent" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <TextBlock Grid.Column="2" FontSize="10" FontWeight="SemiBold" FontFamily="Consolas" MinWidth="28"
                                       Foreground="{Binding Monitor.CpuPercent, Converter={StaticResource PercentToColorConverter}}" TextAlignment="Right"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding Monitor.CpuPercent, Mode=OneWay}"/><Run Text="%"/>
                            </TextBlock>
                        </Grid>
                        <!-- CPU Details: Takt + Temp -->
                        <Grid Margin="34,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="9" FontFamily="Consolas"
                                       Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Monitor.IsCpuClockAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="Takt: "/><Run Text="{Binding Monitor.CpuClockMhz, Mode=OneWay, StringFormat=N0}"/><Run Text=" MHz"/>
                            </TextBlock>
                            <TextBlock Grid.Column="0" FontSize="9" FontFamily="Consolas"
                                       Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Text" Value="Takt: n/a"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Monitor.IsCpuClockAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Monitor.IsSensorBlocked}" Value="True">
                                                <Setter Property="Text" Value="Takt: geschuetzt"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.ToolTip>
                                    <TextBlock Text="{Binding Monitor.SensorBlockedReason, Mode=OneWay}"/>
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <TextBlock Grid.Column="1" FontSize="9" FontFamily="Consolas"
                                       Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Monitor.IsCpuTempAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="Temp: "/><Run Text="{Binding Monitor.CpuTempC, Mode=OneWay}"/><Run Text=" °C"/>
                            </TextBlock>
                            <TextBlock Grid.Column="1" FontSize="9" FontFamily="Consolas"
                                       Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Text" Value="Temp: n/a"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Monitor.IsCpuTempAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Monitor.IsSensorBlocked}" Value="True">
                                                <Setter Property="Text" Value="Temp: geschuetzt"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.ToolTip>
                                    <TextBlock Text="{Binding Monitor.SensorBlockedReason, Mode=OneWay}"/>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </Grid>

                        <!-- ═══════════════ RAM ═══════════════ -->
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,8" Opacity="0.3"/>
                        <!-- RAM Bar -->
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="RAM" FontSize="10" FontWeight="SemiBold" FontFamily="Consolas"
                                       Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Height="5" CornerRadius="2.5"
                                    Background="#FFDAE1ED" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Border CornerRadius="2.5" HorizontalAlignment="Left"
                                        Background="{Binding DataContext.Monitor.RamPercent, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PercentToColorConverter}}">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                            <Binding Path="DataContext.Monitor.RamPercent" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <TextBlock Grid.Column="2" FontSize="10" FontWeight="SemiBold" FontFamily="Consolas" MinWidth="28"
                                       Foreground="{Binding Monitor.RamPercent, Converter={StaticResource PercentToColorConverter}}" TextAlignment="Right"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding Monitor.RamPercent, Mode=OneWay}"/><Run Text="%"/>
                            </TextBlock>
                        </Grid>
                        <!-- RAM Details: Takt + Temp + Speicher -->
                        <Grid Margin="34,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="9" FontFamily="Consolas"
                                       Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Monitor.IsRamClockAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="Takt: "/><Run Text="{Binding Monitor.RamClockMhz, Mode=OneWay, StringFormat=N0}"/><Run Text=" MHz"/>
                            </TextBlock>
                            <TextBlock Grid.Column="0" FontSize="9" FontFamily="Consolas"
                                       Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Text" Value="Takt: n/a"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Monitor.IsRamClockAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Monitor.IsSensorBlocked}" Value="True">
                                                <Setter Property="Text" Value="Takt: geschuetzt"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.ToolTip>
                                    <TextBlock Text="{Binding Monitor.SensorBlockedReason, Mode=OneWay}"/>
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <TextBlock Grid.Column="1" FontSize="9" FontFamily="Consolas"
                                       Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Monitor.IsRamTempAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="Temp: "/><Run Text="{Binding Monitor.RamTempC, Mode=OneWay}"/><Run Text=" °C"/>
                            </TextBlock>
                            <TextBlock Grid.Column="1" FontSize="9" FontFamily="Consolas"
                                       Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Text" Value="Temp: n/a"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Monitor.IsRamTempAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Monitor.IsSensorBlocked}" Value="True">
                                                <Setter Property="Text" Value="Temp: geschuetzt"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.ToolTip>
                                    <TextBlock Text="{Binding Monitor.SensorBlockedReason, Mode=OneWay}"/>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </Grid>
                        <TextBlock FontSize="9" FontFamily="Consolas" Foreground="{StaticResource MutedBrush}" Opacity="0.7" Margin="34,0,0,8">
                            <Run Text="{Binding Monitor.RamUsedMb, Mode=OneWay, StringFormat=N0}"/><Run Text=" / "/>
                            <Run Text="{Binding Monitor.RamTotalMb, Mode=OneWay, StringFormat=N0}"/><Run Text=" MB"/>
                        </TextBlock>

                        <!-- ═══════════════ GPU ═══════════════ -->
                        <StackPanel>
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,8" Opacity="0.3"/>

                            <TextBlock FontSize="8" FontFamily="Consolas" Foreground="{StaticResource MutedBrush}" Opacity="0.6"
                                       Text="{Binding Monitor.GpuName, Mode=OneWay}" TextTrimming="CharacterEllipsis" Margin="0,0,0,3">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Monitor.IsGpuAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock FontSize="8" FontFamily="Consolas" Foreground="{StaticResource MutedBrush}" Opacity="0.6"
                                       Text="GPU nicht erkannt" Margin="0,0,0,3">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Monitor.IsGpuAvailable}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- GPU Bar -->
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="GPU" FontSize="10" FontWeight="SemiBold" FontFamily="Consolas"
                                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Height="5" CornerRadius="2.5"
                                        Background="#FFDAE1ED" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Border CornerRadius="2.5" HorizontalAlignment="Left"
                                            Background="{Binding DataContext.Monitor.GpuPercent, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PercentToColorConverter}}">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                <Binding Path="DataContext.Monitor.GpuPercent" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}"/>
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                </Border>
                                <TextBlock Grid.Column="2" FontSize="10" FontWeight="SemiBold" FontFamily="Consolas" MinWidth="28"
                                           Foreground="{Binding Monitor.GpuPercent, Converter={StaticResource PercentToColorConverter}}" TextAlignment="Right"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Monitor.IsGpuAvailable}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding Monitor.GpuPercent, Mode=OneWay}"/><Run Text="%"/>
                                </TextBlock>
                                <TextBlock Grid.Column="2" FontSize="10" FontWeight="SemiBold" FontFamily="Consolas" MinWidth="28"
                                           Foreground="{StaticResource MutedBrush}" TextAlignment="Right"
                                           VerticalAlignment="Center" Text="n/a">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Monitor.IsGpuAvailable}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <!-- GPU Details: Takt + Temp -->
                            <Grid Margin="34,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="9" FontFamily="Consolas"
                                           Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Monitor.IsGpuClockAvailable}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="Takt: "/><Run Text="{Binding Monitor.GpuClockMhz, Mode=OneWay, StringFormat=N0}"/><Run Text=" MHz"/>
                                </TextBlock>
                                <TextBlock Grid.Column="0" FontSize="9" FontFamily="Consolas"
                                           Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Text" Value="Takt: n/a"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Monitor.IsGpuClockAvailable}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Monitor.IsSensorBlocked}" Value="True">
                                                    <Setter Property="Text" Value="Takt: geschuetzt"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.ToolTip>
                                        <TextBlock Text="{Binding Monitor.SensorBlockedReason, Mode=OneWay}"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Grid.Column="1" FontSize="9" FontFamily="Consolas"
                                           Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Monitor.IsGpuTempAvailable}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="Temp: "/><Run Text="{Binding Monitor.GpuTempC, Mode=OneWay}"/><Run Text=" °C"/>
                                </TextBlock>
                                <TextBlock Grid.Column="1" FontSize="9" FontFamily="Consolas"
                                           Foreground="{StaticResource MutedBrush}" Opacity="0.7">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Text" Value="Temp: n/a"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Monitor.IsGpuTempAvailable}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Monitor.IsSensorBlocked}" Value="True">
                                                    <Setter Property="Text" Value="Temp: geschuetzt"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.ToolTip>
                                        <TextBlock Text="{Binding Monitor.SensorBlockedReason, Mode=OneWay}"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </Grid>

                            <!-- VRAM Bar -->
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="VRAM" FontSize="9" FontWeight="SemiBold" FontFamily="Consolas"
                                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Height="5" CornerRadius="2.5"
                                        Background="#FFDAE1ED" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Border CornerRadius="2.5" HorizontalAlignment="Left"
                                            Background="{Binding DataContext.Monitor.GpuMemPercent, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PercentToColorConverter}}">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                <Binding Path="DataContext.Monitor.GpuMemPercent" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}"/>
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                </Border>
                                <TextBlock Grid.Column="2" FontSize="10" FontWeight="SemiBold" FontFamily="Consolas" MinWidth="28"
                                           Foreground="{Binding Monitor.GpuMemPercent, Converter={StaticResource PercentToColorConverter}}" TextAlignment="Right"
                                           VerticalAlignment="Center">
                                    <Run Text="{Binding Monitor.GpuMemPercent, Mode=OneWay}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            <TextBlock FontSize="9" FontFamily="Consolas" Foreground="{StaticResource MutedBrush}" Opacity="0.7" Margin="34,0,0,0">
                                <Run Text="{Binding Monitor.GpuMemUsedMb, Mode=OneWay, StringFormat=N0}"/><Run Text=" / "/>
                                <Run Text="{Binding Monitor.GpuMemTotalMb, Mode=OneWay, StringFormat=N0}"/><Run Text=" MB"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- KI Neural Sphere -->
                <Border DockPanel.Dock="Bottom" Margin="12,4,12,4" HorizontalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAiWorking}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <ctrl:NeuralSphereControl IsActive="{Binding IsAiWorking}"
                            StatusText="{Binding AiStatusLabel}" Width="160" Height="160"/>
                        <TextBlock Text="KI AKTIV" FontSize="10" FontWeight="Bold"
                            HorizontalAlignment="Center" Margin="0,2,0,0"
                            Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding AiStatusLabel}" FontSize="9"
                            HorizontalAlignment="Center" Margin="0,1,0,0"
                            Foreground="{StaticResource MutedBrush}"
                            TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                    </StackPanel>
                </Border>

                <ListBox ItemsSource="{Binding NavItems}" SelectedItem="{Binding SelectedNavItem}"
                         BorderThickness="0" Background="Transparent" Margin="8,4,8,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,4">
                                <Grid Width="24" Height="18" VerticalAlignment="Center">
                                    <TextBlock x:Name="DefaultNavIcon"
                                               Text="{Binding Icon}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="16"
                                               Width="24"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <Canvas x:Name="PipeNavIcon" Width="28" Height="20" Visibility="Collapsed">
                                        <Ellipse Canvas.Left="1.5" Canvas.Top="4" Width="7.5" Height="12"
                                                 Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.6"/>
                                        <Line X1="5.5" Y1="4" X2="22.5" Y2="4"
                                              Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.6"/>
                                        <Line X1="5.5" Y1="16" X2="22.5" Y2="16"
                                              Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.6"/>
                                        <Ellipse Canvas.Left="19" Canvas.Top="4" Width="7.5" Height="12"
                                                 Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.6"/>
                                    </Canvas>

                                    <Canvas x:Name="ShaftNavIcon" Width="28" Height="20" Visibility="Collapsed">
                                        <Ellipse Canvas.Left="6" Canvas.Top="2" Width="16" Height="4.5"
                                                 Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.6"/>
                                        <Rectangle Canvas.Left="8" Canvas.Top="4.5" Width="12" Height="10.5"
                                                   Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.6"/>
                                        <Ellipse Canvas.Left="8" Canvas.Top="13" Width="12" Height="4.5"
                                                 Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.6"/>
                                        <Line X1="2" Y1="10" X2="8" Y2="10"
                                              Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.6"/>
                                        <Line X1="20" Y1="10" X2="26" Y2="10"
                                              Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.6"/>
                                    </Canvas>

                                    <Canvas x:Name="VsaNavIcon" Width="28" Height="20" Visibility="Collapsed">
                                        <Ellipse Canvas.Left="1" Canvas.Top="10.5" Width="7" Height="7"
                                                 Fill="{StaticResource TextSecondaryBrush}"/>
                                        <Ellipse Canvas.Left="2.5" Canvas.Top="4.5" Width="5.5" Height="5.5"
                                                 Fill="{StaticResource TextSecondaryBrush}"/>
                                        <Ellipse Canvas.Left="6.5" Canvas.Top="1.5" Width="4.5" Height="4.5"
                                                 Fill="{StaticResource TextSecondaryBrush}"/>
                                        <Ellipse Canvas.Left="11.5" Canvas.Top="0.5" Width="3.8" Height="3.8"
                                                 Fill="{StaticResource TextSecondaryBrush}"/>
                                        <Ellipse Canvas.Left="16.5" Canvas.Top="2.3" Width="3.2" Height="3.2"
                                                 Fill="{StaticResource TextSecondaryBrush}"/>
                                        <Ellipse Canvas.Left="20.5" Canvas.Top="6" Width="2.8" Height="2.8"
                                                 Fill="{StaticResource TextSecondaryBrush}"/>
                                        <Ellipse Canvas.Left="22.8" Canvas.Top="10.8" Width="2.2" Height="2.2"
                                                 Fill="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Canvas.Left="12.5" Canvas.Top="12.5" Text="V"
                                                   FontSize="7" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Canvas>
                                </Grid>
                                <TextBlock Text="{Binding Title}" Margin="10,0,0,0" FontSize="13.5"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Title}" Value="Haltungen">
                                    <Setter TargetName="DefaultNavIcon" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="PipeNavIcon" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Title}" Value="Schaechte">
                                    <Setter TargetName="DefaultNavIcon" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="ShaftNavIcon" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Title}" Value="VSA">
                                    <Setter TargetName="DefaultNavIcon" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="VsaNavIcon" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="IsEnabled" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="AccentStrip" Grid.Column="0"
                                                    Background="{StaticResource AccentBrush}"
                                                    CornerRadius="1.5" Margin="0,6" Opacity="0"/>
                                            <Border x:Name="bd" Grid.Column="1" Background="Transparent"
                                                    CornerRadius="6" Padding="2"
                                                    Margin="4,0,0,0">
                                                <ContentPresenter/>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#FFDBEAFE"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter TargetName="AccentStrip" Property="Opacity" Value="1"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#FFE8EDF5"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsProjectReady, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="False">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Opacity" Value="0.5"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Title}" Value="Uebersicht">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Title}" Value="Projekt">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="16"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.IsFocusMode, ElementName=RootWindow}" Value="True">
                            <Setter Property="Margin" Value="8"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Style="{StaticResource Card}">
                <Grid>
                    <ctrl:AnimatedContentControl Content="{Binding CurrentPage}"/>
                    <Border Background="#F0F8FAFC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProjectReady}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedNavItem.Title}" Value="Projekt">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedNavItem.Title}" Value="Uebersicht">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
                            <TextBlock Text="Bitte zuerst ein Projekt speichern (Datei anlegen)." FontSize="16"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextAlignment="Center"/>
                            <TextBlock Text="Danach sind alle Funktionen freigeschaltet." Margin="0,6,0,0"
                                       Foreground="{StaticResource MutedBrush}" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
    </DockPanel>
</Window>
