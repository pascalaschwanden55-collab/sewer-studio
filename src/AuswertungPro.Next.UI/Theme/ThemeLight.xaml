<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         SCI-FI ENGINEERING — Sharp contrast, subtle futuristic tint
         High-readability. Blue-steel surfaces. No neon.
         ═══════════════════════════════════════════════════════════ -->

    <!-- ── ACCENT ── -->
    <Color x:Key="ColorAccent">#FF2563EB</Color>
    <Color x:Key="ColorAccentHover">#FF1D4ED8</Color>
    <Color x:Key="ColorAccentLight">#FF3B82F6</Color>
    <Color x:Key="ColorAccentSubtle">#FFD6E4F7</Color>

    <!-- ── SURFACES — Subtle blue-steel tint ── -->
    <Color x:Key="ColorBgLight">#FFF0F3F8</Color>
    <Color x:Key="ColorBgMid">#FFE6EBF3</Color>
    <Color x:Key="ColorCard">#FFFCFDFF</Color>
    <Color x:Key="ColorCardGlass">#FFFCFDFF</Color>
    <Color x:Key="ColorHeader">#FFE8EDF5</Color>
    <Color x:Key="ColorBorder">#FF9EAEC4</Color>
    <Color x:Key="ColorBorderLight">#FFCDD6E4</Color>

    <!-- ── TEXT — WCAG AAA contrast ── -->
    <Color x:Key="ColorTextPrimary">#FF0A0F1A</Color>
    <Color x:Key="ColorTextSecondary">#FF1C2536</Color>
    <Color x:Key="ColorTextMuted">#FF3D4D63</Color>

    <!-- ── SEMANTIC ── -->
    <Color x:Key="ColorSuccess">#FF16A34A</Color>
    <Color x:Key="ColorDanger">#FFDC2626</Color>
    <Color x:Key="ColorWarning">#FFF59E0B</Color>
    <Color x:Key="ColorInfo">#FF2563EB</Color>

    <!-- ── BACKWARD COMPAT — Legacy keys mapped to engineering palette ── -->
    <Color x:Key="ColorNeonCyan">#FF2563EB</Color>
    <Color x:Key="ColorNeonPurple">#FF7C3AED</Color>
    <Color x:Key="ColorNeonBlue">#FF2563EB</Color>
    <Color x:Key="ColorNeonGreen">#FF16A34A</Color>
    <Color x:Key="ColorNeonPink">#FFDC2626</Color>
    <Color x:Key="ColorNeonOrange">#FFEA580C</Color>
    <Color x:Key="ColorLcarsAmber">#FF2563EB</Color>
    <Color x:Key="ColorLcarsPeach">#FF64748B</Color>
    <Color x:Key="ColorLcarsLavender">#FF7C3AED</Color>
    <Color x:Key="ColorLcarsBlue">#FF2563EB</Color>
    <Color x:Key="ColorLcarsTan">#FFDBEAFE</Color>

    <!-- ── SOLID BRUSHES ── -->
    <SolidColorBrush x:Key="BgLightBrush" Color="{StaticResource ColorBgLight}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource ColorCard}"/>
    <SolidColorBrush x:Key="CardGlassBrush" Color="{StaticResource ColorCardGlass}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="HeaderBrush" Color="{StaticResource ColorHeader}"/>
    <SolidColorBrush x:Key="HeaderTextBrush" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource ColorTextMuted}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource ColorAccent}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ColorDanger}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource ColorInfo}"/>

    <!-- Legacy brush keys (still referenced in pages) -->
    <SolidColorBrush x:Key="NeonCyanBrush" Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="NeonBlueBrush" Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="NeonPinkBrush" Color="{StaticResource ColorDanger}"/>
    <SolidColorBrush x:Key="NeonPurpleBrush" Color="{StaticResource ColorNeonPurple}"/>
    <SolidColorBrush x:Key="NeonGreenBrush" Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="NeonOrangeBrush" Color="{StaticResource ColorNeonOrange}"/>
    <SolidColorBrush x:Key="LcarsAmberBrush" Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="LcarsPeachBrush" Color="{StaticResource ColorTextMuted}"/>
    <SolidColorBrush x:Key="LcarsLavenderBrush" Color="{StaticResource ColorNeonPurple}"/>
    <SolidColorBrush x:Key="LcarsBlueBrush" Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="LcarsTanBrush" Color="{StaticResource ColorAccentSubtle}"/>

    <!-- ── GRADIENT BRUSHES ── -->
    <LinearGradientBrush x:Key="BgBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF0F3F8" Offset="0"/>
        <GradientStop Color="#FFEAEFF6" Offset="0.5"/>
        <GradientStop Color="#FFE5EBF4" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="NeonGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ColorAccent}" Offset="0"/>
        <GradientStop Color="{StaticResource ColorAccentHover}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LcarsGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ColorAccent}" Offset="0"/>
        <GradientStop Color="{StaticResource ColorAccentLight}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LcarsHeaderBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ColorAccent}" Offset="0"/>
        <GradientStop Color="{StaticResource ColorAccentLight}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="NeonWarmGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ColorNeonOrange}" Offset="0"/>
        <GradientStop Color="{StaticResource ColorDanger}" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="GlassBrush" Color="Transparent"/>

    <!-- Nav sidebar: blue-steel tinted panel -->
    <LinearGradientBrush x:Key="NavPanelBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#FFF3F5FA" Offset="0"/>
        <GradientStop Color="#FFEDF0F7" Offset="0.5"/>
        <GradientStop Color="#FFE7ECF4" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="NeonBorderGlow" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource ColorAccent}" Offset="0"/>
        <GradientStop Color="{StaticResource ColorAccentHover}" Offset="1"/>
    </LinearGradientBrush>

    <!-- ═══════════════════════════════════════════════════════════
         WINDOW
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type Window}">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, Aptos, Arial"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Background" Value="{StaticResource BgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="AllowsTransparency" Value="True"/>
        <Setter Property="ResizeMode" Value="CanResizeWithGrip"/>
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         CARD — Clean white surface with subtle shadow
         ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#161E3050" BlurRadius="20" ShadowDepth="3" Direction="270" Opacity="1"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         BUTTON — Clean, no glow
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="MinWidth" Value="100"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="MainBorder" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource ColorAccent}" Opacity="0.04"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="MainBorder" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource ColorAccent}" Opacity="0.1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary Button — Blue filled -->
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource ColorAccent}"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Secondary Button — Subtle surface -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         TOOLBAR BUTTON — Compact, transparent background
         ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="ToolbarButton" TargetType="Button">
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FFE8EDF5"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="bd" Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FFCDD6E4"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FFCDD6E4"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Toolbar Accent Button — Blue accent for primary actions -->
    <Style x:Key="ToolbarButtonAccent" TargetType="Button">
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Name="bd"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Border.Background>
                            <SolidColorBrush Color="{StaticResource ColorAccent}"/>
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource ColorAccentHover}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FF1E40AF"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Toolbar Danger Button -->
    <Style x:Key="ToolbarButtonDanger" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
    </Style>

    <!-- Action Card Button -->
    <Style x:Key="ActionCardButton" TargetType="Button">
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource ColorAccent}" Opacity="0.04"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource ColorAccent}" Opacity="0.08"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Icon Button — Round, icon-only -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="MinWidth" Value="28"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FFE8EDF5"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FFCDD6E4"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CompactButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}"/>

    <!-- ═══════════════════════════════════════════════════════════
         TEXTBOX — Clean input with blue focus border
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                    Focusable="False"
                                    HorizontalScrollBarVisibility="Hidden"
                                    VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FF94A3B8"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         DATAGRID — Clean engineering grid
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="RowHeight" Value="36"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFCDD6E4"/>
            </Setter.Value>
        </Setter>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="RowBackground" Value="{StaticResource CardBrush}"/>
        <Setter Property="AlternatingRowBackground">
            <Setter.Value>
                <SolidColorBrush Color="#FFF3F5FA"/>
            </Setter.Value>
        </Setter>
        <Setter Property="AlternationCount" Value="2"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CanUserResizeColumns" Value="True"/>
        <Setter Property="CanUserSortColumns" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="Grayscale"/>
    </Style>

    <!-- DataGrid Header — Steel-blue tinted -->
    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FFE4EAF4"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFCDD6E4"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <Thumb x:Name="PART_LeftHeaderGripper"
                               HorizontalAlignment="Left" Width="6"
                               Background="Transparent" Cursor="SizeWE"/>
                        <Thumb x:Name="PART_RightHeaderGripper"
                               HorizontalAlignment="Right" Width="6"
                               Background="Transparent" Cursor="SizeWE"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4,2"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="{StaticResource ColorAccentSubtle}"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type DataGridRow}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#FFE8EDF5"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="{StaticResource ColorAccentSubtle}"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         LISTBOX
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="10,8"
                            BorderThickness="0">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource ColorAccentSubtle}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FFE8EDF5"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         GROUPBOX — Clean panel
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="6,6,0,0"
                                Padding="12,8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFE4EAF4" Offset="0"/>
                                    <GradientStop Color="#FFEDF1F7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter ContentSource="Header"
                                            TextElement.Foreground="{StaticResource TextBrush}"
                                            TextElement.FontWeight="Bold"
                                            TextElement.FontSize="13"/>
                        </Border>
                        <Border Grid.Row="1"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1,0,1,1"
                                CornerRadius="0,0,6,6"
                                Padding="16">
                            <ContentPresenter/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         MENU
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type Menu}">
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    </Style>

    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#FFE8EDF5"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         SCROLLBAR — Slim, neutral
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="8"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
