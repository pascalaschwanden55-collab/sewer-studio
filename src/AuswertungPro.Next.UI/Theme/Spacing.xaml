<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        Sprint 3 (2026-05-07): 4-Pixel-Spacing-Grid System.
        Alle neuen Margins/Paddings sollen sich an diesen Stufen orientieren.
        Bestehende Margins werden bei Hotspot-Migration angeglichen.

        Verwendung:
            Margin="{StaticResource MarginGroupBottom}"
            Padding="{StaticResource SP4}"

        Visuelle Grundsaetze:
            - SP1 (4px): innerhalb eng zusammengehoeriger Elemente
            - SP2 (8px): Standard-Element-Abstand
            - SP4 (16px): Standard-Container-Padding
            - SP6 (24px): Trennung von Gruppen
            - SP8 (32px): Trennung grosser Sektionen
    -->

    <!-- 4-Pixel Spacing Grid -->
    <sys:Double x:Key="SP1">4</sys:Double>
    <sys:Double x:Key="SP2">8</sys:Double>
    <sys:Double x:Key="SP3">12</sys:Double>
    <sys:Double x:Key="SP4">16</sys:Double>
    <sys:Double x:Key="SP5">20</sys:Double>
    <sys:Double x:Key="SP6">24</sys:Double>
    <sys:Double x:Key="SP8">32</sys:Double>
    <sys:Double x:Key="SP10">40</sys:Double>
    <sys:Double x:Key="SP12">48</sys:Double>
    <sys:Double x:Key="SP16">64</sys:Double>

    <!-- Standard-Thicknesses fuer haeufige Verwendungen.
         Decken die Top-3 Margin-Verwendungen aus dem 2026-05-07-Audit ab. -->
    <Thickness x:Key="MarginGroupBottom">0,0,0,16</Thickness>
    <Thickness x:Key="MarginItemBottom">0,0,0,8</Thickness>
    <Thickness x:Key="MarginLabelToInput">0,16,0,8</Thickness>
    <Thickness x:Key="MarginButtonRight">0,0,8,0</Thickness>
    <Thickness x:Key="MarginButtonLeft">8,0,0,0</Thickness>
    <Thickness x:Key="PaddingCard">16</Thickness>
    <Thickness x:Key="PaddingPage">16</Thickness>
    <Thickness x:Key="PaddingDialog">24</Thickness>
</ResourceDictionary>
